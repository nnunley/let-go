(ns clojure.core-test.portability
  (:require [test :refer :all]))

;; when-var-exists: In let-go we don't have compile-time resolve,
;; so we just always emit the body. Tests for missing vars will fail
;; at compile time and the Go runner treats those as SKIPs.
(defmacro when-var-exists [var-sym & body]
  `(do ~@body))

;; thrown?: portable exception assertion.
;; Used as (is (p/thrown? expr)) — must return truthy on exception.
;; Note: let-go catch syntax is (catch bindSym body...) not (catch Class bindSym body...)
(defmacro thrown? [& body]
  `(try
     (do ~@body false)
     (catch _# true)))

;; Suite-local numeric bounds used by many test files. Clojure/JVM and bb
;; expose the underlying host constants as Long/MAX_VALUE, Double/MAX_VALUE,
;; etc.; let-go provides the same names natively for the :clj suite path.
(def max-int Long/MAX_VALUE)
(def min-int Long/MIN_VALUE)
(def max-double Double/MAX_VALUE)
(def min-double Double/MIN_VALUE)
(def all-ones-int -1)

;; Re-export let-go's native BigInt predicate under the suite-local helper name.
(def big-int? clojure.core/big-int?)

;; Re-export let-go's native lazy-seq? predicate. Upstream's lazy_seq.cljc
;; and repeatedly.cljc tests assert that a (lazy-seq ...) form returns
;; something distinguishable from a fully-realized seq.
(def lazy-seq? clojure.core/lazy-seq?)

;; Most JVM/Clojure compatibility names used by the suite now live in core:
;; java.lang.* aliases, clojure.lang.* aliases, Long/Double constants,
;; definterface/new, with-precision, refs, and synchronous agent placeholders.
;; Keep this shim focused on test-portability helpers that require clojure.test
;; integration or upstream-suite local names.

;; FIXME: Clojure JVM's `num` boxes primitive long/double values. let-go does
;; not have separate primitive-vs-boxed numeric host types, so this remains a
;; suite-local compatibility shim for overload-dispatch characterization tests.
(in-ns 'core)
(deftype LetGoNumBox [value])
(defn num [x]
  (cond
    (nil? x) nil
    (not (number? x)) (throw (str "Expected a number, got " (type x)))
    (or (bigint? x) (decimal? x)) x
    :else (->LetGoNumBox x)))
(in-ns 'clojure.core-test.portability)
