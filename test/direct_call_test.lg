;; Direct-call rewrite end-to-end tests.
;;
;; Covers ir.lower-go/*lowered-registry* plumbing, ir.lower-go/lookup-direct-callable,
;; and the call-assign-stmts same-NS branch that emits bare Go function
;; calls instead of rt.LookupVar + rt.InvokeValue.
;;
;; Strategy: drive ir.passes.pipeline/lower-ns-to-go on synthetic defn
;; forms and assert on the rendered Go source. Keeps the tests at the
;; PUBLIC API boundary; internal IR shape changes don't break them.

(ns test.direct-call-test
  (:require
   [clojure.string :as str]
   [ir.lower-go :as lower-go]
   [ir.passes.pipeline :as pipeline]
   [ir.passes.typeinfer :as ti]
   [test :refer :all]))

(def ^:private ns-sym 'test.direct-call-scratch)

(defn- caller-body
  "Extract the body of a func declaration named `fn-name` from a
   rendered Go source string. Returns nil when the func isn't found.
   We need this because the auto-emitted gogen_wrap dispatch table at
   the bottom of every package contains `callee(args[0])`-style lines
   for EVERY lowered defn — those are NOT caller bodies, and naive
   substring assertions confuse the two."
  [src fn-name]
  (let [pattern (str "func " fn-name "(")
        start (str/index-of src pattern)]
    (when start
      ;; Walk forward to the matching closing brace at column 0.
      (let [rest-src (subs src start)
            end (str/index-of rest-src "\n}\n")]
        (when end (subs rest-src 0 (+ end 3)))))))

(defn- compile-ns
  "Run lower-ns-to-go on a vec of (defn ...) forms. Returns the
   rendered Go source string. The scratch ns is created on demand,
   and forms are eval'd FIRST so referenced symbols resolve to real
   Vars before lower-ns-to-go re-builds the IR for lowering. Without
   this pre-eval, '(defn caller [y] (callee y)) fails with
   'unresolved symbol callee' because lower-ns-to-go doesn't itself
   create Vars."
  [forms]
  (when-not (find-ns ns-sym) (create-ns ns-sym))
  (binding [*ns* (find-ns ns-sym)]
    (doseq [f forms] (eval f)))
  (pipeline/lower-ns-to-go "scratch" ns-sym forms))

(defn- compile-ns-with-decls
  "Same as compile-ns but pre-interns the supplied names as nil-bound
   Vars FIRST, then evals the forms. Lets a defn form reference a
   sibling whose definition follows in source order — needed when
   testing mutual recursion, because eval'ing the first defn would
   otherwise fail with 'unresolved symbol' on the as-yet-undefined
   sibling."
  [decl-names forms]
  (when-not (find-ns ns-sym) (create-ns ns-sym))
  (binding [*ns* (find-ns ns-sym)]
    (doseq [n decl-names] (intern (find-ns ns-sym) n))
    (doseq [f forms] (eval f)))
  (pipeline/lower-ns-to-go "scratch" ns-sym forms))

;; --- registry plumbing --------------------------------------------------

(deftest registry-populates-during-lowering
  (testing "single-arity vm.Value-only defn is registered as direct-callable"
    (let [src (compile-ns ['(defn helper [x] x)])]
      ;; The defn itself lowers (presence of `func helper` proves it).
      (is (str/includes? src "func helper")
          "helper should lower to a Go func"))))

;; --- deterministic registry resolution ---------------------------------
;; resolve-registry-entry is the pure core of lookup-direct-callable:
;; given (registry, call-ns-or-nil, name, arity) it must pick ONE entry
;; deterministically. The old matcher used (some (get) (filter (keys …))),
;; i.e. first match in HASH-KEY order, so an unqualified call that collides
;; with a seeded native (same name+arity, e.g. native_direct_install.go's
;; clojure.core/seq vs an own-ns sibling) resolved differently across regens
;; — the #188 non-determinism that drops a func def under -tags gogen_ir.
;; Contract: qualified → exact-ns lookup; unqualified → prefer the own-ns
;; (non-native) sibling, then lexicographic by ns; result independent of
;; the registry's internal key order.

(def ^:private sibling-entry
  {:go-name "myfn" :arity 1 :needs-error? false
   :param-specs ["vm.Value"] :result-spec "vm.Value" :native? false :go-pkg nil})

(def ^:private native-entry
  {:go-name "Myfn" :arity 1 :needs-error? false
   :param-specs ["vm.Value"] :result-spec "vm.Value" :native? true :go-pkg "corefns"})

(deftest resolve-registry-entry-is-order-independent
  (testing "unqualified collision picks the non-native own-ns sibling, regardless of key order"
    ;; array-map preserves insertion order, so the two registries below
    ;; iterate their keys in OPPOSITE orders. A hash/insertion-order
    ;; dependent resolver returns different entries for them; a
    ;; deterministic one returns the sibling for both.
    (let [reg-sib-first (array-map ['my.ns "myfn" 1]        sibling-entry
                                   ['clojure.core "myfn" 1] native-entry)
          reg-nat-first (array-map ['clojure.core "myfn" 1] native-entry
                                   ['my.ns "myfn" 1]        sibling-entry)]
      (is (= sibling-entry (lower-go/resolve-registry-entry reg-sib-first nil "myfn" 1))
          "sibling-first registry must resolve unqualified call to the sibling")
      (is (= sibling-entry (lower-go/resolve-registry-entry reg-nat-first nil "myfn" 1))
          "native-first registry must ALSO resolve to the sibling (order independent)"))))

(deftest resolve-registry-entry-respects-qualification-and-misses
  (let [reg (array-map ['my.ns "myfn" 1]        sibling-entry
                       ['clojure.core "myfn" 1] native-entry)]
    (testing "qualified call resolves to the named ns"
      (is (= native-entry  (lower-go/resolve-registry-entry reg 'clojure.core "myfn" 1)))
      (is (= sibling-entry (lower-go/resolve-registry-entry reg 'my.ns "myfn" 1))))
    (testing "no name/arity match yields nil"
      (is (nil? (lower-go/resolve-registry-entry reg nil "nope" 1)))
      (is (nil? (lower-go/resolve-registry-entry reg nil "myfn" 2)))
      (is (nil? (lower-go/resolve-registry-entry reg 'other.ns "myfn" 1))))))

;; Realistic callee bodies — ones whose lowered signature is
;; (vm.Value, error), matching the shape that emit-call-stmts assumes
;; at the call site. Identity defns (defn id [x] x) bypass the
;; needs-error? shape gate and exercise a different code path; we
;; cover the realistic case here and document the gate in a separate
;; test below.

(def ^:private callee-form
  '(defn callee [x] (clojure.core/+ x 1)))

(def ^:private caller-form
  '(defn caller [y] (callee y)))

(deftest both-defns-lower
  (testing "both defns reach the rendered Go source"
    (let [src (compile-ns [callee-form caller-form])]
      (is (str/includes? src "func callee(")  "callee lowers")
      (is (str/includes? src "func caller(")  "caller lowers"))))

;; --- same-NS direct-call rewrite ---------------------------------------

(deftest same-ns-call-emits-direct-go-call
  (testing "caller invokes callee via bare Go call, not rt.LookupVar"
    (let [src    (compile-ns [callee-form caller-form])
          body   (caller-body src "caller")]
      (is body "caller func body should be extractable")
      ;; The direct call lives ONLY in the caller body, NOT in the
      ;; gogen_wrap dispatch table (which spuriously contains
      ;; `callee(args[0])` for every lowered defn).
      (is (str/includes? body "callee(")
          (str "caller body should contain direct call callee(...); got:\n" body))
      (is (not (str/includes? body "rt.LookupVar"))
          (str "caller body should NOT route through rt.LookupVar; got:\n" body)))))

(deftest topo-order-callees-precede-callers
  (testing "defn ordering doesn't matter — caller-before-callee in source still folds"
    (let [src  (compile-ns [caller-form callee-form])
          body (caller-body src "caller")]
      (is body "caller func body should be extractable")
      (is (str/includes? body "callee(")
          (str "caller should still emit direct call when defined first in source; got:\n"
               body)))))

(deftest identity-callee-direct-calls
  (testing "callee with a no-error shape (e.g. identity) is direct-called"
    ;; The MVP shape gate once REJECTED callees that return just vm.Value
    ;; (no error), routing such calls through rt.LookupVar/rt.InvokeValue.
    ;; That gate has since been relaxed (lookup-direct-callable accepts the
    ;; no-error shape): emit-call-stmts emits a single-value direct call
    ;;   v = id_callee(arg)
    ;; instead of the (v, callErr = ...) error-shaped form, so the caller no
    ;; longer trampolines. This is the change the previous version of this
    ;; test was waiting for.
    (let [src  (compile-ns ['(defn id-callee [x] x)
                            '(defn id-caller [y] (id-callee y))])
          body (caller-body src "id_caller")]
      (is body "id_caller body should be extractable")
      (is (str/includes? body "id_callee(")
          (str "id_caller should direct-call id_callee (no-error shape now lowered); got:\n"
               body))
      (is (not (str/includes? body "rt.LookupVar"))
          (str "id_caller should NOT trampoline a now-direct-callable callee; got:\n"
               body)))))

(deftest unknown-callee-still-uses-trampoline
  (testing "call to an undeclared symbol — its caller doesn't lower at all"
    ;; pre-eval will fail on the unknown symbol; we expect compile-ns
    ;; to surface the build failure as a WARNING line. The defn for
    ;; `user` is therefore NOT in the output.
    (let [src (try (compile-ns ['(defn user [y] (some-external-thing y))])
                   (catch e ""))]
      ;; Either it errored out before producing src, or it skipped the
      ;; failing defn. Both are acceptable; we just don't want a
      ;; spurious direct call to a phantom symbol.
      (is (not (str/includes? src "some_external_thing("))
          "no direct call when the callee isn't a real Var"))))

;; --- shape gating ------------------------------------------------------

;; --- the topo-fallback case (mutual recursion) -------------------------
;;
;; order-defn-forms (pipeline.lg) toposorts defns by call-graph deps,
;; BUT falls back to lex order when the graph has any cycle (line
;; 279-282). The per-ns growing-registry then loses its "callee before
;; caller" invariant: in lex order, "alpha" is processed before
;; "omega" even if alpha calls omega. omega's entry isn't in the
;; registry when alpha's body is lowered → direct-call rewrite misses
;; → trampoline emitted.
;;
;; This test is the synthetic minimal repro of the real-world
;; apply→spread bug in core.lg. It's expected to FAIL on the current
;; growing-registry implementation; it pins the contract that a
;; refactor (per-ns 2-pass loop OR full corpus pre-scan) must
;; satisfy.

(deftest mutual-recursion-still-folds-cross-calls
  (testing "mutual-recursion cycle in call graph doesn't break direct-call rewrite"
    ;; alpha and omega form a 2-cycle, so order-defn-forms falls back
    ;; to lex order: alpha processed first. alpha's body calls omega,
    ;; which isn't registered yet. Current impl: omega lookup misses,
    ;; trampoline emitted. Desired: registry pre-populated either by
    ;; 2-pass-per-ns or full corpus pre-scan.
    (let [src   (compile-ns-with-decls '[alpha omega]
                                       ['(defn alpha [n] (clojure.core/+ (omega n) 1))
                                        '(defn omega [n] (clojure.core/+ (alpha n) 1))])
          alpha (caller-body src "alpha")]
      (is alpha "alpha body should be extractable")
      ;; This is the assertion that fails today and must pass after fix.
      (is (str/includes? alpha "omega(")
          (str "alpha should call omega directly (cycle forces lex-order fallback in source);\n"
               "two-pass loop should populate the registry before any body is lowered.\n"
               "Got:\n" alpha))
      ;; Same-ns trampolines for omega specifically — not cross-ns
      ;; builtins like clojure.core/+ which are unrelated to this gate.
      (is (not (str/includes? alpha
                              "rt.LookupVar(\"test.direct-call-scratch\", \"omega\")"))
          (str "alpha should NOT trampoline omega through rt.LookupVar; got:\n"
               alpha)))))

(deftest variadic-callee-uses-ifn-dispatch
  (testing "variadic callees are not direct-call eligible (MVP shape gate); they
            lift to cached-var IFn dispatch — var-mediated, not a bare Go call"
    (let [src  (compile-ns ['(defn varargs [x & rest] x)
                            '(defn vcaller [a b] (varargs a b))])
          body (caller-body src "vcaller")]
      (is body "vcaller body should be extractable")
      ;; Not direct-call eligible: no bare `vN = varargs(arg0, ...)` Go call.
      (is (not (str/includes? body "varargs(arg"))
          (str "vcaller should NOT emit a bare direct varargs(...) Go call; got:\n"
               body))
      ;; Instead it lifts to cached-var IFn dispatch via rt.CachedVarFn (the
      ;; override seam: the *Var is cached, its fn root re-read each call).
      (is (str/includes? body "rt.CachedVarFn(")
          (str "vcaller should dispatch the variadic callee via rt.CachedVarFn; got:\n"
               body))
      ;; The per-call rt.LookupVar is eliminated — resolution moves into the
      ;; shared rt.CachedVarFn helper, memoized through the package-level var.
      (is (not (str/includes? body "rt.LookupVar"))
          (str "vcaller body should not do a per-call rt.LookupVar; got:\n" body)))))

;; --- registry size sanity ----------------------------------------------

(deftest registry-cleared-between-runs
  (testing "*lowered-registry* default value is empty"
    ;; The dynamic var's TOP-level default is {}. Each lower-ns-to-go
    ;; loop iteration rebinds, so this assertion is about the resting state.
    (is (= {} lower-go/*lowered-registry*)
        "default *lowered-registry* should be empty between compilations")))

;; --- determinism: codegen output must not depend on the typeinfer budget ---
;;
;; *typeinfer-budget-ms* bounds the monotone worklist fixpoint by WALL-CLOCK
;; time. When the clock is hit, typeinfer returns a PARTIAL result whose
;; contents depend on how far it drained before the deadline — i.e. on machine
;; load and scheduling, not on program content. Because the Go-lowering path
;; encodes inferred types into the rendered source, a time-bounded partial
;; fixpoint makes the generated tree non-deterministic across processes (the
;; 4th hash/time-order axis behind the flaky core_go_lowered regen). It also
;; DROPS forms entirely under starvation (a :bottom-heavy partial trips a
;; downstream pass → the form throws → it's filtered out → undefined: build
;; errors). The codegen path must therefore run typeinfer to FIXPOINT,
;; independent of whatever budget the caller has bound.

(defn- compile-ns-budget
  "compile-ns, but run under an explicit *typeinfer-budget-ms* binding."
  [budget forms]
  (when-not (find-ns ns-sym) (create-ns ns-sym))
  (binding [*ns* (find-ns ns-sym)]
    (doseq [f forms] (eval f)))
  (binding [ti/*typeinfer-budget-ms* budget]
    (pipeline/lower-ns-to-go "scratch" ns-sym forms)))

(deftest codegen-output-invariant-to-typeinfer-budget
  (testing "lowered Go is identical under a starved vs unbounded typeinfer budget"
    ;; A loop-carrying accumulator needs several worklist widenings to reach
    ;; fixpoint, so a zero budget bails before draining (partial result),
    ;; while nil runs to completion.
    (let [forms ['(defn budget-countdown [n]
                    (loop [i n acc 0]
                      (if (> i 0) (recur (dec i) (+ acc i)) acc)))]
          starved (str (compile-ns-budget 0 forms))    ;; immediate bail
          full    (str (compile-ns-budget nil forms))] ;; fixpoint
      ;; Goal (b): consistent outputs — byte-identical regardless of budget.
      (is (= full starved)
          (str "rendered Go must be invariant to *typeinfer-budget-ms*;\n"
               "starved (len " (count starved) ") != full (len " (count full) ")"))
      ;; Goal (a): entry points must not disappear under budget pressure.
      (is (str/includes? starved "func budget_countdown(")
          (str "the budget_countdown entry point must survive a starved budget; got:\n"
               starved)))))
