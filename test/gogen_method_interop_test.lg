;; Regression test for the Go method-call interop self-AOT lowering gap.
;;
;; Root cause: ir.build/build-list had no dispatch for a call head that is a
;; symbol starting with '.' (Go method interop, e.g. (.WriteString w s)). It
;; fell through to symbol resolution and threw "ir/build: unresolved symbol
;; .WriteString". The bytecode VM handles this by rewriting (.Method recv args)
;; to the canonical dot form (. recv (quote Method) args); the fix mirrors that
;; rewrite in build-list so the gogen path lowers interop the same way (a
;; generic call to the `.` builtin via the normal trampoline).
;;
;; RED before the fix: compile-form returns :fallback (unresolved symbol
;; .WriteString / .UnixMilli). GREEN after: :lowered. Trigger forms are
;; self-contained so the test stays valid regardless of which real defns hit
;; the bucket.

(ns test.gogen-method-interop-test
  (:require
   [clojure.string :as str]
   [gogen :as g]
   [ir.passes.pipeline :as pipeline]
   [test :refer :all]))

(defn- lower-status [form]
  (binding [pipeline/*target* :go]
    (:status (pipeline/compile-form form))))

(defn- lower-src [form]
  (binding [pipeline/*target* :go]
    (g/render (:decl (pipeline/compile-form form)))))

(deftest go-method-interop-lowers
  (testing "a (.Method recv args) interop call lowers cleanly instead of throwing unresolved symbol"
    (is (= :lowered (lower-status '(defn writes [w s] (.WriteString w s)))))
    (is (= :lowered (lower-status '(defn millis [inst] (.UnixMilli inst)))))))

(deftest qualified-dot-head-is-not-method-interop
  (testing "(foo/.bar x) — a namespace-qualified head whose name starts with '.' — is an ordinary qualified var call, NOT a Go method-interop rewrite to clojure.core/."
    ;; Method interop rewrites (.bar recv) to a call on the clojure.core/.
    ;; builtin: rt.LookupVar(\"clojure.core\", \".\") with the member as a quoted
    ;; symbol arg. A namespace-qualified head must NOT be rewritten that way —
    ;; it resolves the literal var foo/.bar, matching the bytecode compiler's
    ;; raw-symbol guard (the raw text \"foo/.bar\" does not start with '.').
    (let [src (lower-src '(defn call-qualified [o] (foo/.bar o)))]
      (is (str/includes? src "rt.LookupVar(\"foo\", \".bar\")"))
      (is (not (str/includes? src "rt.LookupVar(\"clojure.core\", \".\")"))))))
