;; IR → Go AST lowering.
;;
;; Current scope:
;;   - single optimized function
;;   - strict mode: unsupported ops/shapes throw
;;   - bridge mode: unsupported functions fall back at whole-function granularity
;;   - supported ops: const, load-arg, block-arg, add/sub/mul, lt/lte/gt/gte/eq,
;;     inc/dec, return, branch, branch-if, tail-call
;;   - control flow lowers from block-parameter SSA to mutable locals plus labels/gotos

(ns ir.lower-go
  (:require
   [ir.data]))

(def ^:private binary-op
  {:add  "+"
   :sub  "-"
   :mul  "*"
   :quot "/"
   :lt   "<"
   :lte  "<="
   :gt   ">"
   :gte  ">="
   :eq   "=="})

(declare function-needs-error?)
(declare function-needs-rt?)
(declare function-needs-vm?)
(declare function-needs-tail-call?)
(declare return-ref-ids)
(declare function-return-spec)
(declare const-param-of)

(defn- unsupported [mode msg]
  (if (= mode :bridge)
    {:status :fallback
     :decl nil
     :reason msg}
    (throw (str "ir.lower-go: " msg))))

(defn- go-type-spec [t]
  (cond
    (or (= t :int) (= t [:const :int 0]))        "int"
    (or (= t :float) (= t [:const :float 0.0]))  "float64"
    (or (= t :bool) (= t :true) (= t :false))    "bool"
    (= t :string)                                "string"
    (= t :char)                                  "vm.Char"
    (or (= t :unknown) (= t :any) (= t :nil))    "vm.Value"
    (and (vector? t) (= (first t) :union))       "vm.Value"
    :else nil))

(defn- infer-go-type [t]
  (let [spec (go-type-spec t)]
    (when spec
      (gogen/type spec))))

(defn- const-expr [aux t]
  (cond
    (nil? aux)        (gogen/ident "nil")
    (= aux true)      (gogen/ident "true")
    (= aux false)     (gogen/ident "false")
    (string? aux)     (gogen/string-lit aux)
    (char? aux)       (gogen/call (gogen/field-sel (gogen/ident "vm") "Char")
                                  [(gogen/char-lit aux)])
    (keyword? aux)    nil
    (or (= t :float) (= t [:const :float 0.0])) (gogen/float-lit aux)
    (integer? aux)    (gogen/int-lit aux)
    (float? aux)      (gogen/float-lit aux)
    :else nil))

(declare boxed-value-expr)

(defn- vm-sel [name]
  (gogen/field-sel (gogen/ident "vm") name))

(defn- vm-call [name args]
  (gogen/call (vm-sel name) args))

(defn- boxed-vector-expr [xs]
  (let [elems (mapv boxed-value-expr xs)]
    (when (every? identity elems)
      (vm-call "NewArrayVector"
               [(gogen/composite-lit (gogen/type "[]vm.Value") elems)]))))

(defn- boxed-list-expr [xs]
  (if (zero? (count xs))
    (vm-sel "EmptyList")
    (let [elems (mapv boxed-value-expr (seq xs))]
      (when (every? identity elems)
        (vm-call "NewList"
                 [(gogen/composite-lit (gogen/type "[]vm.Value") elems)])))))

(defn- boxed-map-expr [m]
  (if (zero? (count m))
    (vm-sel "EmptyPersistentMap")
    (let [entries (seq m)
          elems   (loop [remaining entries out []]
                    (if (nil? remaining)
                      out
                      (let [entry (first remaining)
                            kexpr (boxed-value-expr (first entry))
                            vexpr (boxed-value-expr (second entry))]
                        (if (or (nil? kexpr) (nil? vexpr))
                          nil
                          (recur (next remaining) (conj out kexpr vexpr))))))]
      (when elems
        (vm-call "NewPersistentMap"
                 [(gogen/composite-lit (gogen/type "[]vm.Value") elems)])))))

(declare value-expr)

(defn- box-as-value
  "Produce a vm.Value-typed expression for inst nid.
   If nid's go-type-spec is vm.Value already, returns value-expr unchanged.
   Otherwise wraps the raw value in the appropriate vm constructor so the
   bridge-mode call-site (rt.InvokeValue, []vm.Value{...}) typechecks."
  [f closed-exprs nid]
  (let [t    (ir/type-of nid f)
        spec (go-type-spec t)
        expr (value-expr f closed-exprs nid)]
    (cond
      (nil? expr)         nil
      (= spec "vm.Value") expr
      (= spec "bool")     (gogen/call (gogen/field-sel (gogen/ident "vm") "Boolean") [expr])
      (= spec "int")      (vm-call "Int" [expr])
      (= spec "float64")  (vm-call "Float" [expr])
      (= spec "string")   (vm-call "String" [expr])
      ;; vm.Char is a thin rune type that already implements vm.Value, so a
      ;; vm.Char-typed expr is usable as vm.Value directly (no wrapper needed).
      (= spec "vm.Char")  expr
      :else               expr)))

(defn- unbox-from-value
  "Inverse of box-as-value: extract the native Go payload from a vm.Value
   expression `raw` when the target slot's go-type-spec is a native primitive.
   Used at copy sites (branch-edge param<-arg transfers) where typeinfer's edge
   refinement narrowed the value to exactly one primitive while the source inst
   stayed vm.Value — e.g. a `string|nil` union is `:string` on the truthy edge
   (refine-truthy drops :nil), so a `vm.Value` arg must be unwrapped into the
   `string` param slot. Sound precisely because the refinement guarantees the
   runtime value IS that primitive on this edge. Mirrors box-as-value's type
   set (the supported unboxed lowering targets)."
  [spec raw]
  (cond
    (= spec "bool")     (gogen/call (vm-sel "IsTruthy") [raw])
    (= spec "int")      (gogen/call (gogen/ident "int")     [(gogen/type-assert raw (gogen/type "vm.Int"))])
    (= spec "float64")  (gogen/call (gogen/ident "float64") [(gogen/type-assert raw (gogen/type "vm.Float"))])
    (= spec "string")   (gogen/call (gogen/ident "string")  [(gogen/type-assert raw (gogen/type "vm.String"))])
    ;; vm.Char already implements vm.Value, so the slot type is vm.Char — a
    ;; direct assertion extracts it without a conversion.
    (= spec "vm.Char")  (gogen/type-assert raw (gogen/type "vm.Char"))
    :else               raw))

(defn- boxed-value-expr [v]
  (cond
    (nil? v)        (vm-sel "NIL")
    (= v true)      (vm-sel "TRUE")
    (= v false)     (vm-sel "FALSE")
    (integer? v)    (vm-call "Int" [(gogen/int-lit v)])
    (float? v)      (vm-call "Float" [(gogen/float-lit v)])
    (string? v)     (vm-call "String" [(gogen/string-lit v)])
    (char? v)       (vm-call "Char" [(gogen/char-lit v)])
    (keyword? v)    (vm-call "Keyword" [(gogen/string-lit (subs (str v) 1))])
    (symbol? v)     (vm-call "Symbol" [(gogen/string-lit (str v))])
    (list? v)       (boxed-list-expr v)
    (vector? v)     (boxed-vector-expr v)
    (map? v)        (boxed-map-expr v)
    :else nil))

(declare go-name)

(defn- source-name-of [f nid]
  "Pick a user-visible source name from the inst's attached source-infos,
   if any carry a non-empty Symbol. Returns nil otherwise."
  (let [sis (ir/source-infos nid f)]
    (loop [remaining sis]
      (when (seq remaining)
        (let [sym (ir/source-info-symbol (first remaining))]
          (if (and (string? sym) (pos? (count sym)))
            sym
            (recur (next remaining))))))))

(defn- value-name
  "Go identifier for inst nid. Prefers the user-visible source name when
   one is attached via a name-only SourceInfo (suffix `_<nid>` preserves
   uniqueness across shadowing — multiple SSA insts can share a source
   symbol, but each gets its own Go local). Falls back to `v<nid>` when
   no name is attached."
  ([nid] (str "v" nid))
  ([f nid]
   (or (when-let [cm (:coalesce (deref f))]
         (get cm nid))
       (when-let [sym (source-name-of f nid)]
         (str (go-name sym) "_" nid))
       (str "v" nid))))

;; Munge Lisp-idiomatic identifier chars to a valid Go identifier.
;; Convention is Clojure-flavoured: each unsafe char maps to a distinct
;; underscore-bracketed token so munged names don't collide with
;; legitimately-named Go identifiers like `foo_bang` already in source.
(def go-name-munge-map
  {\-  "_"
   \!  "_BANG_"
   \?  "_QMARK_"
   \*  "_STAR_"
   \/  "_SLASH_"
   \+  "_PLUS_"
   \=  "_EQ_"
   \<  "_LT_"
   \>  "_GT_"
   \'  "_PRIME_"})

(def ^:private go-reserved-words
  #{"break" "default" "func" "interface" "select" "case" "defer" "go"
    "map" "struct" "chan" "else" "goto" "package" "switch" "const"
    "fallthrough" "if" "range" "type" "continue" "for" "import"
    "return" "var"})

(defn- go-name [s]
  (let [munged (apply str
                      (map (fn [ch]
                             (or (get go-name-munge-map ch) ch))
                           s))]
    (if (contains? go-reserved-words munged)
      (str munged "_")
      munged)))

(defn- import-entry [path alias]
  {:path path :alias alias})

(defn- label-name [bid]
  (str "b" bid))

(defn- value-ident
  ([nid] (gogen/ident (value-name nid)))
  ([f nid] (gogen/ident (value-name f nid))))

(defn- same-ident? [a b]
  (and (gogen/ident? a) (gogen/ident? b)
       (= (gogen/ident-name a) (gogen/ident-name b))))

(defn- fn-template? [aux]
  (and (map? aux) (= (:kind aux) :fn-template)))

(defn- multi-fn-template? [aux]
  (and (map? aux) (= (:kind aux) :multi-fn-template)))

(defn- any-fn-template? [aux]
  (or (fn-template? aux) (multi-fn-template? aux)))

(defn- template-fns [aux]
  (cond
    (fn-template? aux)       [(:fn aux)]
    (multi-fn-template? aux) (mapv :fn (:fns aux))
    :else                    []))

(defn- local-carrying-op? [op]
  (or (= op :block-arg)
      (= op :call)
      (= op :inc)
      (= op :dec)
      (contains? binary-op op)))

(defn- used? [f nid]
  (let [uses (ir/uses f)]
    (and (< nid (count uses))
         (pos? (count (nth uses nid))))))

;; live? — is nid's VALUE actually read by emitted Go? Reads the backward
;; read-set computed by live-nids and cached on f by lower-body. The IR `uses`
;; table over-reports: build threads some argument subexpressions twice, leaving
;; dead duplicate insts with non-empty (stale) use lists. live? is the truth for
;; lowering decisions (declare/assign/route-to-_). Falls back to used? when the
;; set is absent (non-lowering callers).
(defn- live? [f nid]
  (let [ls (:live (deref f))]
    (if ls
      (contains? ls nid)
      (used? f nid))))

(declare value-expr)
(declare lower-fn-lit)

;; --- block-parameter lineage --------------------------------------------
;; A closure created inside a loop has its fn-template (and its captured
;; values) threaded through the loop header as block-parameters (:block-arg),
;; rather than referenced as direct :const / inst nodes. To resolve such a
;; value we read the block-param's incoming branch-target-args directly off the
;; block structure — the lineage that block-parameter SSA already encodes.
;; Block-oriented; no phi/dominance reconstruction (lesson_dae310d3ce22).
;;
;; param-sources ({param-nid -> [feeder-nid …]}) and a closure-info memo are
;; precomputed ONCE per function and cached on f by lower-body (alongside
;; :coalesce/:live/:const-params): closure-value? is queried per param across
;; collect-local-ids and per edge in emit-assignments, so an un-memoized
;; block-graph re-walk would blow the lowering time budget on large functions.
;; Both fall back to direct computation when the cache is absent (callers that
;; run before lower-body, e.g. params-for/result-node).

(defn- term-targets [op aux]
  (cond
    (= op :branch)    [aux]
    (= op :branch-if) [(ir/cond-target-true aux) (ir/cond-target-false aux)]
    :else             []))

(defn- compute-param-sources [f]
  (let [m (atom {})]
    (doseq [bid (ir/blocks f)]
      (let [params (ir/block-params bid f)
            np     (count params)]
        (doseq [p (ir/block-preds bid f)]
          (let [term (ir/block-term p f)]
            (when term
              (let [op (ir/op term f) aux (ir/aux term f)]
                (doseq [bt (term-targets op aux)]
                  (when (and bt (= (ir/branch-target-target bt) bid))
                    (let [args (ir/branch-target-args bt)]
                      (loop [i 0]
                        (when (< i np)
                          (when (< i (count args))
                            (let [pid (nth params i)
                                  a   (nth args i)]
                              (swap! m update pid (fn [v] (conj (or v []) a)))))
                          (recur (inc i)))))))))))))
    @m))

(defn- block-arg-sources [f nid]
  ;; Inst ids feeding block-parameter nid, from the per-fn cache (or computed).
  (if-let [srcs (:param-sources (deref f))]
    (get srcs nid)
    (get (compute-param-sources f) nid)))

(defn- closure-info* [f nid visited]
  (if (contains? visited nid)
    nil
    (let [op   (ir/op nid f)
          aux  (ir/aux nid f)
          refs (ir/refs nid f)]
      (cond
        (and (= op :const) (any-fn-template? aux))
        {:template aux :captures []}

        (= op :make-closure)
        (when (= 1 (count refs))
          (closure-info* f (nth refs 0) visited))

        (= op :push-closed)
        (when (= 2 (count refs))
          (let [base (closure-info* f (nth refs 0) visited)]
            (when base
              (assoc base :captures (conj (:captures base) (nth refs 1))))))

        (= op :block-arg)
        (some (fn [src] (closure-info* f src (conj visited nid)))
              (block-arg-sources f nid))

        :else nil))))

(defn- closure-info
  "Resolve the closure a value refers to: {:template <aux> :captures [nid …]}
   or nil. Walks make-closure/push-closed and follows block-parameter lineage
   so closures threaded through a loop header still resolve (captures on
   push-closed nodes are preserved across the walk). Memoized per function on f."
  [f nid]
  (if-let [memo (:closure-memo (deref f))]
    (if (contains? @memo nid)
      (get @memo nid)
      (let [r (closure-info* f nid #{})]
        (swap! memo assoc nid r)
        r))
    (closure-info* f nid #{})))

(defn- nested-template-fns [f]
  (loop [blocks (ir/blocks f) out []]
    (if (empty? blocks)
      out
      (let [insts (ir/block-insts (first blocks) f)
            found (reduce (fn [acc nid]
                            (let [aux (ir/aux nid f)]
                              (if (any-fn-template? aux)
                                (into acc (template-fns aux))
                                acc)))
                          []
                          insts)]
        (recur (rest blocks) (into out found))))))

(defn- lower-template-closure-expr [template capture-exprs]
  (cond
    (fn-template? template)
    (let [inner* (lower-fn-lit (:fn template) capture-exprs)]
      (when inner*
        (gogen/call
          (gogen/field-sel (gogen/ident "rt") "BoxNativeFn")
          [inner*])))

    (multi-fn-template? template)
    (let [inners (mapv (fn [entry]
                         (lower-fn-lit (:fn entry) capture-exprs))
                       (:fns template))]
      (when (every? identity inners)
        (let [boxed (mapv (fn [inner*]
                            (gogen/call
                              (gogen/field-sel (gogen/ident "rt") "BoxNativeFn")
                              [inner*]))
                          inners)]
          (gogen/call
            (gogen/field-sel (gogen/ident "rt") "MakeNativeMultiArity")
            [(gogen/composite-lit (gogen/type "[]vm.Value") boxed)]))))

    :else nil))

(defn- closure-value?
  "True when nid denotes a closure/fn-template value — closure-info resolves it.
   Such values are compile-time entities: closure-expr re-materializes the real
   Go closure inline at each USE site (from the statically-resolved template +
   captures), so they have no runtime Go local and must be excluded from
   edge-assignment and local materialization — a bare template threaded through
   a loop header as a block-arg has no standalone Go value."
  [f nid]
  (some? (closure-info f nid)))

(defn- closure-expr [f closed-exprs nid]
  (let [info (closure-info f nid)]
    (when info
      ;; Captures flow into the inner fn as vm.Value (read back via :load-closed,
      ;; which is vm.Value-typed), so box each capture to vm.Value at the splice.
      ;; Arg captures are already vm.Value (raw is a no-op box), but a loop-carried
      ;; capture is a primitive Go local (e.g. int) — splicing it raw produces
      ;; `[]vm.Value{i_5}` / `return i_5`, which doesn't typecheck.
      (let [capture-exprs (mapv (fn [rid] (box-as-value f closed-exprs rid)) (:captures info))]
        (when (every? identity capture-exprs)
          (lower-template-closure-expr (:template info) capture-exprs))))))

(defn- value-expr [f closed-exprs nid]
  (let [op  (ir/op nid f)
        aux (ir/aux nid f)
        t   (ir/type-of nid f)]
    (or (closure-expr f closed-exprs nid)
        ;; A constant block-param is re-materialized as the literal inline
        ;; (consts are block-free), eliding its local and its edge copies.
        (when-let [cp (const-param-of f nid)]
          (if (= "vm.Value" (go-type-spec t))
            (boxed-value-expr (first cp))
            (const-expr (first cp) t)))
        (cond
          (= op :load-closed)
          (when (and closed-exprs
                     (>= aux 0)
                     (< aux (count closed-exprs)))
            (nth closed-exprs aux))

          (= op :load-arg)
          (if (and (ir/fn-variadic? f) (= aux (dec (ir/fn-arity f))))
            (let [rest-var (if (function-needs-tail-call? f) "args0" "args")]
              (gogen/call
                (gogen/field-sel (gogen/ident "rt") "BoxRestArgs")
                [(gogen/ident rest-var)]))
            (let [prefix (if (function-needs-tail-call? f) "a" "arg")]
              (gogen/ident (str prefix aux))))

          (= op :load-var)
          ;; rt.LookupVar returns *vm.Var; .Deref() returns the value-typed
          ;; root (or thread-bound) form. We need vm.Value here because the
          ;; result may be compared (`==`) or assigned to a vm.Value local;
          ;; *vm.Var is a concrete type and won't compare against other
          ;; vm.Value concrete types like vm.Keyword. For :call sites
          ;; rt.InvokeValue handles either form, so deref is safe there too.
          (let [sym (symbol aux)
                sns (namespace sym)
                sn  (name sym)]
            (gogen/call
              (gogen/field-sel
                (gogen/call
                  (gogen/field-sel (gogen/ident "rt") "LookupVar")
                  [(gogen/string-lit (if (nil? sns) "core" sns))
                   (gogen/string-lit sn)])
                "Deref")
              []))

          (= op :const)
          (if (= "vm.Value" (go-type-spec t))
            (boxed-value-expr aux)
            (const-expr aux t))

          (local-carrying-op? op)
          (when (and (live? f nid) (infer-go-type t))
            (value-ident f nid))

          :else nil))))

(def ^:private comparison-op? #{"==" "!=" "<" "<=" ">" ">="})

(defn- inst-rhs [f closed-exprs nid]
  (let [op   (ir/op nid f)
        refs (ir/refs nid f)]
    (cond
      (contains? binary-op op)
      (let [op-str       (get binary-op op)
            s0           (go-type-spec (ir/type-of (nth refs 0) f))
            s1           (go-type-spec (ir/type-of (nth refs 1) f))
            order-op?    (#{"<" "<=" ">" ">="} op-str)
            arith-op?    (#{"+" "-" "*" "/"} op-str)
            any-vm?      (or (= "vm.Value" s0) (= "vm.Value" s1))
            ;; rt.LtValue/AddValue/... polymorphic helpers — used when
            ;; any operand is vm.Value, so we don't bail the whole defn.
            ;; Each helper mirrors the bytecode VM's OP_<X>: vm.Int fast
            ;; path then vm.Num<X> fallback for ordering; always-delegate
            ;; to vm.Num<X> for arithmetic (keeps overflow / BigInt
            ;; promotion semantics in one place).
            vm-helper    (when any-vm?
                           (cond
                             (= op-str "<")  "LtValue"
                             (= op-str "<=") "LeValue"
                             (= op-str ">")  "GtValue"
                             (= op-str ">=") "GeValue"
                             (= op-str "+")  "AddValue"
                             (= op-str "-")  "SubValue"
                             (= op-str "*")  "MulValue"
                             (= op-str "/")  "QuotValue"
                             :else           nil))
            ;; Mixed operand types (only meaningful when NOT routing
            ;; through a helper, i.e. for `==`/`!=` with one vm.Value
            ;; side): box the other so Go's `==` sees compatible types.
            mixed?       (and (not vm-helper)
                              (not= s0 s1)
                              (or (= "vm.Value" s0) (= "vm.Value" s1)))
            lhs-expr     (cond
                           vm-helper (box-as-value f closed-exprs (nth refs 0))
                           mixed?    (box-as-value f closed-exprs (nth refs 0))
                           :else     (value-expr f closed-exprs (nth refs 0)))
            rhs-expr     (cond
                           vm-helper (box-as-value f closed-exprs (nth refs 1))
                           mixed?    (box-as-value f closed-exprs (nth refs 1))
                           :else     (value-expr f closed-exprs (nth refs 1)))
            result-spec  (go-type-spec (ir/type-of nid f))]
        (cond
          ;; Polymorphic helper path: emit rt.<Op>Value(lhs, rhs).
          ;; Helpers return: bool for ordering, vm.Value for arithmetic.
          (and vm-helper lhs-expr rhs-expr)
          (let [call (gogen/call
                       (gogen/field-sel (gogen/ident "rt") vm-helper)
                       [lhs-expr rhs-expr])]
            (if (and order-op? (= "vm.Value" result-spec))
              ;; Inst declared type didn't narrow to bool — wrap.
              (gogen/call (gogen/field-sel (gogen/ident "vm") "Boolean") [call])
              call))

          ;; Native Go binary path: both operands typed compatibly.
          (and lhs-expr rhs-expr)
          (let [raw-binary (gogen/binary op-str lhs-expr rhs-expr)]
            (if (and (comparison-op? op-str) (= "vm.Value" result-spec))
              (gogen/call (gogen/field-sel (gogen/ident "vm") "Boolean") [raw-binary])
              raw-binary))

          :else nil))

      (or (= op :inc) (= op :dec))
      (let [lhs-id   (nth refs 0)
            lhs-spec (go-type-spec (ir/type-of lhs-id f))]
        (if (= "vm.Value" lhs-spec)
          (let [lhs (box-as-value f closed-exprs lhs-id)]
            (when lhs
              (gogen/call
                (gogen/field-sel (gogen/ident "rt")
                  (if (= op :inc) "AddValue" "SubValue"))
                [lhs (vm-call "Int" [(gogen/int-lit 1)])])))
          (let [lhs (value-expr f closed-exprs lhs-id)]
            (when lhs
              (gogen/binary (if (= op :inc) "+" "-") lhs (gogen/int-lit 1))))))

      :else nil)))

(defn- collect-local-ids [f]
  (let [block-ids (ir/blocks f)]
    (loop [bs block-ids out []]
      (if (empty? bs)
        out
        (let [bid    (first bs)
              params (filter (fn [nid] (and (live? f nid)
                                            (not (const-param-of f nid))
                                            (not (closure-value? f nid))
                                            (infer-go-type (ir/type-of nid f))))
                             (ir/block-params bid f))
              insts  (filter (fn [nid]
                               (let [op (ir/op nid f)]
                                 (and (local-carrying-op? op)
                                      (not= op :block-arg)
                                      (live? f nid)
                                      (not (closure-value? f nid))
                                      (infer-go-type (ir/type-of nid f)))))
                             (ir/block-insts bid f))]
          (recur (rest bs) (into out (concat params insts))))))))

(defn- local-decls [f]
  ;; One var-decl per DISTINCT Go name. Coalescing maps several SSA nids to the
  ;; same name (one mutable local per variable lineage), so dedupe by name to
  ;; avoid "redeclared in this block".
  (let [ids  (distinct (collect-local-ids f))
        seen (atom #{})]
    (loop [remaining ids out []]
      (if (empty? remaining)
        out
        (let [nid     (first remaining)
              go-type (infer-go-type (ir/type-of nid f))
              nm      (value-name f nid)]
          (cond
            (nil? go-type)        nil
            (contains? @seen nm)  (recur (rest remaining) out)
            :else (do (swap! seen conj nm)
                      (recur (rest remaining)
                             (conj out (gogen/var-decl nm go-type nil))))))))))

;; --- parallel-copy sequencing for block-arg edge transfers ------------------
;; A branch-target's param<-arg copies execute simultaneously (parallel copy).
;; After coalescing, an arg that is a bare reference to another param (e.g. a
;; loop swap `(recur b a)`) becomes `a = b` / `b = a`, which clobbers if
;; emitted naively. We order copies so no destination is overwritten while a
;; pending copy still reads it, breaking read/write cycles with a fresh `:=`
;; temp. Computed args are materialized into distinct temps upstream, so only
;; bare-ident copies can ever form a cycle.

(defn- oos-next-tmp! [f]
  (let [n (or (:pc-tmp (deref f)) 0)]
    (swap! f assoc :pc-tmp (inc n))
    (str "_pc" n)))

(defn- oos-vec-remove [v i]
  (vec (concat (take i v) (drop (inc i) v))))

(defn- oos-rhs-read-name [rhs]
  ;; The single dst name this rhs reads, IF rhs is a bare identifier; else nil.
  (when (gogen/ident? rhs) (gogen/ident-name rhs)))

(defn- oos-sequence-copies [f pairs]
  ;; pairs: vec of [lhs-ident rhs-expr]. Returns ordered gogen assign stmts.
  (if (<= (count pairs) 1)
    (mapv (fn [p] (gogen/assign "=" (nth p 0) (nth p 1))) pairs)
    (loop [pending pairs out []]
      (if (empty? pending)
        out
        (let [reads (reduce (fn [s p]
                              (let [rd (oos-rhs-read-name (nth p 1))]
                                (if rd (conj s rd) s)))
                            #{} pending)
              ;; a writer is safe iff no pending copy still reads its dst
              ready (loop [i 0]
                      (if (< i (count pending))
                        (if (contains? reads (gogen/ident-name (nth (nth pending i) 0)))
                          (recur (inc i)) i)
                        -1))]
          (if (>= ready 0)
            (let [p (nth pending ready)]
              (recur (oos-vec-remove pending ready)
                     (conj out (gogen/assign "=" (nth p 0) (nth p 1)))))
            ;; all remaining are in cycles: save one dst to a temp, redirect readers
            (let [p     (nth pending 0)
                  dname (gogen/ident-name (nth p 0))
                  tname (oos-next-tmp! f)
                  save  (gogen/assign ":=" (gogen/ident tname) (gogen/ident dname))
                  pending* (mapv (fn [q]
                                   (let [r (nth q 1)]
                                     (if (and (gogen/ident? r) (= dname (gogen/ident-name r)))
                                       [(nth q 0) (gogen/ident tname)]
                                       q)))
                                 pending)]
              (recur pending* (conj out save)))))))))

(defn- emit-assignments-for-target [f closed-exprs bt]
  (let [params (ir/block-params (ir/branch-target-target bt) f)
        args   (ir/branch-target-args bt)]
    (loop [i 0 pairs []]
      (if (>= i (count params))
        (oos-sequence-copies f pairs)
        (let [pid     (nth params i)
              arg-nid (nth args i)]
          ;; Skip when the param is unused, a const-param (materialized inline at
          ;; each use), or when either side is a compile-time template/closure
          ;; value. Closure/template values carry no runtime Go local —
          ;; closure-expr re-materializes the real closure inline at each USE
          ;; site — so threading them across an edge would reference a local that
          ;; was never declared. Checking the ARG too catches templates threaded
          ;; into DCE-killed (:invalid) params.
          (if (or (not (live? f pid))
                  (const-param-of f pid)
                  (closure-value? f pid)
                  (closure-value? f arg-nid))
            (recur (inc i) pairs)
            (let [lhs (value-ident f pid)
                  lhs-spec (go-type-spec (ir/type-of pid f))
                  arg-spec (go-type-spec (ir/type-of arg-nid f))
                  rhs (cond
                        ;; LHS is vm.Value: box raw RHS if needed.
                        (= "vm.Value" lhs-spec)
                        (box-as-value f closed-exprs arg-nid)
                        ;; LHS is a native primitive but RHS is vm.Value: unbox.
                        ;; Edge refinement (refine-truthy/falsey) can narrow a
                        ;; param to one primitive while its incoming arg stays
                        ;; vm.Value, so the copy needs a type-assert/convert.
                        ;; Generalizes the former bool-only IsTruthy special case
                        ;; to every box-as-value target (int/float/string/char).
                        (and lhs-spec (not= lhs-spec arg-spec) (= "vm.Value" arg-spec))
                        (let [raw (value-expr f closed-exprs arg-nid)]
                          (when raw (unbox-from-value lhs-spec raw)))
                        :else
                        (value-expr f closed-exprs arg-nid))]
              (if (nil? rhs)
                nil
                (if (same-ident? lhs rhs)
                  (recur (inc i) pairs)
                  (recur (inc i) (conj pairs [lhs rhs])))))))))))

(defn- transfer-stmts [f closed-exprs bt]
  (let [assigns (emit-assignments-for-target f closed-exprs bt)]
    (when assigns
      (conj assigns (gogen/goto-stmt (label-name (ir/branch-target-target bt)))))))

(defn- lower-terminator [f closed-exprs bid]
  (let [term (ir/block-term bid f)
        op   (ir/op term f)
        refs (ir/refs term f)
        aux  (ir/aux term f)
        needs-error? (function-needs-error? f)]
    (cond
      (= op :return)
      (when (= 1 (count refs))
        ;; Coerce the return value to the function's declared return type.
        ;; If the function returns vm.Value, box raw values. Otherwise emit
        ;; raw and let result-node have chosen the matching type.
        (let [ret-spec (function-return-spec f)
              expr (if (= "vm.Value" ret-spec)
                     (box-as-value f closed-exprs (nth refs 0))
                     (value-expr f closed-exprs (nth refs 0)))]
          (when expr
            [(gogen/return-stmt
               (if needs-error?
                 [expr (gogen/ident "nil")]
                 [expr]))])))

      (= op :branch)
      (transfer-stmts f closed-exprs aux)

      (= op :branch-if)
      (when (= 1 (count refs))
        (let [cond-nid    (nth refs 0)
              cond-spec   (go-type-spec (ir/type-of cond-nid f))
              raw-cond    (value-expr f closed-exprs cond-nid)
              cond-expr   (if (= "bool" cond-spec)
                            raw-cond
                            (when raw-cond
                              (gogen/call
                                (gogen/field-sel (gogen/ident "vm") "IsTruthy")
                                [raw-cond])))
              true-stmts  (transfer-stmts f closed-exprs (ir/cond-target-true aux))
              false-stmts (transfer-stmts f closed-exprs (ir/cond-target-false aux))]
          (when (and cond-expr true-stmts false-stmts)
            [(gogen/if-stmt nil cond-expr true-stmts false-stmts)])))

      (= op :tail-call)
      (let [tail-args refs
            fixed-arity (if (ir/fn-variadic? f) (dec (ir/fn-arity f)) (ir/fn-arity f))
            assigns (loop [i 0 remaining tail-args out []]
                      (if (empty? remaining)
                        out
                        (let [val-expr (box-as-value f closed-exprs (first remaining))
                              lhs (if (and (ir/fn-variadic? f) (= i fixed-arity))
                                    (gogen/ident "args0")
                                    (gogen/ident (str "a" i)))]
                          (if (nil? val-expr)
                            nil
                            (recur (inc i) (rest remaining)
                                   (if (same-ident? lhs val-expr)
                                     out
                                     (conj out (gogen/assign "=" lhs val-expr))))))))]
        (when assigns
          (conj assigns (gogen/goto-stmt "func_entry"))))

      :else nil)))

(declare function-needs-error?)

;; When bound (by the two-pass go-lowering in pipeline.lg) to
;;   {:ns "<namespace>" :fns {"<let-go-name>" {:arity n :go-name "<go-func>"}}}
;; intra-namespace calls to single-arity, vm.Value-uniform lowered siblings are
;; emitted as direct Go calls instead of rt.InvokeValue/LookupVar. Default nil →
;; behavior is exactly as before (bytecode path and any single-pass caller).
(def ^:dynamic *lowered-siblings* nil)

(defn- direct-call-target
  "If callee-ref is a :load-var naming a same-namespace lowered sibling in
   *lowered-siblings* with matching arity, return its entry
   {:go-name :arity :needs-error?}; else nil."
  [f callee-ref argc]
  (when (and *lowered-siblings* (= :load-var (ir/op callee-ref f)))
    (let [sym   (symbol (ir/aux callee-ref f))
          sns   (namespace sym)
          entry (get (:fns *lowered-siblings*) (name sym))]
      (when (and entry
                 (or (nil? sns) (= sns (:ns *lowered-siblings*)))
                 (= argc (:arity entry)))
        entry))))

(defn- call-assign-stmts [f closed-exprs nid]
  (let [refs      (ir/refs nid f)
        arg-exprs (mapv (fn [rid] (box-as-value f closed-exprs rid)) (rest refs))
        entry     (direct-call-target f (first refs) (count (rest refs)))]
    (if (and entry (not (:needs-error? entry)))
      ;; Direct call to a sibling returning a single vm.Value (no error):
      ;; emit `result = callee(args)` with NO callErr / err-check. (rt.InvokeValue
      ;; always returns (vm.Value, error), so the 2-value form below applies only
      ;; to it and to error-returning direct callees.)
      (let [call-expr (gogen/call (gogen/ident (:go-name entry)) arg-exprs)]
        (when (every? identity arg-exprs)
          (if (live? f nid)
            [(gogen/multi-assign "=" [(value-ident f nid)] [call-expr])]
            [(gogen/multi-assign "=" [(gogen/ident "_")] [call-expr])])))
      ;; Two-value form: rt.InvokeValue, or a direct call to an error-returning
      ;; sibling. Both yield (vm.Value, error).
      (let [call-expr (if entry
                        (gogen/call (gogen/ident (:go-name entry)) arg-exprs)
                        (let [callee (box-as-value f closed-exprs (first refs))]
                          (when callee
                            (gogen/call
                              (gogen/field-sel (gogen/ident "rt") "InvokeValue")
                              [callee (gogen/composite-lit (gogen/type "[]vm.Value") arg-exprs)]))))
            err-id    (gogen/ident "callErr")]
        (when (and call-expr (every? identity arg-exprs))
          (let [assign (if (live? f nid)
                         (gogen/multi-assign "=" [(value-ident f nid) err-id] [call-expr])
                         (gogen/multi-assign "=" [(gogen/ident "_") err-id] [call-expr]))
                ;; Error-path return zero value must match the function's actual
                ;; declared return type (not always nil — bool/int/etc. have
                ;; different zeros).
                zero-expr (case (function-return-spec f)
                            "bool"    (gogen/ident "false")
                            "int"     (gogen/int-lit 0)
                            "float64" (gogen/float-lit 0.0)
                            "string"  (gogen/string-lit "")
                            (gogen/ident "nil"))
                err-check (gogen/if-stmt nil
                                         (gogen/binary "!=" err-id (gogen/ident "nil"))
                                         [(gogen/return-stmt [zero-expr err-id])]
                                         nil)]
            [assign err-check]))))))

(defn- lower-inst-stmts [f closed-exprs nid]
  (let [op  (ir/op nid f)
        aux (ir/aux nid f)]
    (cond
      (= op :load-arg)  []
      (= op :load-var)  []
      (= op :load-closed) []
      (and (= op :const) (any-fn-template? aux))
      []
      (= op :const)     []
      (= op :make-closure) []
      (= op :push-closed)  []
      (= op :block-arg) []
      (contains? binary-op op)
      (if (live? f nid)
        (let [rhs (inst-rhs f closed-exprs nid)]
          (when rhs
            [(gogen/assign "=" (value-ident f nid) rhs)]))
        [])
      (or (= op :inc) (= op :dec))
      (if (live? f nid)
        (let [rhs (inst-rhs f closed-exprs nid)]
          (when rhs
            [(gogen/assign "=" (value-ident f nid) rhs)]))
        [])
      (= op :call)
      (call-assign-stmts f closed-exprs nid)
      :else nil)))

(defn- lower-block-stmts [f closed-exprs bid]
  (let [label-stmts (if (= bid (ir/entry-block f))
                      []
                      [(gogen/label-stmt (label-name bid) nil)])
        insts (ir/block-insts bid f)
        inst-stmts (loop [remaining insts out []]
                     (if (empty? remaining)
                       out
                       (let [stmts (lower-inst-stmts f closed-exprs (first remaining))]
                         (if (nil? stmts)
                           (let [op (ir/op (first remaining) f)]
                             ;; A nil result means "no statement". Side-effect-free
                             ;; ops (loads/const/block-arg, and any other dead value)
                             ;; can be skipped. A :call that returns nil, however, is
                             ;; an un-lowerable side-effecting call (e.g. push-binding!
                             ;; with a (var X) arg) — dropping it would change behavior,
                             ;; so the whole function must fall back instead.
                             (if (and (not= op :call)
                                      (or (= op :load-arg)
                                          (= op :load-var)
                                          (= op :load-closed)
                                          (= op :const)
                                          (= op :block-arg)
                                          (not (live? f (first remaining)))))
                               (recur (rest remaining) out)
                               nil))
                           (recur (rest remaining) (into out stmts))))))
        term-stmts (lower-terminator f closed-exprs bid)]
    (when (and inst-stmts term-stmts)
      (vec (concat label-stmts inst-stmts term-stmts)))))

(defn- function-needs-error? [f]
  (loop [blocks (ir/blocks f)]
    (cond
      (empty? blocks) false
      (some (fn [nid] (= :call (ir/op nid f))) (ir/block-insts (first blocks) f)) true
      :else (recur (rest blocks)))))

(defn- function-needs-rt? [f]
  (let [local? (loop [blocks (ir/blocks f)]
                 (cond
                   (empty? blocks) false
                   (some (fn [nid]
                           (let [op   (ir/op nid f)
                                 aux  (ir/aux nid f)
                                 refs (ir/refs nid f)]
                             (or (= op :call)
                                 (= op :load-var)
                                 (any-fn-template? aux)
                                 ;; Binary op with any vm.Value operand
                                 ;; lowers to rt.<Op>Value helper call.
                                 (and (contains? binary-op op)
                                      (not= op :eq)
                                      (or (= "vm.Value" (go-type-spec (ir/type-of (nth refs 0) f)))
                                          (= "vm.Value" (go-type-spec (ir/type-of (nth refs 1) f)))))
                                 ;; inc/dec over vm.Value also delegates to
                                 ;; rt.AddValue/SubValue so unknown numeric
                                 ;; values do not emit invalid native Go
                                 ;; arithmetic.
                                 (and (or (= op :inc) (= op :dec))
                                      (= "vm.Value" (go-type-spec (ir/type-of (nth refs 0) f)))))))
                         (ir/block-insts (first blocks) f))
                   true
                   :else (recur (rest blocks))))]
    (or (ir/fn-variadic? f)
        local?
        (some function-needs-rt? (nested-template-fns f)))))

(defn- function-needs-vm? [f]
  (let [arg-types (or (ir/fn-arg-types f) [])
        ret-ids   (or (return-ref-ids f) [])]
    (or (ir/fn-variadic? f)
        (function-needs-rt? f)
        (some (fn [t] (= "vm.Value" (go-type-spec t))) arg-types)
        (some (fn [nid] (= "vm.Value" (go-type-spec (ir/type-of nid f)))) ret-ids)
        (some function-needs-vm? (nested-template-fns f)))))

(defn- function-needs-tail-call? [f]
  ;; Blocks with no terminator (e.g. unreachable dead blocks left by build)
  ;; return nil from block-term; `(ir/op nil f)` would fail. Skip them.
  (loop [blocks (ir/blocks f)]
    (cond
      (empty? blocks) false
      :else
      (let [term (ir/block-term (first blocks) f)]
        (cond
          (nil? term) (recur (rest blocks))
          (= :tail-call (ir/op term f)) true
          :else (recur (rest blocks)))))))

(defn- arg-local-decls [f]
  "For tail-call fns, declare mutable locals (a0, a1, ...) that shadow the
   immutable Go params, plus init assignments (a0 = arg0, ...).
   Returns [var-decls assign-stmts]."
  (let [arity       (ir/fn-arity f)
        variadic?   (ir/fn-variadic? f)
        fixed-arity (if variadic? (dec arity) arity)]
    (loop [i 0 decls [] assigns []]
      (if (>= i fixed-arity)
        (let [final-decls decls
              final-assigns assigns]
          (if variadic?
            [(conj final-decls (gogen/var-decl "args0" (gogen/type "[]vm.Value") nil))
             (conj final-assigns
                   (gogen/assign "=" (gogen/ident "args0") (gogen/ident "args")))]
            [final-decls final-assigns]))
        (let [sym (str "a" i)
              arg-sym (str "arg" i)]
          (recur (inc i)
                 (conj decls (gogen/var-decl sym (gogen/type "vm.Value") nil))
                 (conj assigns
                       (gogen/assign "=" (gogen/ident sym) (gogen/ident arg-sym)))))))))

;; --- out-of-SSA coalescing (block-oriented; phi-free) -----------------------
;; The IR is block-parameter SSA, and the build pass propagates each source
;; variable's name onto its block params. A variable's SSA versions are
;; sequential (each def kills the prior), so they can share ONE mutable Go
;; local: name every nid carrying source name S as `S`. The only unsafe case
;; is shadowing — two distinct same-named bindings live at once — detected
;; conservatively: a name is unsafe if a single inst references two DIFFERENT
;; nids carrying it. Unsafe names stay versioned. No union-find, no dominance,
;; no liveness engine.

(defn- oos-all-nids [f]
  (let [acc (atom [])]
    (doseq [bid (ir/blocks f)]
      (doseq [p (ir/block-params bid f)] (swap! acc conj p))
      (doseq [nid (ir/block-insts bid f)] (swap! acc conj nid)))
    (distinct @acc)))

(defn- oos-unsafe-names [f]
  ;; #{source-name} unsafe to coalesce: some single inst references two
  ;; distinct nids sharing the name (both live at once — e.g. shadowing).
  (let [unsafe (atom #{})]
    (doseq [bid (ir/blocks f)
            nid (ir/block-insts bid f)]
      (let [seen (atom {})]
        (doseq [r (ir/refs nid f)]
          (let [s (source-name-of f r)]
            (when (and (string? s) (pos? (count s)))
              (if-let [prev (get @seen s)]
                (when (not= prev r) (swap! unsafe conj s))
                (swap! seen assoc s r)))))))
    @unsafe))

(defn- oos-captured-names [f]
  ;; Source names that arrive via :load-closed (lexical captures). Such a name
  ;; must NOT coalesce onto a block-param local: that param would shadow the Go
  ;; closure's captured variable, and the init copy (param = capture) — being a
  ;; textual self-assign over the shared name — is elided, leaving the capture
  ;; unread (the closure would read a zero value). Keeping captured names
  ;; versioned makes the copy real and preserves the capture.
  (let [acc (atom #{})]
    (doseq [bid (ir/blocks f)
            nid (ir/block-insts bid f)]
      (when (= :load-closed (ir/op nid f))
        (let [s (source-name-of f nid)]
          (when (and (string? s) (pos? (count s)))
            (swap! acc conj s)))))
    @acc))

(defn- oos-branch-targets [term f]
  ;; The branch-targets a terminator transfers control to (for reasoning about
  ;; which block-param incoming args are read).
  (let [op (ir/op term f) aux (ir/aux term f)]
    (cond
      (= op :branch)    [aux]
      (= op :branch-if) [(ir/cond-target-true aux) (ir/cond-target-false aux)]
      :else             [])))

(defn- coalesce-map [f]
  ;; {nid go-name} for every nid whose source name is safe to coalesce; all
  ;; same-named versions map to the one bare name. Absent nids fall through to
  ;; value-name's versioned naming. Cached on f by lower-body.
  ;; A name is coalescable only when it is (1) interference-safe and (2) every
  ;; version shares ONE Go type — versions of differing type (e.g. the and/or
  ;; macro temps, bool vs vm.Value) cannot share a single mutable local.
  (let [unsafe (into (oos-unsafe-names f) (oos-captured-names f))
        nids   (oos-all-nids f)
        name-types (reduce (fn [m nid]
                             (let [s (source-name-of f nid)]
                               (if (and (string? s) (pos? (count s)))
                                 (assoc m s (conj (get m s #{})
                                                  (go-type-spec (ir/type-of nid f))))
                                 m)))
                           {}
                           nids)]
    (reduce (fn [result nid]
              (let [s (source-name-of f nid)]
                (if (and (string? s) (pos? (count s))
                         (not (contains? unsafe s))
                         (= 1 (count (get name-types s))))
                  (let [gn (go-name s)]
                    ;; never coalesce to the Go blank identifier or an empty
                    ;; name; those fall through to versioned naming (valid).
                    (if (and (pos? (count gn)) (not= "_" gn))
                      (assoc result nid gn)
                      result))
                  result)))
            {}
            nids)))

(defn- live-nids [f]
  ;; Backward read-set: the nids whose VALUE is actually read by emitted Go.
  ;; Roots: refs of value-reading terminators (:return / :branch-if cond /
  ;; :tail-call args) and refs of every :call inst (calls always emit for their
  ;; side effects, so their callee+args are read). Propagation to a fixpoint: a
  ;; live instruction's refs are read; a live block-param's incoming branch-args
  ;; are read. Dead duplicate subexpressions — which build threads twice and the
  ;; ir/uses table still marks "used" — are reachable from nothing and stay out,
  ;; so lowering routes their side-effecting calls to `_` and never declares the
  ;; pure ones.
  (let [live (atom #{})
        seed (fn [nid] (swap! live conj nid))]
    (doseq [bid (ir/blocks f)]
      (let [term (ir/block-term bid f)]
        (when term
          (let [op (ir/op term f)]
            (when (or (= op :return) (= op :branch-if) (= op :tail-call))
              (doseq [r (ir/refs term f)] (seed r))))))
      (doseq [nid (ir/block-insts bid f)]
        (when (= :call (ir/op nid f))
          (doseq [r (ir/refs nid f)] (seed r)))))
    (loop []
      (let [before (count @live)]
        (doseq [bid (ir/blocks f)]
          (doseq [nid (ir/block-insts bid f)]
            (when (contains? @live nid)
              (doseq [r (ir/refs nid f)] (seed r))))
          (let [term (ir/block-term bid f)]
            (when term
              (doseq [bt (oos-branch-targets term f)]
                (let [tgt    (ir/branch-target-target bt)
                      params (ir/block-params tgt f)
                      args   (ir/branch-target-args bt)]
                  (loop [i 0]
                    (when (< i (count params))
                      (when (and (< i (count args))
                                 (contains? @live (nth params i)))
                        (seed (nth args i)))
                      (recur (inc i)))))))))
        (when (> (count @live) before) (recur))))
    @live))

(defn- oos-param-incoming-args [f b i]
  ;; Every argument feeding param index i of block b, across predecessor edges.
  (let [acc (atom [])]
    (doseq [bp (ir/block-preds b f)]
      (let [term (ir/block-term bp f)]
        (when term
          (doseq [bt (oos-branch-targets term f)]
            (when (= (ir/branch-target-target bt) b)
              (let [args (ir/branch-target-args bt)]
                (when (< i (count args))
                  (swap! acc conj (nth args i)))))))))
    @acc))

(defn- const-inst-val [f nid]
  ;; [value] when nid is a :const we can re-materialize as a literal; nil else.
  ;; Wrapped in a vector so a genuine `nil`/`false` const is distinguishable from
  ;; "not a const". fn-template consts are excluded (not plain literals).
  (when (= :const (ir/op nid f))
    (let [aux (ir/aux nid f)]
      (when (not (any-fn-template? aux))
        [aux]))))

;; Lattice for constant-param analysis: :top (no info yet) ⊐ [const-value] ⊐ :bot
;; (provably not a single constant). meet moves DOWN only, so the fixpoint is
;; monotone and terminates.
(defn- cp-meet [a b]
  (cond
    (= a :top) b
    (= b :top) a
    (= a :bot) :bot
    (= b :bot) :bot
    (= a b)    a       ; [c] meet [c]
    :else      :bot))  ; [c] meet [d], c != d

(defn- cp-value [f known a p]
  ;; The lattice value an incoming arg contributes to param p. A self-ref
  ;; (loop back-edge passing p through) contributes :top — it constrains nothing.
  ;; A :const inst contributes its [value]; another param contributes its current
  ;; lattice value; any other inst (call/inc/…) is :bot (not a constant).
  (if (= a p)
    :top
    (or (const-inst-val f a)
        (get known a :bot))))

(defn- const-param-map [f]
  ;; nid -> [const-value] for every block-param that PROVABLY always holds ONE
  ;; constant on every path. OPTIMISTIC fixpoint (SCCP-style): all params start
  ;; :top, each is lowered to the meet of its incoming args, iterated to a fixed
  ;; point. Optimism is essential — a constant threaded around a LOOP forms a
  ;; param cycle (v79←v80←v81←v78←v79 all carrying :else); a pessimistic
  ;; "promote only when all inputs already known" pass deadlocks on the cycle,
  ;; the optimistic meet resolves it. A constant is block-free, so a const-param
  ;; lowers to the literal inline — NO cross-block ref, NO interference, NO copy —
  ;; collapsing constant copy chains the cross-block-ref invariant forbids
  ;; rewriting in the IR.
  (let [known (atom {})]
    (doseq [bid (ir/blocks f)
            p   (ir/block-params bid f)]
      (swap! known assoc p :top))
    (loop []
      (let [changed (atom false)]
        (doseq [bid (ir/blocks f)]
          (let [params (ir/block-params bid f)]
            (loop [i 0]
              (when (< i (count params))
                (let [p    (nth params i)
                      args (oos-param-incoming-args f bid i)
                      newv (if (empty? args)
                             :bot
                             (reduce cp-meet :top
                                     (map (fn [a] (cp-value f @known a p)) args)))]
                  (when (not= newv (get @known p))
                    (swap! known assoc p newv)
                    (reset! changed true)))
                (recur (inc i))))))
        (when @changed (recur))))
    (reduce (fn [m kv] (if (vector? (val kv)) (assoc m (key kv) (val kv)) m))
            {}
            @known)))

(defn- const-param-of [f nid]
  ;; [const-value] if nid is a recognized constant block-param (cached on f), nil
  ;; otherwise. Falls back to nil for non-lowering callers.
  (when-let [cp (:const-params (deref f))]
    (get cp nid)))

(defn- lower-body
  ([f] (lower-body f nil))
  ([f closed-exprs]
   ;; Per-fn lowering caches. param-sources + closure-memo back the
   ;; block-parameter-lineage closure resolution (closure-value? is queried per
   ;; param/edge); the rest back read-set gating, coalescing and const-params.
   (swap! f assoc :param-sources (compute-param-sources f))
   (swap! f assoc :closure-memo (atom {}))
   (swap! f assoc :const-params (const-param-map f))
   (swap! f assoc :coalesce (coalesce-map f))
   (swap! f assoc :live (live-nids f))
   (let [needs-error? (function-needs-error? f)
         needs-tail-call? (function-needs-tail-call? f)
         decls0 (local-decls f)
         decls1 (if needs-error?
                  (conj decls0 (gogen/var-decl "callErr" (gogen/type "error") nil))
                  decls0)
         [arg-decls arg-inits] (if needs-tail-call?
                                 (arg-local-decls f)
                                 [[] []])
         decls  (into decls1 arg-decls)
         entry-label [(gogen/label-stmt "func_entry" nil)]]
     (when decls
       (loop [blocks (ir/blocks f)
              out    (if needs-tail-call?
                       (vec (concat decls arg-inits entry-label))
                       decls)]
         (if (empty? blocks)
           out
           (let [bid (first blocks)]
             ;; Skip dead/unterminated blocks — build can leave them and
             ;; lower-terminator would call (ir/op nil f), failing.
             (if (nil? (ir/block-term bid f))
               (recur (rest blocks) out)
               (let [stmts (lower-block-stmts f closed-exprs bid)]
                 (if (nil? stmts)
                   nil
                   (recur (rest blocks) (into out stmts))))))))))))
(defn- params-for [f]
  (let [arity       (ir/fn-arity f)
        variadic?   (ir/fn-variadic? f)
        fixed-arity (if variadic? (dec arity) arity)
        arg-types   (or (ir/fn-arg-types f) [])]
    (loop [i 0 out []]
      (if (>= i fixed-arity)
        (if variadic?
          (conj out (gogen/variadic-param "args" (gogen/type "vm.Value")))
          out)
        ;; Priority: load-arg inst's inferred type > explicit fn-arg-types
        ;; metadata > :unknown. The load-arg path picks up backward
        ;; inference from infer-arg-types so params can lower natively.
        (let [load-arg-t  (ir/fn-load-arg-type f i)
              meta-t      (if (< i (count arg-types)) (nth arg-types i) :unknown)
              t           (cond
                            (not= :unknown load-arg-t) load-arg-t
                            :else                      meta-t)
              go-type     (infer-go-type t)]
          (if (nil? go-type)
            nil
            (recur (inc i) (conj out (gogen/param (str "arg" i) go-type)))))))))

(defn- return-ref-ids [f]
  (loop [blocks (ir/blocks f) out []]
    (if (empty? blocks)
      out
      (let [term (ir/block-term (first blocks) f)]
        (cond
          ;; Block has no terminator — unreachable/dead block left over from
          ;; build. Skip; only terminated :return blocks contribute return ids.
          (nil? term)
          (recur (rest blocks) out)
          (= (ir/op term f) :return)
          (let [refs (ir/refs term f)]
            (if (= 1 (count refs))
              (recur (rest blocks) (conj out (nth refs 0)))
              nil))
          :else
          (recur (rest blocks) out))))))

(defn- function-return-spec [f]
  ;; What Go type does this function return? Mirrors result-node's logic.
  ;; Returns "vm.Value" / "bool" / "int" / "float64" / "string", or nil.
  (let [ret-ids (return-ref-ids f)]
    (when (and ret-ids (pos? (count ret-ids)))
      (let [specs (map (fn [nid] (go-type-spec (ir/type-of nid f))) ret-ids)]
        (when (and (every? identity specs)
                   (= 1 (count (distinct specs))))
          (first specs))))))

(defn- result-node [f]
  (let [ret-ids (return-ref-ids f)]
    (when (and ret-ids (pos? (count ret-ids)))
      (let [specs (map (fn [nid] (go-type-spec (ir/type-of nid f))) ret-ids)]
        (when (and (every? identity specs)
                   (= 1 (count (distinct specs))))
          (let [results [(gogen/result (gogen/type (first specs)))]]
            (if (function-needs-error? f)
              (conj results (gogen/result (gogen/type "error")))
              results)))))))

(defn- function-param-specs [f]
  ;; Go type-spec string ("vm.Value"/"int"/"bool"/…) for each fixed
  ;; (non-variadic) param, mirroring params-for's type resolution.
  (let [arity       (ir/fn-arity f)
        variadic?   (ir/fn-variadic? f)
        fixed-arity (if variadic? (dec arity) arity)
        arg-types   (or (ir/fn-arg-types f) [])]
    (loop [i 0 out []]
      (if (>= i fixed-arity)
        out
        (let [load-arg-t (ir/fn-load-arg-type f i)
              meta-t     (if (< i (count arg-types)) (nth arg-types i) :unknown)
              t          (if (not= :unknown load-arg-t) load-arg-t meta-t)]
          (recur (inc i) (conj out (go-type-spec t))))))))

(defn- override-uniform-value? [f]
  ;; True iff the lowered Go signature is uniformly vm.Value in / vm.Value
  ;; out (the error result aside). Such a fn can be wrapped as a NativeFn
  ;; override with NO boxing/unboxing at the boundary — args[i] flow
  ;; straight in and the result straight out. Fns with typed (int/bool/…)
  ;; params or result need coercion the Part-1 wrapper does not emit, so
  ;; they are left to dispatch via bytecode.
  (and (not (ir/fn-variadic? f))
       (= "vm.Value" (function-return-spec f))
       (every? (fn [s] (= "vm.Value" s)) (function-param-specs f))))

(defn- lower-fn-lit [f closed-exprs]
  ;; Returns nil on any unlowerable inner — callers (closure-expr →
  ;; lower-template-closure-expr) propagate nil up through value-expr,
  ;; which makes the OUTER defn fall back via the normal :status :fallback
  ;; path in lower-fn*. Previously this threw, which still ended in the
  ;; same fallback but interrupted control flow harshly and made it
  ;; harder to attribute the failure. Per-closure fallback (NOTE: this
  ;; is a stopgap; the real fix is lambda lifting — see
  ;; project-lambda-lifting-todo memory).
  (let [params  (params-for f)
        results (result-node f)
        body    (lower-body f closed-exprs)]
    (when (and params results body)
      (gogen/func-lit params results body))))

(defn- lower-fn* [f mode]
  (let [params  (params-for f)
        results (result-node f)
        body    (lower-body f)
        needs-rt? (function-needs-rt? f)
        needs-vm? (function-needs-vm? f)
        needs-error? (function-needs-error? f)
        imports (vec
                  (concat
                    (if needs-rt?
                      [(import-entry "github.com/nooga/let-go/pkg/rt" "rt")]
                      [])
                    (if needs-vm?
                      [(import-entry "github.com/nooga/let-go/pkg/vm" "vm")]
                      [])))]
    (cond
      (nil? params)  (unsupported mode "unsupported parameter types")
      (nil? results) (unsupported mode "unsupported result type")
      (nil? body)    (unsupported mode "unsupported function body shape")
      :else
      ;; :fn-name/:go-name/:arity/:needs-error?/:override-eligible? feed
      ;; the gogen_ir override-registration emitter (pipeline.lg's
      ;; register-init-decl). :override-eligible? is true only for
      ;; uniformly-vm.Value signatures the Part-1 wrapper can adapt
      ;; without coercion; typed (int/bool/…) and variadic fns are
      ;; excluded and stay on bytecode. (Multi-arity defns never reach
      ;; this path: lgbgen's runGoTarget pre-filters to isSingleArityDefn
      ;; before calling lower-ns-to-go.)
      {:status :lowered
       :imports imports
       :fn-name (str (ir/fn-name f))
       :go-name (go-name (ir/fn-name f))
       :arity (ir/fn-arity f)
       :needs-error? needs-error?
       :override-eligible? (override-uniform-value? f)
       :decl   (gogen/func-decl (go-name (ir/fn-name f)) params results body)})))

(defn- import-spec-node [entry]
  (let [path  (:path entry)
        alias (:alias entry)]
    (if alias
      (gogen/import-spec path alias)
      (gogen/import-spec path))))

(defn- distinct-imports [entries]
  (loop [remaining entries seen #{} out []]
    (if (empty? remaining)
      out
      (let [entry (first remaining)
            key   [(:path entry) (:alias entry)]]
        (if (contains? seen key)
          (recur (rest remaining) seen out)
          (recur (rest remaining) (conj seen key) (conj out entry)))))))

(defn file [pkg lowered-results]
  (let [results (vec lowered-results)
        imports (distinct-imports
                  (mapcat (fn [result]
                            (let [entries (:imports result)]
                              (if entries entries [])))
                          results))
        decls   (mapv (fn [result] (:decl result)) results)
        import-nodes (mapv import-spec-node imports)]
    (gogen/file pkg import-nodes decls)))

(defn lower [f mode]
  (if (nil? f)
    (throw "ir.lower-go: nil function")
    (try
      (lower-fn* f mode)
      (catch e
        (if (= mode :bridge)
          {:status :fallback :decl nil :reason (str e)}
          (throw e))))))
