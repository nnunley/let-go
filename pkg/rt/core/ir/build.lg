;; Lisp-side Forms→IR Build — sem-ir Phase 1 Tasks 5–6.
;;
;; Take a Lisp `(defn name [args] body)` form and produce a boxed
;; *ir.Function (via the ir/ namespace primitives defined in
;; pkg/rt/ir_bridge_generated.go).
;;
;; Coverage so far:
;;   - literals: int, string, keyword → Const
;;   - symbols: lexical local lookup; otherwise LoadVar
;;   - arithmetic: + - *  → Add/Sub/Mul
;;   - function args: LoadArg per arg, bound in lexical scope
;;   - generic calls: LoadVar(head) + Invoke
;;   - special forms (Task 6): if, let, do, quote
;;   - terminator: Return on the final block
;;
;; Pending (Task 7+): loop/recur with block-arg threading.

;; ir.data MUST load before any (ir/new-fn ...) call here resolves;
;; its bottom intern block overrides the Go bridge primitives with
;; the Lisp data layer's atom-backed implementations.
(ns ir.build
  (:require
   [ir.data]))

;; --- builder context -----------------------------------------------------

(defn new-context [fn]
  (atom {:fn            fn
         :current-block (ir/entry-block fn)
         :locals        [{}]
         :gensym        0}))

(defn ctx-gensym!
  "Deterministic, ctx-scoped replacement for (gensym prefix) used for
   IR-build slot keys (e.g. arg__/head__). The counter lives in the ctx
   atom and is fresh per `new-context`, so generated names are a pure
   function of build order within a single function build — NOT of the
   process-global gensym counter. This makes lowering reproducible across
   regenerations; previously these names drifted (arg__8368 -> arg__52670)
   with however many gensyms had run earlier in the process. Monotonic over
   the whole ctx lifetime, so nested build-args never collide."
  [ctx prefix]
  (let [s @ctx
        n (get s :gensym 0)]
    (reset! ctx (assoc s :gensym (inc n)))
    (symbol (str prefix n))))

(defn ctx-fn [ctx] (get @ctx :fn))
(defn ctx-block [ctx] (get @ctx :current-block))

(defn ctx-set-block! [ctx blk]
  (reset! ctx (assoc @ctx :current-block blk)))

(defn push-locals! [ctx]
  (let [s @ctx]
    (reset! ctx (assoc s :locals (conj (get s :locals) {})))))

(defn pop-locals! [ctx]
  (let [s @ctx
        stack (get s :locals)]
    (reset! ctx (assoc s :locals (subvec stack 0 (dec (count stack)))))))

(defn- attach-name! [ctx inst-id sym]
  "Attach a name-only SourceInfo to the inst so lower-go can emit a
   readable Go identifier. Skipped for non-positive inst-ids (block
   params, which use a different addressing scheme)."
  (when (and (integer? inst-id) (>= inst-id 0))
    (let [f (ctx-fn ctx)]
      (ir/add-source-info! f inst-id (ir/new-named-source-info (str sym))))))

(defn bind-local! [ctx sym inst-id]
  (let [s @ctx
        stack (get s :locals)
        top-idx (dec (count stack))
        top (nth stack top-idx)]
    (reset! ctx (assoc s :locals (assoc stack top-idx (assoc top sym inst-id))))
    (attach-name! ctx inst-id sym)))

(defn rebind-local! [ctx sym inst-id]
  "Find the nearest frame containing sym and update it there;
   if not found anywhere, bind in the top frame."
  (let [s @ctx
        stack (get s :locals)]
    (loop [i (dec (count stack))]
      (cond
        (< i 0) (bind-local! ctx sym inst-id)
        (contains? (nth stack i) sym)
        (let [updated-frame (assoc (nth stack i) sym inst-id)
              new-stack (assoc stack i updated-frame)]
          (reset! ctx (assoc s :locals new-stack))
          (attach-name! ctx inst-id sym))
        :else (recur (dec i))))))

(defn lookup-local [ctx sym]
  (loop [i (dec (count (get @ctx :locals)))]
    (cond
      (< i 0) nil
      (contains? (nth (get @ctx :locals) i) sym)
      (get (nth (get @ctx :locals) i) sym)
      :else (recur (dec i)))))

(defn current-locals-flat [ctx]
  "Flatten the locals scope stack into a single sym→InstId map.
   Inner scopes shadow outer."
  (reduce merge {} (get @ctx :locals)))
(defn- binding-syms [sym]
  (cond
    (symbol? sym) #{sym}
    (vector? sym) (into #{} (filter symbol? (flatten sym)))
    (map? sym)    (let [keys-syms (when-let [ks (:keys sym)]
                                    (into #{} (map (fn [x] (if (keyword? x) (symbol (name x)) x)) ks)))
                        strs-syms (when-let [ss (:strs sym)]
                                    (into #{} (map symbol ss)))
                        as-sym (when-let [as (:as sym)] #{as})
                        other-syms (into #{} (filter symbol? (keys (dissoc sym :keys :strs :as :or))))]
                    (into #{} (concat keys-syms strs-syms as-sym other-syms)))
    :else #{}))

(defn captures-of [form known-locals]
  "Return the SET of symbols `form` references that are bound in
   `known-locals`. Used by build-if/build-loop to compute which block-
   args each child block needs to receive.

   `known-locals` is a set of symbol; `form` is any Lisp form.

   Handles:
     - symbol: returns #{form} if known-local, else #{}
     - list (or seq): walks subforms, with special handling for:
       - (quote ...) — returns #{} (quoted data isn't a use)
       - (fn* ...)   — returns #{} (closures have their own scope;
                       captured-closed-overs are tracked elsewhere)
       - (let [bindings] body...) — bindings progressively shadow
                       outer locals; right-hand sides see the locals
                       known BEFORE that binding's name is introduced
     - vector: walks subforms
     - other: #{}"
  (cond
    (symbol? form)
    (if (known-locals form) #{form} #{})
    (or (list? form) (seq? form))
    (let [head (first form)]
      (cond
        (= head 'quote) #{}
        (= head 'var)   #{}
        (= head 'set!)  (let [[_ _sym val] form]
                          (captures-of val known-locals))
        (= head 'fn*)
        ;; fn* captures its free vars via push-closed in the current
        ;; block. If those captured InstIds live in a different block
        ;; (e.g. the entry block's LoadArgs), the closure-emit creates
        ;; a cross-block direct-ref. Including the captures here makes
        ;; build-if/build-loop thread them through block-args so the
        ;; push-closed refs the local block-arg instead. Shadowing
        ;; logic mirrors free-vars's fn* case.
        (let [[_ maybe-name & raw-rest] form
              has-name?  (symbol? maybe-name)
              name-sym   (if has-name? maybe-name nil)
              rest-forms (if has-name? raw-rest (cons maybe-name raw-rest))
              multi?     (and (seq rest-forms) (list? (first rest-forms)))
              shadow-for (fn [args-vec]
                           (if name-sym
                             (conj (into #{} args-vec) name-sym)
                             (into #{} args-vec)))]
          (if-not multi?
            (let [args-vec   (first rest-forms)
                  body       (rest rest-forms)
                  inner-known (difference known-locals (shadow-for args-vec))]
              (into #{} (mapcat #(captures-of % inner-known) body)))
            (into #{} (mapcat (fn [arity-form]
                                (let [args-vec    (first arity-form)
                                      body        (rest arity-form)
                                      inner-known (difference known-locals
                                                              (shadow-for args-vec))]
                                  (mapcat #(captures-of % inner-known) body)))
                              rest-forms))))
        (or (= head 'let) (= head 'let*) (= head 'loop) (= head 'loop*))
        (let [[_ bindings & body] form
              pairs    (partition 2 bindings)
              [used let-bound-set]
              (reduce (fn [[caps shadowed] [sym init]]
                        (let [locs (difference known-locals shadowed)]
                          [(into caps (captures-of init locs))
                           (into shadowed (binding-syms sym))]))
                      [#{} #{}]
                      pairs)
              new-locals    (into known-locals let-bound-set)
              body-captures (into #{} (mapcat #(captures-of % new-locals) body))]
          (into used (difference body-captures let-bound-set)))
        :else
        (into #{} (mapcat #(captures-of % known-locals) form))))
    (vector? form)
    (into #{} (mapcat #(captures-of % known-locals) form))
    :else #{}))

;; --- form dispatch -------------------------------------------------------

(declare build-list build-symbol build-if build-let build-do build-quote
         build-var build-set! build-loop build-recur build-fn*
         build-vector build-map build-call)

;; Sentinel returned by recur / any form whose current-block is already
;; terminated. Callers must check for this before emitting more code.
(def TERMINATED :ir-build/terminated)

(defn terminated? [v] (= v TERMINATED))

(defn- add-inst! [ctx block op-kw refs aux]
  (let [f (ctx-fn ctx)
        nid (ir/add-inst f block op-kw refs aux)
        si (get @ctx :source-info)]
    (when si
      (ir/add-source-info! f nid si))
    nid))

(defn- add-terminator! [ctx bid op-kw refs aux]
  (let [f (ctx-fn ctx)
        nid (ir/add-terminator! f bid op-kw refs aux)
        si (get @ctx :source-info)]
    (when si
      (ir/add-source-info! f nid si))
    nid))

(defn build-form [form ctx]
  "Build IR for one form; return the InstId of its result value."
  (let [si (ir/form-source-info form)
        old-si (get @ctx :source-info)
        _ (when si (swap! ctx assoc :source-info si))
        nid (cond
              (nil?     form)  (add-inst! ctx (ctx-block ctx) :const [] nil)
              (integer? form)  (add-inst! ctx (ctx-block ctx) :const [] form)
              (float?   form)  (add-inst! ctx (ctx-block ctx) :const [] form)
              (string?  form)  (add-inst! ctx (ctx-block ctx) :const [] form)
              (char?    form)  (add-inst! ctx (ctx-block ctx) :const [] form)
              (keyword? form)  (add-inst! ctx (ctx-block ctx) :const [] form)
              (boolean? form)  (add-inst! ctx (ctx-block ctx) :const [] form)
              (symbol?  form)  (build-symbol form ctx)
              (vector?  form)  (build-vector form ctx)
              (map?     form)  (build-map form ctx)
              (list?    form)  (build-list form ctx)
              :else (throw (str "build-form: unrecognized form " form)))]
    (when si
      (swap! ctx assoc :source-info old-si))
    nid))

(defn build-symbol [sym ctx]
  (let [local (lookup-local ctx sym)]
    (if local
      local
      (let [v (resolve sym)]
        (if (nil? v)
          (throw (str "ir/build: unresolved symbol " sym))
          (add-inst! ctx (ctx-block ctx) :load-var [] v))))))

(defn- free-vars [form bound]
  "Return the set of symbols in form that are not bound locally.
   Recurses into fn* bodies so outer-scope captures are tracked
   through nested closures."
  (cond
    (symbol? form)
    (if (bound form) #{} #{form})
    (or (list? form) (seq? form))
    (let [head (first form)]
      (cond
        (= head 'quote) #{}
        (= head 'var)   #{}
        (= head 'set!)  (let [[_ _sym val] form] (free-vars val bound))
        (= head 'fn*)
        (let [[_ maybe-name & raw-rest] form
              has-name?  (symbol? maybe-name)
              name-sym   (if has-name? maybe-name nil)
              rest-forms (if has-name? raw-rest (cons maybe-name raw-rest))
              multi?     (and (seq rest-forms) (list? (first rest-forms)))]
          (if-not multi?
            (let [args-vec (first rest-forms)
                  body     (rest rest-forms)
                  arg-set  (if name-sym
                             (conj (into #{} args-vec) name-sym)
                             (into #{} args-vec))]
              (into #{} (mapcat #(free-vars % arg-set) body)))
            (into #{} (mapcat (fn [arity-form]
                                (let [args-vec (first arity-form)
                                      body     (rest arity-form)
                                      arg-set  (if name-sym
                                                 (conj (into #{} args-vec) name-sym)
                                                 (into #{} args-vec))]
                                  (mapcat #(free-vars % arg-set) body)))
                              rest-forms))))
        (or (= head 'let) (= head 'let*) (= head 'loop) (= head 'loop*))
        (let [[_ bindings & body] form
              pairs    (partition 2 bindings)
              [used new-bound]
              (reduce (fn [[caps b] [sym init]]
                        [(into caps (free-vars init b))
                         (into b (binding-syms sym))])
                      [#{} bound]
                      pairs)]
          (into used (mapcat #(free-vars % new-bound) body)))
        :else
        (into #{} (mapcat #(free-vars % bound) form))))
    (vector? form)
    (into #{} (mapcat #(free-vars % bound) form))
    :else #{}))

;; --- builtin operator dispatch -----------------------------------------
;;
;; Map of head-symbol → IR op keyword for n-ary builtin operators. Each
;; entry compiles like a generic call but emits a typed op directly
;; (Add/Lt/etc.) instead of OpCall with a LoadVar'd head. Keeps the
;; dispatch table the single source of truth.

(def builtin-ops
  {'+    :add
   '-    :sub
   '*    :mul
   'quot :quot
   '<    :lt
   '<=   :lte
   '>    :gt
   '>=   :gte
   '=    :eq
   'inc  :inc
   'dec  :dec})

;; Ops whose arity-1 form is the canonical shape (no n-ary folding).
(def unary-only-ops #{:inc :dec})

(defn build-args [forms ctx]
  ;; Build each arg, AND register its result as a temporary live local
  ;; under a gensym so any subsequent arg's build-if symmetric pass-
  ;; through threads this value through new blocks. After all args are
  ;; built, re-lookup each gensym — the rebinding by intervening
  ;; if-joins gives us the threaded (current-block) value, not the
  ;; original cross-block InstId.
  ;;
  ;; Without this, a multi-arg op like (+ (if ...A) (if ...B)) would
  ;; emit the final op in B's join block but ref A's result (defined
  ;; in A's join block) — a cross-block direct ref.
  (let [pre-locals (current-locals-flat ctx)]
    (push-locals! ctx)
    (let [syms    (atom [])
          results (atom [])]
      (doseq [a forms]
        (let [r (build-form a ctx)]
          (if (terminated? r)
            (do (swap! syms conj nil)
                (swap! results conj r))
            (let [sym (ctx-gensym! ctx "arg__")]
              (bind-local! ctx sym r)
              (swap! syms conj sym)
              (swap! results conj r)))))
      ;; Re-lookup each gensym to pick up the threaded InstId (the local
      ;; may have been rebound to a join-block BlockArg by subsequent
      ;; build-if invocations).
      (let [threaded (vec (map (fn [sym orig]
                                 (if sym
                                   (or (lookup-local ctx sym) orig)
                                   orig))
                               @syms
                               @results))
            post-locals (current-locals-flat ctx)]
        (pop-locals! ctx)
        ;; If nested ifs inside args rebound outer-scope symbols to join-block
        ;; BlockArgs, those rebindings were in the temporary arg scope.  After
        ;; popping they're lost, but the current block is still the join block.
        ;; Preserve any outer-scope bindings that changed so later code
        ;; (e.g. a call head looked up after args) finds the threaded value.
        (doseq [[sym val] post-locals]
          (when (and (contains? pre-locals sym)
                     (not= val (get pre-locals sym)))
            (bind-local! ctx sym val)))
        threaded))))

(defn- build-call-with-head [fn-id args-forms ctx]
  "Helper to build call arguments while threading the function head ID
   through any potential branch joins inside build-args. Prevents cross-block refs."
  (push-locals! ctx)
  (let [head-sym (ctx-gensym! ctx "head__")
        _        (bind-local! ctx head-sym fn-id)
        arg-ids  (build-args args-forms ctx)
        threaded (lookup-local ctx head-sym)]
    (pop-locals! ctx)
    (add-inst! ctx (ctx-block ctx) :call
      (vec (cons threaded arg-ids))
      (count arg-ids))))

(defn fold-binary-chain [op-kw args ctx]
  "Build a left-leaning chain of binary Insts: [a b c d] → (((a op b) op c) op d)."
  (loop [acc (add-inst! ctx (ctx-block ctx)
               op-kw [(nth args 0) (nth args 1)] nil)
         i   2]
    (if (>= i (count args))
      acc
      (recur (add-inst! ctx (ctx-block ctx)
               op-kw [acc (nth args i)] nil)
             (inc i)))))

(defn build-builtin-op [op-kw form ctx]
  ;; Builtin ops are binary (stack-effect 2→1). Fold n-ary calls.
  ;; Unary-only ops (:inc, :dec) take exactly one ref.
  (let [args (build-args (rest form) ctx)]
    (cond
      (contains? unary-only-ops op-kw)
      (if (= 1 (count args))
        (ir/add-inst (ctx-fn ctx) (ctx-block ctx) op-kw [(nth args 0)] nil)
        ;; Wrong-arity (inc) / (inc x y) — fall back to a generic call so
        ;; the runtime arity-error surfaces normally.
        (build-call form ctx))
      ;; Unary: (- x) → (sub 0 x); (+ x), (* x), comparisons → identity.
      (= 1 (count args))
      (if (= op-kw :sub)
        (let [zero-id (add-inst! ctx (ctx-block ctx) :const [] 0)]
          (add-inst! ctx (ctx-block ctx) :sub [zero-id (nth args 0)] nil))
        (nth args 0))
      (= 2 (count args))
      (add-inst! ctx (ctx-block ctx) op-kw args nil)
      :else
      (fold-binary-chain op-kw args ctx))))

(defn build-call [form ctx]
  ;; Generic function call. Aux is the arity (Refs[0] is the fn value,
  ;; Refs[1:] are the args), matching OpCall in op_generated.go.
  ;; Head may be a computed expression, not just a symbol.
  ;;
  ;; Build args FIRST so any nested control-flow inside args switches to
  ;; a join block BEFORE we build the head.  Otherwise the head (e.g. a
  ;; LoadVar for `not`) ends up in the entry block while the Call ends
  ;; up in the join block — a cross-block ref.
  (let [head    (first form)
        arg-ids (build-args (rest form) ctx)
        fn-id   (if (symbol? head)
                  (build-symbol head ctx)
                  (build-form head ctx))]
    (build-call-with-head fn-id (rest form) ctx)))

(defn build-list [form ctx]
  (let [head    (first form)
        builtin (get builtin-ops head)]
    (cond
      (= head 'if)    (build-if form ctx)
      (= head 'let)   (build-let form ctx)
      (= head 'let*)  (build-let form ctx)
      (= head 'do)    (build-do form ctx)
      (= head 'quote) (build-quote form ctx)
      (= head 'var)   (build-var form ctx)
      (= head 'set!)  (build-set! form ctx)
      (= head 'loop)  (build-loop form ctx)
      (= head 'loop*) (build-loop form ctx)
      (= head 'recur) (build-recur form ctx)
      (= head 'fn*)   (build-fn* form ctx)
      builtin         (build-builtin-op builtin form ctx)
      ;; Keywords, numbers, strings are callable (implement IFn in Clojure).
      ;; Treat them as Const values, build as generic call with const head.
      ;; Build args first so nested control-flow doesn't strand the const
      ;; head in an earlier block.
      (or (keyword? head) (number? head) (string? head))
      (let [fn-id   (build-form head ctx)]
        (build-call-with-head fn-id (rest form) ctx))
      :else           (build-call form ctx))))

;; --- special forms -------------------------------------------------------

(defn build-quote [form ctx]
  "(quote x) emits a Const Inst with x as the Aux."
  (let [[_ x] form]
    (add-inst! ctx (ctx-block ctx) :const [] x)))

(defn build-var [form ctx]
  "(var sym) and reader macro #'sym resolve sym at build time and emit
   a Const Inst with the *vm.Var as the Aux — same as bytecode's
   varCompiler: LOAD_CONST of the Var object itself (not its value)."
  (let [[_ sym] form
        v       (resolve sym)]
    (if (nil? v)
      (throw (str "ir/build: can't resolve var " sym))
      (add-inst! ctx (ctx-block ctx) :const [] v))))

(defn build-set! [form ctx]
  "(set! sym val) resolves sym to a *vm.Var at build time and emits a
   :set-var Inst whose refs are [var-inst val-inst]. Matches bytecode
   setBangCompiler: LOAD_CONST(var) → compile val → OP_SET_VAR. Result
   is the Var itself (SET_VAR pushes the var back)."
  (let [[_ sym val] form
        v           (resolve sym)]
    (when (nil? v)
      (throw (str "ir/build: set! can't resolve " sym)))
    (let [var-nid (add-inst! ctx (ctx-block ctx) :const [] v)
          val-nid (build-form val ctx)]
      (add-inst! ctx (ctx-block ctx) :set-var [var-nid val-nid] nil))))

(defn build-vector [form ctx]
  "[a b c] → (vector a b c). Empty vector → Const literal.
   Each element flows through build-form so sub-expressions IR-build
   correctly; build-args handles cross-block threading."
  (if (zero? (count form))
    (add-inst! ctx (ctx-block ctx) :const [] form)
    (let [fn-id   (add-inst! ctx (ctx-block ctx)
                    :load-var [] (resolve 'vector))]
      (build-call-with-head fn-id (seq form) ctx))))

(defn is-literal? [v]
  "Check if v is a literal value (not a symbol or expression)."
  (or (nil? v) (integer? v) (float? v) (string? v) (keyword? v) (boolean? v)))

(defn build-map [form ctx]
  "{:a 1 :b 2} → Const if all keys/values are literals; else (array-map :a 1 :b 2).
   array-map preserves insertion order. Empty map → Const literal."
  (if (zero? (count form))
    (add-inst! ctx (ctx-block ctx) :const [] form)
    ;; Check if all keys and values are literals (not symbols/expressions).
    ;; If so, emit as a constant.
    (let [all-const? (every? (fn [e]
                               (and (is-literal? (first e)) (is-literal? (second e))))
                             (seq form))
          pairs      (vec (mapcat (fn [e] [(first e) (second e)]) (seq form)))]
      (if all-const?
        (add-inst! ctx (ctx-block ctx) :const [] form)
        (let [fn-id   (add-inst! ctx (ctx-block ctx)
                        :load-var [] (resolve 'array-map))]
          (build-call-with-head fn-id pairs ctx))))))

(defn build-do [form ctx]
  "do evaluates each form sequentially; result is the last one."
  (let [forms (rest form)]
    (loop [fs forms last-id nil]
      (if (seq fs)
        (recur (rest fs) (build-form (first fs) ctx))
        last-id))))

(defn build-let [form ctx]
  "let pushes a locals scope, evaluates bindings pairwise, then body."
  (let [[_ bindings & body] form]
    (push-locals! ctx)
    (loop [i 0]
      (when (< i (count bindings))
        (let [sym     (nth bindings i)
              expr    (nth bindings (inc i))
              expr-id (build-form expr ctx)]
          (bind-local! ctx sym expr-id)
          (recur (+ i 2)))))
    (let [result (loop [fs body last-id nil]
                   (if (seq fs)
                     (recur (rest fs) (build-form (first fs) ctx))
                     last-id))
          ;; If the body switched to a join block (via nested if),
          ;; build-if rebound outer-scope vars to BlockArgs in the
          ;; current scope.  After we pop the let-scope those rebindings
          ;; vanish, but the current block is still the join block, so
          ;; later lookups would find the stale pre-join InstIds and
          ;; emit cross-block refs.  Preserve any outer-scope BlockArg
          ;; bindings by copying them back into the parent scope.
          let-syms   (into #{} (map #(nth bindings %) (range 0 (count bindings) 2)))
          post-locals (current-locals-flat ctx)]
      (pop-locals! ctx)
      (doseq [[sym val] post-locals]
        (when (and (not (let-syms sym))
                   (not= val (lookup-local ctx sym)))
          (bind-local! ctx sym val)))
      result)))

(defn build-if [form ctx]
  "if emits BranchIf with then/else BranchTargets and a join block.
   Each child block gets BlockArg params for the captures it needs
   from the parent scope (computed by captures-of). The BranchIf
   passes those captured values via BranchTarget.args. Result: no
   cross-block direct refs in IR built from if.

   Either branch may evaluate to TERMINATED (e.g. its body ends in recur);
   in that case we DON'T emit a branch-to-join for that branch and DON'T
   register it as a join-pred. The join block then has fewer preds.
   If both branches terminate, the if itself is terminated and we return
   TERMINATED without entering the join block."
  (let [[_ test-form then-form & rest-form] form
        else-form (first rest-form)  ; nil when (if test then) — else omitted
        f         (ctx-fn ctx)
        entry-blk (ctx-block ctx)
        ;; Pass ALL current locals as branch-target args (symmetric).
        ;; Reason: a downstream `recur` (or any control-flow that later
        ;; passes parent-scope values back) needs those values to be in
        ;; scope inside the branch blocks. captures-of only sees direct
        ;; references in the if's BODIES, so a loop-invariant referenced
        ;; ONLY in the loop header's test would be dropped — then recur
        ;; from inside the if-else couldn't reference it. Passing all
        ;; locals is the simpler invariant; DCE drops anything the
        ;; branch doesn't actually need. Symmetric args let both
        ;; targets enter with the same param layout.
        ;;
        ;; Sort by InstId so the args appear in parent-stack order: the
        ;; lower's skip-prefix fast path then matches and no DUP_NTH
        ;; reordering is emitted in the common case.
        locals-map (current-locals-flat ctx)
        all-caps   (vec (sort-by (fn [sym] (get locals-map sym))
                          (keys locals-map)))
        ;; Create blocks for then, else, join.
        then-blk  (ir/add-block f)
        else-blk  (ir/add-block f)
        join-blk  (ir/add-block f)
        ;; Emit one BlockArg per capture in each child block — identical
        ;; shape across both branches.
        then-params (mapv (fn [sym]
                            (let [pid (add-inst! ctx then-blk :block-arg [] (count (ir/block-params then-blk f)))]
                              (ir/add-block-param! f then-blk pid)
                              (ir/add-source-info! f pid (ir/new-named-source-info (str sym)))
                              pid))
                          all-caps)
        else-params (mapv (fn [sym]
                            (let [pid (add-inst! ctx else-blk :block-arg [] (count (ir/block-params else-blk f)))]
                              (ir/add-block-param! f else-blk pid)
                              (ir/add-source-info! f pid (ir/new-named-source-info (str sym)))
                              pid))
                          all-caps)
        ;; Materialize the test in the parent block.
        test-id   (build-form test-form ctx)
        ;; If the test contained control flow (e.g. `and` → nested if),
        ;; build-form may have switched to a join block.  Capture the
        ;; block where the test *finished* — that is where the BranchIf
        ;; must live.
        entry-blk (ctx-block ctx)
        ;; Look up each capture's parent-scope InstId — same args go to
        ;; both BranchTargets (symmetric layout invariant; validate.lg
        ;; enforces this post-build).
        bt-args   (mapv (fn [sym] (lookup-local ctx sym)) all-caps)
        true-bt   (ir/new-branch-target then-blk bt-args)
        false-bt  (ir/new-branch-target else-blk bt-args)
        cond-aux  (ir/new-cond-target true-bt false-bt)
        _         (add-terminator! ctx entry-blk :branch-if [test-id] cond-aux)
        _         (ir/add-pred! f then-blk entry-blk)
        _         (ir/add-pred! f else-blk entry-blk)]
    ;; --- then branch ---
    (ctx-set-block! ctx then-blk)
    (push-locals! ctx)
    (doseq [[sym pid] (map vector all-caps then-params)]
      (bind-local! ctx sym pid))
    (let [then-val (build-form then-form ctx)
          then-end (ctx-block ctx)
          then-terminated? (terminated? then-val)
          ;; Capture each cap's current scope-binding BEFORE pop-locals!
          ;; so we send the then-branch's BlockArg (not the parent stale).
          then-cap-vals (when-not then-terminated?
                          (mapv (fn [sym] (lookup-local ctx sym)) all-caps))]
      (pop-locals! ctx)
      (when-not then-terminated?
        (add-terminator! ctx then-end :branch []
          (ir/new-branch-target join-blk
                                (vec (cons then-val then-cap-vals))))
        (ir/add-pred! f join-blk then-end))
      ;; --- else branch ---
      (ctx-set-block! ctx else-blk)
      (push-locals! ctx)
      (doseq [[sym pid] (map vector all-caps else-params)]
        (bind-local! ctx sym pid))
      (let [else-val (build-form else-form ctx)
            else-end (ctx-block ctx)
            else-terminated? (terminated? else-val)
            else-cap-vals (when-not else-terminated?
                            (mapv (fn [sym] (lookup-local ctx sym)) all-caps))]
        (pop-locals! ctx)
        (when-not else-terminated?
          (add-terminator! ctx else-end :branch []
            (ir/new-branch-target join-blk
                                  (vec (cons else-val else-cap-vals))))
          (ir/add-pred! f join-blk else-end))
        ;; --- join continuation ---
        (cond
          (and then-terminated? else-terminated?) TERMINATED
          :else
          (do (ctx-set-block! ctx join-blk)
              ;; Slot 0 = merged result. Slots 1..N = re-bound captures.
              (let [merged (add-inst! ctx join-blk :block-arg [] 0)
                    _      (ir/add-block-param! f join-blk merged)
                    cap-pids (mapv (fn [i]
                                     (let [pid (add-inst! ctx join-blk :block-arg [] (inc i))]
                                       (ir/add-block-param! f join-blk pid)
                                       (ir/add-source-info! f pid (ir/new-named-source-info (str (nth all-caps i))))
                                       pid))
                                   (range (count all-caps)))]
                ;; Rebind in the CURRENT top scope so future lookup-local
                ;; in this lexical scope finds the join's BlockArg first.
                (doseq [[sym pid] (map vector all-caps cap-pids)]
                  (rebind-local! ctx sym pid))
                merged)))))))

(defn build-loop [form ctx]
  "loop pushes a fresh locals scope, evaluates init vals, creates a
   header block with block-args for both loop vars AND parent-scope
   captures, and builds the body in that header. Recur branches back
   to the header carrying new loop-var values and self-passing the
   captures (loop-invariant pass-through)."
  (let [[_ bindings & body] form
        f          (ctx-fn ctx)
        n-slots    (/ (count bindings) 2)
        old-header (get @ctx :loop-header)
        old-caps   (get @ctx :loop-capture-syms)
        ;; Loop pushes its own scope AFTER this captures pass, so the
        ;; parent locals don't include the loop vars yet — captures-of
        ;; over `known` naturally excludes them.
        known     (set (keys (current-locals-flat ctx)))
        body-caps (vec (reduce (fn [acc bf] (into acc (captures-of bf known)))
                               #{}
                               body))
        n-caps    (count body-caps)
        ;; Total header param count = n-slots (loop vars) + n-caps (captures).
        header    (ir/add-block f)
        ;; Emit BlockArg + Param for each loop-var slot (positions 0..n-slots-1).
        loop-param-ids (mapv (fn [i]
                               (let [pid (add-inst! ctx header :block-arg [] i)]
                                 (ir/add-block-param! f header pid)
                                 (ir/add-source-info! f pid (ir/new-named-source-info (str (nth bindings (* i 2)))))
                                 pid))
                             (range n-slots))
        ;; Emit BlockArg + Param for each capture (positions n-slots..n-slots+n-caps-1).
        cap-param-ids  (mapv (fn [i]
                               (let [pid (add-inst! ctx header :block-arg [] (+ n-slots i))]
                                 (ir/add-block-param! f header pid)
                                 (ir/add-source-info! f pid (ir/new-named-source-info (str (nth body-caps i))))
                                 pid))
                             (range n-caps))
        ;; Evaluate initial values in the PRE-loop block. Each build-form
        ;; can switch ctx-block if the init expression contains nested
        ;; control flow, so we must re-read ctx-block AFTER building all
        ;; inits and terminate THAT block — not the block we entered with.
        init-vals (mapv (fn [i] (build-form (nth bindings (inc (* i 2))) ctx))
                        (range n-slots))
        ;; Look up each capture's parent-scope InstId.
        cap-vals  (mapv (fn [sym] (lookup-local ctx sym)) body-caps)
        ;; Branch entry-end → header(init-vals ++ cap-vals).
        bt        (ir/new-branch-target header (vec (concat init-vals cap-vals)))
        entry-end (ctx-block ctx)
        _         (add-terminator! ctx entry-end :branch [] bt)
        _         (ir/add-pred! f header entry-end)]
    ;; Switch to header.
    (ctx-set-block! ctx header)
    (push-locals! ctx)
    ;; Bind each loop var to its loop-var-param.
    (doseq [i (range n-slots)]
      (bind-local! ctx (nth bindings (* i 2)) (nth loop-param-ids i)))
    ;; Bind each capture symbol to its capture-param. (So body code
    ;; references the header's BlockArg, not the parent's InstId.)
    (doseq [[sym pid] (map vector body-caps cap-param-ids)]
      (rebind-local! ctx sym pid))
    ;; Stash :loop-header + capture metadata so recur can find them.
    ;; We stash the SYMBOLS (not their header-param InstIds) so that
    ;; build-recur looks them up against the CURRENT lexical scope —
    ;; build-if rebinds captures to its branch BlockArgs, and recur
    ;; from inside an if-else must pick those up (not the header's
    ;; stale param InstIds, which would be a cross-block ref).
    ;; Use a stack (conj/pop) so nested loops don't clobber outer state.
    (reset! ctx (-> @ctx
                    (update :loop-headers (fn [s] (conj (or s []) header)))
                    (update :loop-capture-syms-stack (fn [s] (conj (or s []) body-caps)))))
    ;; Build body.
    (let [pre-locals (current-locals-flat ctx)
          result (loop [fs body last-val nil]
                   (if (seq fs)
                     (recur (rest fs) (build-form (first fs) ctx))
                     last-val))
          post-locals (current-locals-flat ctx)]
      (pop-locals! ctx)
      ;; Preserve outer-scope bindings that changed to BlockArgs inside the loop
      ;; (e.g. via nested if join-blocks) so code after the loop sees the
      ;; threaded value, not a stale cross-block InstId.
      (doseq [[sym val] post-locals]
        (when (and (contains? pre-locals sym)
                   (not= val (get pre-locals sym)))
          (bind-local! ctx sym val)))
      (reset! ctx (-> @ctx
                      (update :loop-headers (fn [s] (pop (or s []))))
                      (update :loop-capture-syms-stack (fn [s] (pop (or s []))))))
      result)))

(defn build-recur [form ctx]
  "recur emits Branch back to the current loop header, or :tail-call for
   function-level recursion.

   Subtle: ctx-block must be re-read AFTER building the recur args, not
   captured at entry. A recur arg may contain nested control flow (e.g.
   `(recur (if cond a b) (next ks))`) whose build-form sequence creates
   join blocks and leaves ctx-block pointing at the join. The terminator
   has to land on that current join block, otherwise we'd terminate the
   already-sealed entry block and the join block would be left without
   a :term — failing validate-after-build."
  (let [headers (get @ctx :loop-headers)
        f       (ctx-fn ctx)]
    (if (and headers (seq headers))
      ;; Inside loop*: branch back to loop header.
      (let [header (peek headers)
            cap-syms-stack (get @ctx :loop-capture-syms-stack)
            cap-syms (or (peek cap-syms-stack) [])
            cap-vals (mapv (fn [sym] (lookup-local ctx sym)) cap-syms)
            loop-arg-ids (mapv (fn [a] (build-form a ctx)) (rest form))
            all-args (vec (concat loop-arg-ids cap-vals))
            bt       (ir/new-branch-target header all-args)
            cur      (ctx-block ctx)]
        (ir/add-terminator! f cur :branch [] bt)
        (ir/add-pred! f header cur)
        TERMINATED)
      ;; Function-level recur: emit :tail-call.
      (let [arg-syms (get @ctx :fn-arg-syms)]
        (if arg-syms
          (let [arg-ids (mapv (fn [a] (build-form a ctx)) (rest form))
                cur     (ctx-block ctx)]
            ;; :tail-call refs are just the new arg values (self-recursive,
            ;; no fn ref needed).
            (ir/add-terminator! f cur :tail-call arg-ids (count arg-ids))
            TERMINATED)
          (throw "recur outside of loop or function"))))))

;; --- destructuring helpers ------------------------------------------------
;; Port of core.lg's destructure* / destructure-vector / destructure-map.
;; Operates on S-expressions so the resulting let*/nth/get forms are
;; built by the normal IR builder path.

(declare expand-binding expand-map-pattern)

(defn- expand-vector-pattern [sym pat]
  (loop [i 0 remaining pat out []]
    (if (empty? remaining)
      (expand-binding out)
      (let [x (first remaining)]
        (cond
          (= x '&)
          (let [rest-pat (second remaining)
                rem*     (drop 2 remaining)
                rest-expr (list 'drop i sym)
                out*     (if (symbol? rest-pat)
                           (conj out rest-pat rest-expr)
                           (let [gs (gensym "rest__")]
                             (into (conj out gs rest-expr) (expand-binding [gs rest-pat]))))]
            (if (and (seq rem*) (= (first rem*) :as))
              (recur i (drop 2 rem*) (conj out* (second rem*) sym))
              (recur i rem* out*)))
          (= x :as)
          (recur i (drop 2 remaining) (conj out (second remaining) sym))
          (symbol? x)
          (recur (inc i) (rest remaining) (conj out x (list 'nth sym i nil)))
          (or (vector? x) (map? x))
          (let [gs     (gensym "v__")
                nested (cond
                         (vector? x) (expand-vector-pattern gs x)
                         (map? x)    (expand-map-pattern gs x))
                out*   (conj out gs (list 'nth sym i nil))]
            (recur (inc i) (rest remaining) (into out* nested)))
          :else
          (throw (str "unsupported destructuring pattern: " (pr-str x))))))))

(defn- expand-map-pattern [sym pat]
  (let [defaults (:or pat)
        as-sym   (:as pat)
        keys*    (:keys pat)
        strs*    (:strs pat)
        get-expr (fn [kn default]
                   (if default
                     (list 'get sym (keyword kn) default)
                     (list 'get sym (keyword kn))))
        binds    (loop [ks (or keys* []) out []]
                   (if (empty? ks)
                     out
                     (let [k  (first ks)
                           kn (if (keyword? k) (symbol (name k)) k)]
                       (recur (rest ks)
                              (conj out kn (get-expr kn (get defaults kn)))))))
        binds    (if strs*
                   (reduce (fn [out s]
                             (let [kn (if (keyword? s) (symbol (name s)) s)]
                               (conj out kn (get-expr kn (get defaults kn)))))
                           binds strs*)
                   binds)
        binds    (if as-sym (conj binds as-sym sym) binds)]
    (expand-binding binds)))

(defn- expand-binding [bindings]
  (loop [b bindings out []]
    (if (empty? b)
      out
      (let [n (first b) v (second b)]
        (cond
          (vector? n) (let [gs (gensym "vec__")]
                        (recur (drop 2 b)
                               (-> out (conj gs v) (into (expand-vector-pattern gs n)))))
          (map? n)    (let [gs (gensym "map__")]
                        (recur (drop 2 b)
                               (-> out (conj gs v) (into (expand-map-pattern gs n)))))
          (nil? n)    (recur (drop 2 b) out)
          :else       (recur (drop 2 b) (conj out n v)))))))

(defn- expand-fn-args [args-vec body-forms]
  "Detect & rest and destructuring patterns in args-vec.
   Returns nil if nothing to expand, or {:flat-args [...] :body (...) :variadic? bool}."
  (let [amp-pos   (loop [i 0 remaining args-vec]
                    (if (empty? remaining)
                      -1
                      (if (= (first remaining) '&)
                        i
                        (recur (inc i) (rest remaining)))))
        variadic? (not= amp-pos -1)
        fixed-args (if variadic? (take amp-pos args-vec) args-vec)
        rest-sym   (when variadic? (nth args-vec (inc amp-pos) nil))
        has-destructure? (some (fn [x] (not (symbol? x))) fixed-args)]
    (when (or variadic? has-destructure?)
      (let [result (loop [remaining fixed-args flat-args [] let-binds []]
                     (if (empty? remaining)
                       {:flat-args flat-args :let-binds let-binds}
                       (let [x (first remaining)]
                         (if (symbol? x)
                           (recur (rest remaining) (conj flat-args x) let-binds)
                           (let [gs (gensym "p__")
                                 binds (cond
                                         (vector? x) (expand-vector-pattern gs x)
                                         (map? x)    (expand-map-pattern gs x)
                                         :else (throw (str "unsupported arg pattern: " (pr-str x))))]
                             (recur (rest remaining)
                                    (conj flat-args gs)
                                    (into let-binds binds)))))))
            final-flat-args (if variadic?
                              (conj (:flat-args result) rest-sym)
                              (:flat-args result))
            body (if (seq (:let-binds result))
                   (list (apply list 'let* (vec (:let-binds result)) body-forms))
                   body-forms)]
        {:flat-args final-flat-args
         :body body
         :variadic? variadic?}))))

(defn- build-inner-fn-template [name-sym args-vec body-forms capture-syms variadic?]
  (let [inner     (ir/new-fn (str name-sym) (count args-vec) variadic?)
        entry     (ir/entry-block inner)
        inner-ctx (new-context inner)]
    ;; Stash arg symbols so build-recur can emit :tail-call at function level.
    (reset! inner-ctx (assoc @inner-ctx :fn-arg-syms (vec args-vec)))
    (loop [i 0]
      (when (< i (count args-vec))
        (bind-local! inner-ctx (nth args-vec i)
                     (add-inst! inner-ctx entry :load-arg [] i))
        (recur (inc i))))
    (loop [i 0]
      (when (< i (count capture-syms))
        (bind-local! inner-ctx (nth capture-syms i)
                     (ir/add-inst inner entry :load-closed [] i))
        (recur (inc i))))
    (let [last-val (loop [fs body-forms last-id nil]
                     (if (seq fs)
                       (recur (rest fs) (build-form (first fs) inner-ctx))
                       last-id))
          final-blk (ctx-block inner-ctx)]
      (when-not (terminated? last-val)
        (add-terminator! inner-ctx final-blk :return
          (if (nil? last-val) [] [last-val])
          nil)))
    {:kind :fn-template
     :fn inner
     :arity (count args-vec)
     :variadic? variadic?}))

(defn- emit-template-closure [template capture-syms ctx]
  (let [const-id   (ir/add-inst (ctx-fn ctx) (ctx-block ctx) :const [] template)
        closure-id (if (seq capture-syms)
                     (ir/add-inst (ctx-fn ctx) (ctx-block ctx)
                                  :make-closure [const-id] nil)
                     const-id)]
    (loop [cls closure-id
           caps capture-syms]
      (if (seq caps)
        (let [cap-sym (first caps)
              cap-val (build-symbol cap-sym ctx)
              push-id (ir/add-inst (ctx-fn ctx) (ctx-block ctx)
                                   :push-closed [cls cap-val] nil)]
          (recur push-id (rest caps)))
        cls))))

(defn- build-single-fn* [name-sym args-vec body-forms ctx]
  "Build a single-arity fn* and return the InstId of its value in ctx."
  (let [expanded   (expand-fn-args args-vec body-forms)
        flat-args  (if expanded (:flat-args expanded) args-vec)
        flat-body  (if expanded (:body expanded) body-forms)
        variadic?  (if expanded (:variadic? expanded) false)
        arg-set    (into #{} flat-args)
        frees      (free-vars (cons 'do flat-body) arg-set)
        captures   (vec (sort-by str (filter #(lookup-local ctx %) frees)))
        template   (build-inner-fn-template name-sym flat-args flat-body captures variadic?)]
    (emit-template-closure template captures ctx)))

(defn build-fn* [form ctx]
  "Compile (fn* ...) to IR in the outer function context.
   Handles single-arity, named single-arity, and multi-arity forms.
   Preserves nested function structure so the selected backend can
   lower fn* bodies natively instead of collapsing them here."
  (let [;; Detect multi-arity: (fn* ([args] body...) ([args2] body2...))
        ;;                  or (fn* name ([args] body...) ([args2] body2...))
        [_ maybe-name & raw-rest] form
        has-name?  (symbol? maybe-name)
        name-sym   (if has-name? maybe-name "fn*")
        rest-forms (if has-name? raw-rest (cons maybe-name raw-rest))
        multi?     (and (seq rest-forms) (list? (first rest-forms)))]
    (if-not multi?
      ;; Single-arity path
      (let [args-vec   (first rest-forms)
            body-forms (rest rest-forms)]
        (build-single-fn* name-sym args-vec body-forms ctx))
      ;; Multi-arity path: preserve each arity as a nested template with
      ;; a shared capture layout for all branches. Expand destructured
      ;; args before computing captures so free-vars sees only symbols.
      (let [arities   rest-forms
            expanded-forms (mapv (fn [arity-form]
                                   (let [args-vec   (first arity-form)
                                         body-forms (rest arity-form)
                                         e          (expand-fn-args args-vec body-forms)]
                                     (if e
                                       e
                                       {:flat-args args-vec :body body-forms :variadic? false})))
                                 arities)
            all-caps  (reduce (fn [caps {:keys [flat-args body]}]
                                (let [arg-set (into #{} flat-args)
                                      frees   (free-vars (cons 'do body) arg-set)]
                                  (into caps (filter #(lookup-local ctx %) frees))))
                              #{}
                              expanded-forms)
            captures  (vec (sort-by str all-caps))
            templates (mapv (fn [{:keys [flat-args body variadic?]}]
                              (build-inner-fn-template name-sym flat-args body captures variadic?))
                            expanded-forms)
            template  {:kind :multi-fn-template
                       :fns templates}]
        (emit-template-closure template captures ctx)))))

;; --- entry point ---------------------------------------------------------

(defn parse-defn-args-body [form]
  (let [x2 (nth form 2 nil)
        x3 (nth form 3 nil)
        x4 (nth form 4 nil)]
    (cond
      (string? x2)
      (if (map? x3)
        [x4 (drop 5 form)]
        [x3 (drop 4 form)])
      (map? x2)
      [x3 (drop 4 form)]
      :else
      [x2 (drop 3 form)])))

(defn build-fn [defn-form]
  "Build an IR Function from a (defn name [args] body...) or
   multi-arity (defn name ([args] body...) ([args2] body2...)) form.
   Handles optional docstring. Returns a boxed *ir.Function."
  (let [name-sym   (nth defn-form 1)
        maybe-doc  (nth defn-form 2)
        has-doc?   (string? maybe-doc)
        args-vec   (if has-doc? (nth defn-form 3) maybe-doc)
        body-forms (drop (if has-doc? 4 3) defn-form)
        multi?     (list? args-vec)]
    (if-not multi?
      ;; Single-arity path. Expand destructured args before building.
      (let [expanded   (expand-fn-args args-vec body-forms)
            flat-args  (if expanded (:flat-args expanded) args-vec)
            flat-body  (if expanded (:body expanded) body-forms)
            variadic?  (if expanded (:variadic? expanded) false)
            arity      (count flat-args)
            f          (ir/new-fn (str name-sym) arity variadic?)
            entry-blk  (ir/entry-block f)
            ctx        (new-context f)]
        ;; Stash arg symbols so build-recur can emit :tail-call at function level.
        (reset! ctx (assoc @ctx :fn-arg-syms (vec flat-args)))
        (loop [i 0]
          (when (< i arity)
            (let [arg-id (ir/add-inst f entry-blk :load-arg [] i)]
              (bind-local! ctx (nth flat-args i) arg-id)
              (recur (inc i)))))
        (let [last-val  (loop [fs flat-body last-id nil]
                          (if (seq fs)
                            (recur (rest fs) (build-form (first fs) ctx))
                            last-id))
              final-blk (ctx-block ctx)]
          (when-not (terminated? last-val)
            (ir/add-terminator! f final-blk :return
                                (if (nil? last-val) [] [last-val])
                                nil)))
        f)
      ;; Multi-arity path: preserve each arity as a nested template
      ;; with a shared capture layout. The outer function (arity 0)
      ;; returns the multi-arity closure value.
      (let [f          (ir/new-fn (str name-sym) 0 false)
            entry-blk  (ir/entry-block f)
            ctx        (new-context f)
            arities    (cons args-vec body-forms)
            expanded-forms (mapv (fn [arity-form]
                                   (let [arg-vec   (first arity-form)
                                         body-forms (rest arity-form)
                                         e          (expand-fn-args arg-vec body-forms)]
                                     (if e
                                       e
                                       {:flat-args arg-vec :body body-forms :variadic? false})))
                                 arities)
            all-caps   (reduce (fn [caps {:keys [flat-args body]}]
                                 (let [arg-set (into #{} flat-args)
                                       frees   (free-vars (cons 'do body) arg-set)]
                                   (into caps (filter #(lookup-local ctx %) frees))))
                               #{}
                               expanded-forms)
            captures   (vec (sort-by str all-caps))
            templates  (mapv (fn [{:keys [flat-args body variadic?]}]
                               (build-inner-fn-template name-sym flat-args body captures variadic?))
                             expanded-forms)
            template   {:kind :multi-fn-template :fns templates}
            closure-id (emit-template-closure template captures ctx)
            final-blk  (ctx-block ctx)]
        (ir/add-terminator! f final-blk :return [closure-id] nil)
        f))))
