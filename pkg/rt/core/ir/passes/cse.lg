;; Common-subexpression elimination — per-block.
;;
;; Algorithm (matching OLD pkg/ir/passes/cse.go @ ynwoxxro):
;;   For each block:
;;     hash-table seen: (op refs aux) → first-seen-InstId
;;     for each Inst in the block (in body order):
;;       if op is CSE-eligible (purity/pure-ops, or a stable :load-var):
;;         k = (op refs aux)
;;         if k in seen: replace all uses of this Inst with seen[k]
;;         else: seen[k] = this Inst
;;
;; :load-var is CSE-eligible only when ir.passes.mutability proves the
;; loaded Var is stable. Calls to known var-mutating builtins
;; conservatively mark all vars unstable.

(ns ir.passes.cse
  (:require
   [ir.passes.mutability :as mut]
   ;; Explicit dependency: cse-eligible? consults purity/pure-ops directly
   ;; rather than relying on a transitive load or bundle ordering.
   [ir.passes.purity :as purity]))

(defn- inst-key [nid f]
  "Hashable key identifying this Inst's value. Two Insts with the
   same key compute the same value."
  [(ir/op nid f) (vec (ir/refs nid f)) (ir/aux nid f)])

(defn- cse-eligible? [op nid f var-facts]
  ;; Value-pure ops come from purity/pure-ops (the canonical set, shared
  ;; with DCE and LICM — no local copy to drift). :call and the
  ;; terminators (:branch/:branch-if/:return) are excluded by omission.
  ;; :load-var is eligible only when mutability proves the Var stable.
  (or (contains? purity/pure-ops op)
      (and (= op :load-var)
           (mut/stable-load-var? var-facts (ir/aux nid f)))))

(defn cse [f]
  "Per-block CSE: hash eligible Insts by (op, refs, aux); subsequent
   matches in the same block redirect their uses to the first occurrence
   via ir/replace-all-uses!."
  (let [var-facts (mut/analyze-var-stability f)]
    (doseq [bid (ir/blocks f)]
      ;; Per-block hash table. Atom is fine here — it's per-block
      ;; CSE state, the analysis equivalent of one iteration scope.
      (let [seen (atom {})]
        (doseq [nid (vec (ir/block-insts bid f))
                :let [op (ir/op nid f)]
                :when (cse-eligible? op nid f var-facts)
                :let [k (inst-key nid f)]]
          (if-let [prior (@seen k)]
            (ir/replace-all-uses! f nid prior)
            (swap! seen assoc k nid))))))
  f)
