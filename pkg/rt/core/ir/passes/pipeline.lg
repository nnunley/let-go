;; The Lisp optimization-pass pipeline driver.
;;
;; `(optimize-fn f)` runs the enabled Lisp passes in a sensible order:
;;   1. constfold   — fold Const arithmetic, identities, canonicalize
;;   2. cse         — same-block common-subexpression elimination
;;   3. constfold   — again; CSE may expose new fold opportunities
;;   4. licm        — hoist loop-invariant Insts to pre-headers
;;   5. constfold   — again; LICM may rearrange uses such that more
;;                    folds become possible
;;   6. dce         — drop pure Insts with zero uses (cleanup)
;;
;; Build (Phase 3) now emits BlockArg params proactively for all cross-block
;; captures, eliminating the need for post-pass threading.
;;
;; CSE remains intentionally narrow: same-block pure ops plus stable
;; LoadVar values only. Dominance/GVN-style cross-block CSE is deferred.
;;
;; Returns f (same object — passes mutate in place).

(ns ir.passes.pipeline
  (:require
   [graph :as g]
   [ir.build]
   [ir.lattice :as lat]
   [ir.lower :as lower]
   [ir.lower-go :as lower-go]
   [ir.passes.constfold :refer [constfold]]
   [ir.passes.cse :refer [cse]]
   [ir.passes.dce :refer [dce]]
   [ir.passes.infer-arg-types :refer [infer-arg-types]]
   [ir.passes.licm :refer [licm]]
   [ir.passes.typeinfer :refer [typeinfer]]
   [ir.validate :refer [validate-fn!]]))

(defn- run-typeinfra-epoch [f]
  (let [state0 (lat/seed-state-from-inst-types! (lat/new-typeinfra-state f) f)
        state1 (infer-arg-types f state0)
        state2 (typeinfer f state1)]
    (lat/flush-state-types! state2 f)
    f))

(defn optimize-fn [f]
  (validate-fn! f "build")
  (run-typeinfra-epoch f) (validate-fn! f "infer-arg-types")
  (constfold f)        (validate-fn! f "constfold-1")
  (cse f)              (validate-fn! f "cse")
  (constfold f)        (validate-fn! f "constfold-2")
  (licm f)             (validate-fn! f "licm")
  (constfold f)        (validate-fn! f "constfold-3")
  (dce f)              (validate-fn! f "dce")
  (run-typeinfra-epoch f)
  f)

(declare expand-all)

(declare dt-rewrite-field dt-rewrite-let dt-rewrite-fn)

;; Binding forms with a clean `[target init ...]` vector (no for/doseq-style
;; :let/:when modifiers). Their inits are rewritten in the outer scope; their
;; targets shadow field names inside the body. Mirrors core.lg's -dt-let-like.
;; NB: a *quoted* set literal '#{..} reads as a (hash-set ..) form in let-go,
;; so build the set explicitly with (set '(...)).
(def -dt-field-let-like
  (set '(let let* loop loop* when-let when-let* if-let if-let*
          when-some if-some binding with-open with-local-vars dotimes)))

;; Symbols a binding target introduces (conservative over destructuring: every
;; symbol in the pattern except &).
(defn- dt-collect-syms [form]
  (cond
    (and (symbol? form) (not= form '&)) (list form)
    (vector? form) (apply concat (map dt-collect-syms form))
    (map? form) (apply concat (map (fn [e] (dt-collect-syms (vec e))) (seq form)))
    :else nil))

(defn- dt-rewrite-field
  "Rewrite bare field symbols in a deftype method body into (. this field)
   member-access forms (lowered natively by build-dot/:dot), honoring lexical
   shadowing: a field symbol rebound by the method params or an inner let/loop/
   fn binding is left untouched. `bound` is the set of locally-bound symbols in
   scope. Mirrors core.lg's -dt-rewrite (the bytecode path), minus mutable-field
   / set! handling — the native deftype path is immutable. Known limitation
   (shared with core.lg): for/doseq/letfn are not treated as binding forms."
  [fieldset this-sym bound form]
  (cond
    (symbol? form)
    (if (and (contains? fieldset form) (not (contains? bound form)))
      (list '. this-sym form)
      form)
    (vector? form)
    (vec (map (fn [x] (dt-rewrite-field fieldset this-sym bound x)) form))
    (not (seq? form)) form
    (empty? form) form
    :else
    (let [h (first form)]
      (cond
        (= h 'quote) form
        (and (contains? -dt-field-let-like h) (vector? (second form)))
        (dt-rewrite-let fieldset this-sym bound form)
        (or (= h 'fn) (= h 'fn*))
        (dt-rewrite-fn fieldset this-sym bound form)
        :else
        (apply list (map (fn [x] (dt-rewrite-field fieldset this-sym bound x)) form))))))

(defn- dt-rewrite-let [fieldset this-sym bound form]
  (let [h    (first form)
        bvec (second form)
        body (next (next form))]
    (loop [v (seq bvec) b bound out []]
      (if (or (nil? v) (nil? (next v)))
        (apply list h (vec out)
               (map (fn [x] (dt-rewrite-field fieldset this-sym b x)) body))
        (let [target   (first v)
              init     (second v)
              new-init (dt-rewrite-field fieldset this-sym b init)
              b2       (reduce conj b (dt-collect-syms target))]
          (recur (next (next v)) b2 (conj (conj out target) new-init)))))))

(defn- dt-rewrite-fn [fieldset this-sym bound form]
  (let [h     (first form)
        tail  (next form)
        named (if (and tail (symbol? (first tail))) (first tail) nil)
        rest1 (if named (next tail) tail)
        b1    (if named (conj bound named) bound)
        rw    (fn [params body]
                (let [b2 (reduce conj b1 (dt-collect-syms params))]
                  (apply list params
                         (map (fn [x] (dt-rewrite-field fieldset this-sym b2 x)) body))))]
    (if (and rest1 (vector? (first rest1)))
      (apply list h (concat (if named (list named) (list)) (rw (first rest1) (next rest1))))
      (apply list h (concat (if named (list named) (list))
                            (map (fn [c] (rw (first c) (next c))) rest1))))))

(def ^:private *deftype-method-ir-cache*
  ;; Per-compile cache [tname mname arity] -> built+optimized IR fn, so a deftype
  ;; method isn't run through the full optimize-fn pipeline twice (once for
  ;; protocol-method-sigs/:needs-error?, once for lowering). Reset at the start of
  ;; the orchestration let below.
  (atom {}))

(defn- build-method-ir-fn
  "Build + optimize the IR fn for one deftype protocol-method impl form
   (mname [this & args] body...): bare field refs become (. this field), the body
   is built+optimized, and the receiver arg is seeded as [:dtype tname]. Cached
   per compile so :needs-error? analysis and lowering share a single build."
  [tname fieldset mform]
  (let [ckey [tname (first mform) (count (second mform))]]
    (or (get @*deftype-method-ir-cache* ckey)
        (let [params    (second mform)
              this-sym  (first params)
              body      (drop 2 mform)
              ;; Method params (receiver + args) shadow field names: seed the
              ;; bound set with all of them so a param like `side` on a type with
              ;; a `side` field stays the param, not (. this side).
              bound0    (set (dt-collect-syms params))
              rewritten (map (fn [b] (dt-rewrite-field fieldset this-sym bound0 b)) body)
              defn-form (apply list 'defn (first mform) params (map expand-all rewritten))
              ir-fn     (-> defn-form ir.build/build-fn optimize-fn)]
          (swap! ir-fn assoc :arg-types [[:dtype tname]])
          (swap! *deftype-method-ir-cache* assoc ckey ir-fn)
          ir-fn))))

(defn- protocol-method-sigs
  "Join across all impls of every protocol method to a unified signature map
   keyed by exported Go method name: {go-name {:needs-error? bool}}.
   MVP: only :needs-error? is joined (OR). An impl is total when its built IR fn
   needs no error (no try / only error-free calls), evaluated with
   *force-needs-error* unbound so the body's real shape shows through."
  [deftypes]
  (reduce
    (fn [acc dt]
      (let [tname    (:name dt)
            fieldset (set (:fields dt))]
        (reduce
          (fn [m mform]
            (let [ir-fn (build-method-ir-fn tname fieldset mform)
                  ne?   (binding [lower-go/*force-needs-error* nil]
                          (lower-go/function-needs-error? ir-fn))
                  gname (lower-go/go-export-name (first mform))
                  prev  (get m gname)]
              (assoc m gname {:needs-error? (or (:needs-error? prev) ne?)})))
          acc
          (filter (fn [x] (and (seq? x) (symbol? (first x)) (vector? (second x))))
                  (:impls dt)))))
    {}
    deftypes))

(defn lower-deftype-methods
  "Lower the protocol-method impls of a :deftype capture to native Go receiver
   methods. For each (mname [this & args] body...): bare field refs become
   (. this field), the body is built+optimized as an IR fn whose receiver arg
   is seeded as [:dtype T], then lowered (ir.lower-go/lower-method) to a method
   on *T. Returns {:status :lowered :decls [<method-decl> ...]}."
  [decl]
  (let [tname       (:name decl)
        struct-name (lower-go/go-export-name tname)
        recv-type   (str "*" struct-name)
        fieldset    (set (:fields decl))
        methods     (filter (fn [x] (and (seq? x) (symbol? (first x)) (vector? (second x))))
                            (:impls decl))
        decls       (mapv
                      (fn [m]
                        (let [ir-fn  (build-method-ir-fn tname fieldset m)
                              result (lower-go/lower-method ir-fn recv-type
                                       (lower-go/go-export-name (first m)))]
                          (:decl result)))
                      methods)]
    {:status :lowered :decls decls}))

;; --- end-to-end: form → IR → optimized IR → bytecode -----------------

;; Heads build.lg dispatches on natively. expand-all leaves these alone
;; so user-level macros (cond, when, and, or, ->) get expanded while
;; build-known shapes reach build-form as the special forms they are.
(def ^:private build-known-heads
  #{'let* 'if 'do 'quote 'loop* 'recur
    '+ '- '* '< '<= '> '>= '=})

(defn- expand-fully
  "Macroexpand to fixed point — let-go's `macroexpand` is one-level
   (Clojure's `macroexpand-1`); loop until the head stops changing."
  [form]
  (loop [f form]
    (let [e (macroexpand f)]
      (if (= e f) e (recur e)))))

;; Public: structurize_test.lg (and any out-of-ns IR driver) needs to expand
;; forms exactly as the pipeline does before build. Privacy was unenforced via
;; the bundle but rejected under the source-bootstrap loader, so this must be
;; `defn`, not `defn-`.
(defn expand-all [form]
  ;; seq? not list? — macros frequently return Cons cells (from `cons`)
  ;; which aren't list? but ARE seq?. Build-form will likewise need to
  ;; accept seq? not list? if we want to feed it Cons-shaped output.
  (cond
    (seq? form)
    (let [head (first form)]
      (if (contains? build-known-heads head)
        (apply list head (doall (map expand-all (rest form))))
        (let [expanded (expand-fully form)]
          (if (seq? expanded)
            (if (= 'quote (first expanded))
              expanded
              ;; Expand the head too: in an immediately-invoked fn expression
              ;; ((fn [x] ...) args), the head is itself a form that must be
              ;; expanded (fn -> fn*). Leaving it raw makes the IR builder
              ;; misread the IIFE as a call and fail to resolve the inner
              ;; fn's body symbols. For a symbol head, expand-all is identity.
              (apply list (expand-all (first expanded))
                     (doall (map expand-all (rest expanded)))))
            (expand-all expanded)))))
    (vector? form)
    (vec (doall (map expand-all form)))
    (map? form)
    (into {} (doall (map (fn [[k v]] [(expand-all k) (expand-all v)]) form)))
    :else form))

(def ^:dynamic *target* :bytecode)
;; When set to :go, compile-form* routes through ir.lower-go instead of ir.lower.
;; Set this before calling compile-form to generate Go-lowered output.

(defn- unwrap-name [raw-name]
  "Strip (with-meta sym {...}) wrapper from ^:private etc. metadata annotations.
   Returns the bare symbol."
  (if (and (seq? raw-name) (= 'with-meta (first raw-name)))
    (second raw-name)
    raw-name))

(defn- compile-form* [form]
  "Drives (defn NAME [args] body...) through expand → build → optimize → lower.
   Body forms are macroexpanded; defn and the args vector are passed through
   intact so build-fn's structural reader still works.
   When *target* is :bytecode: returns a lowered chunk for single-arity, or the
   raw *MultiArityFn value for multi-arity.
   When *target* is :go: returns a lowered result map {:status :lowered :decl ...}
   for single-arity, or a :multi-fn-template map for multi-arity."
  (cond
    ;; Capture defprotocol as a declaration form
    (= 'defprotocol (first form))
    {:decl-kind :defprotocol :name (nth form 1) :methods (vec (drop 2 form))}

    ;; Capture deftype as a declaration form
    (= 'deftype (first form))
    {:decl-kind :deftype :name (nth form 1) :fields (nth form 2) :impls (vec (drop 3 form))}

    ;; Capture defmulti as a declaration form. Mirror the defmulti macro's
    ;; argument parse (name docstring? attr-map? dispatch-fn & options) so the
    ;; dispatcher registry can later recognise a type-dispatch fn and the
    ;; default method's dispatch value.
    (= 'defmulti (first form))
    (let [margs       (drop 2 form)
          margs       (if (string? (first margs)) (next margs) margs)
          margs       (if (map? (first margs)) (next margs) margs)
          dispatch-fn (first margs)
          opts        (apply hash-map (or (next margs) '()))]
      {:decl-kind   :defmulti
       :name        (unwrap-name (nth form 1))
       :dispatch-fn dispatch-fn
       :default-val (get opts :default :default)})

    ;; Capture defmethod as a declaration form. The dispatch value selects the
    ;; switch arm; the fn-tail ([args] body...) is the method body lowered into
    ;; that arm.
    (= 'defmethod (first form))
    {:decl-kind    :defmethod
     :name         (unwrap-name (nth form 1))
     :dispatch-val (nth form 2)
     :fn-tail      (vec (drop 3 form))}

    ;; Otherwise, fall through to the existing defn logic
    :else
    (let [name-sym    (unwrap-name (nth form 1))
          maybe-doc   (nth form 2)
          has-doc?    (string? maybe-doc)
          first-form  (if has-doc? (nth form 3) maybe-doc)
          go-target?  (= *target* :go)]
      (if (vector? first-form)
        ;; Single arity
        (let [args-vec   first-form
              body-forms (map expand-all (drop (if has-doc? 4 3) form))
              expanded   (apply list 'defn name-sym args-vec body-forms)
              ir-fn      (-> expanded ir.build/build-fn optimize-fn)]
          (if go-target?
            (lower-go/lower ir-fn :bridge)
            (lower/lower ir-fn)))
        ;; Multi-arity: build each arity separately, combine
        (let [arities   (drop (if has-doc? 3 2) form)]
          (if go-target?
            (let [fn-templates (mapv (fn [arity-form]
                                       (let [args-vec   (first arity-form)
                                             body-forms (map expand-all (rest arity-form))
                                             expanded   (apply list 'defn name-sym args-vec body-forms)
                                             ir-fn      (-> expanded ir.build/build-fn optimize-fn)
                                             result     (lower-go/lower ir-fn :bridge)]
                                         (if (= :lowered (:status result))
                                           {:fn (:decl result)}
                                           result)))
                                     arities)]
              {:kind :multi-fn-template :fns fn-templates})
            (let [fn-vals   (mapv (fn [arity-form]
                                    (let [args-vec   (first arity-form)
                                          body-forms (map expand-all (rest arity-form))
                                          expanded   (apply list 'defn name-sym args-vec body-forms)
                                          chunk      (-> expanded
                                                         ir.build/build-fn
                                                         optimize-fn
                                                         lower/lower)]
                                      (chunk->fn (count args-vec) false chunk)))
                                  arities)]
              (make-multi-arity (apply list fn-vals)))))))))

(defn compile-form [form & caller-ns]
  (if (seq caller-ns)
    (binding [*ns* (first caller-ns)]
      (compile-form* form))
    (compile-form* form)))

  ;; --- Go bootstrap generation -------------------------------------------

(defn- go-name-for [name-sym]
  "Convert a Lisp fn name to a valid Go identifier.
   Hyphens become underscores, other special chars are replaced."
  (let [s (str name-sym)]
    ;; Replace hyphens with underscores
    (apply str (map (fn [c] (if (= c \-) \_ c)) s))))

(defn- defn-key
  "Returns [name-string arity-or-:multi] for a (defn ...) form. Used to
   dedupe consecutive same-name same-arity defns (Lisp's last-write-wins
   for var bindings; Go has no overloading, so emitting both would
   produce a function-redeclaration error). Returns nil if the form
   shape isn't recognised — those are left alone."
  [form]
  (when (and (seq? form) (>= (count form) 3))
    (let [raw-name (nth form 1)
          name-sym (unwrap-name raw-name)
          name-str (str name-sym)
          maybe-doc (nth form 2)
          has-doc?  (string? maybe-doc)
          args-or-arity (if has-doc?
                          (if (>= (count form) 4) (nth form 3) nil)
                          maybe-doc)]
      (cond
        (vector? args-or-arity) [name-str (count args-or-arity)]
        (list? args-or-arity)   [name-str :multi]
        :else                   nil))))

(defn- collect-call-targets
  "Walk form, return a set of symbol-name strings used in
   call-head position. A symbol in head position of a list-form is
   treated as a call target. We over-approximate: this includes locals,
   special forms, macros — toposort-by only uses these to find graph
   edges between known defn names, so spurious entries are harmless."
  [form]
  (let [acc (atom #{})]
    (letfn [(visit [x]
              (cond
                (seq? x)
                (let [head (first x)]
                  (when (symbol? head)
                    (swap! acc conj (str head)))
                  (doseq [el (rest x)] (visit el)))
                (vector? x)
                (doseq [el x] (visit el))
                (map? x)
                (doseq [entry x]
                  (visit (key entry))
                  (visit (val entry)))
                :else nil))]
      (visit form))
    @acc))

(defn- forms-by-arity
  "Group same-name forms by their [name arity] key, keeping only the
   LAST occurrence per key (Lisp redefinition semantics). Returns a
   map {[name arity] -> form}."
  [forms]
  (loop [remaining forms acc {}]
    (if (empty? remaining)
      acc
      (let [form (first remaining)
            k    (defn-key form)]
        (recur (rest remaining)
               (if k (assoc acc k form) acc))))))

(defn- order-defn-forms
  "Dedupe same-(name,arity) forms (last wins) and arrange in
   dependencies-first topological order using graph/toposort-by.
   Tiebreak among independently-ready nodes by lexical name asc, then
   arity asc — so same-name arities cluster together and the overall
   output is deterministic across runs. Returns a vector of forms.

   Non-defn forms (anything `defn-key` doesn't recognise) and forms
   that participate in a dependency cycle fall through to the end in
   source order."
  [forms]
  (let [keyed     (forms-by-arity forms)
        own-names (set (map first (keys keyed)))
        ;; Sort keys deterministically: lex name asc, then arity asc
        ;; (multi-arity placeholder :multi sorts after numbers).
        cmp       (fn [[na aa] [nb ab]]
                    (let [c (compare na nb)]
                      (if (zero? c)
                        (compare (str aa) (str ab))
                        c)))
        sorted-ks (vec (sort cmp (keys keyed)))
        sorted-forms (mapv keyed sorted-ks)
        deps-fn   (fn [form]
                    (let [self-name (first (defn-key form))]
                      ;; SORT the deps: collect-call-targets returns a hash-SET,
                      ;; so filtering it yields hash-ordered (run-varying) deps.
                      ;; toposort appends deps in iteration order (post-order),
                      ;; so unsorted deps flip the emitted function order across
                      ;; processes on acyclic namespaces. A stable dep order pairs
                      ;; with graph/toposort's sorted DFS roots for full determinism.
                      (vec (sort (filter (fn [n] (and (not= n self-name)
                                                      (own-names n)))
                                         (collect-call-targets form))))))
        topo (g/toposort-by (fn [form] (first (defn-key form)))
                            sorted-forms
                            deps-fn)
        ;; If the call graph has a cycle (mutual recursion), toposort
        ;; returns nil — Go is fine with mutual recursion within a
        ;; package, so fall back to the lex-sorted order.
        ordered (or topo sorted-forms)
        non-defn (vec (remove (fn [f] (some? (defn-key f))) forms))]
    (into ordered non-defn)))

  ;; --- gogen_ir override-registration emission (Part 1) ----------------
  ;; Each lowered package emits a package-local `__gogen_wrap` helper plus
  ;; an init() that calls rt.RegisterGoOverrides, clobbering the bytecode-
  ;; produced Vars with NativeFn adapters that call the lowered Go fns. The
  ;; resolver/eval drains these after each namespace loads. Untagged builds
  ;; never import these packages, so none of this runs.
  ;;
  ;; All AST is built with gogen primitives (not string concat) so
  ;; gogen/render owns formatting. Only single-arity, non-variadic lowered
  ;; fns are registered — the strict fixed-arity wrapper can't represent an
  ;; &-rest tail.

(defn- override-wrapper-fn-lit [entry]
  "Build the per-defn `func(args []vm.Value) (vm.Value, error)` adapter:
   arity-check, then call the generated typed fn, supplying `, nil` when
   the typed fn doesn't itself return an error."
  (let [arity        (:arity entry)
        go-name      (:go-name entry)
        fn-name      (:fn-name entry)
        needs-error? (:needs-error? entry)
        args-id      (gogen/ident "args")
        len-call     (gogen/call (gogen/ident "len") [args-id])
        msg          (str fn-name ": wrong number of arguments %d (expected " arity ")")
        arity-mismatch
        (gogen/return-stmt
          [(gogen/ident "nil")
           (gogen/call
             (gogen/field-sel (gogen/ident "fmt") "Errorf")
             [(gogen/string-lit msg) len-call])])
        len-check    (gogen/if-stmt
                       nil
                       (gogen/binary "!=" len-call (gogen/int-lit arity))
                       [arity-mismatch]
                       nil)
        arg-exprs    (mapv (fn [i] (gogen/index args-id (gogen/int-lit i)))
                           (range arity))
        ;; Pass the wrapper's ExecContext as the lowered fn's first arg, so
        ;; dynamic-var resolution inside the lowered body runs against the
        ;; caller's context (matching the bytecode path) rather than the root.
        inner-call   (gogen/call (gogen/ident go-name)
                                 (into [(gogen/ident "ec")] arg-exprs))
        ret-stmt     (if needs-error?
                       (gogen/return-stmt [inner-call])
                       (gogen/return-stmt [inner-call (gogen/ident "nil")]))]
    (gogen/func-lit
      [(gogen/param "ec" (gogen/type "*vm.ExecContext"))
       (gogen/param "args" (gogen/type "[]vm.Value"))]
      [(gogen/result (gogen/type "vm.Value"))
       (gogen/result (gogen/type "error"))]
      [len-check ret-stmt])))

(defn- override-helper-decl []
  "Build the package-local `__gogen_wrap` helper:
     func __gogen_wrap(fn func(ec *vm.ExecContext, args []vm.Value) (vm.Value, error)) vm.Value {
       return vm.NewCtxNativeFn(\"\", fn)
     }
   The override is a context-aware native: ec.Invoke hands it the caller's
   ExecContext, which the wrapper forwards into the lowered fn."
  (let [wrap-call (gogen/call
                    (gogen/field-sel (gogen/ident "vm") "NewCtxNativeFn")
                    [(gogen/string-lit "") (gogen/ident "fn")])
        ret       (gogen/return-stmt [wrap-call])]
    (gogen/func-decl
      "__gogen_wrap"
      [(gogen/param "fn" (gogen/type "func(ec *vm.ExecContext, args []vm.Value) (vm.Value, error)"))]
      [(gogen/result (gogen/type "vm.Value"))]
      [ret])))

(defn- override-init-decl [ns-name entries]
  "Build the package's init() that calls rt.RegisterGoOverrides with a
   map[string]vm.Value literal of __gogen_wrap-wrapped adapters."
  (let [kv-pairs (mapv (fn [e]
                         (gogen/kv-expr
                           (gogen/string-lit (:fn-name e))
                           (gogen/call (gogen/ident "__gogen_wrap")
                                       [(override-wrapper-fn-lit e)])))
                       entries)
        map-lit  (gogen/composite-lit-multi
                   (gogen/type "map[string]vm.Value")
                   kv-pairs)
        register-call (gogen/call
                        (gogen/field-sel (gogen/ident "rt") "RegisterGoOverrides")
                        [(gogen/string-lit ns-name) map-lit])]
    (gogen/func-decl
      "init" [] []
      [(gogen/expr-stmt register-call)])))

(defn- override-entries [valid-results]
  "Lowered results eligible for override registration: single-arity fns
   (carry :fn-name) whose Go signature is uniformly vm.Value, so the
   fixed-arity wrapper adapts them without boxing/unboxing. Typed and
   variadic fns are flagged :override-eligible? false and stay on bytecode."
  (filterv (fn [r] (and (:fn-name r) (:override-eligible? r)))
           valid-results))

  ;; Extra decls reference rt + vm + fmt; attach the imports explicitly so a
  ;; package whose lowered fns happen to need none still compiles.
(def ^:private override-decl-imports
  [{:path "github.com/nooga/let-go/pkg/rt" :alias "rt"}
   {:path "github.com/nooga/let-go/pkg/vm" :alias "vm"}
   {:path "fmt" :alias nil}])

(defn- lower-defn-forms
  "Lower each defn form via the Go pipeline; return the vector of result maps.
   Independent of *lowered-registry* — the caller binds it for pass 2."
  [defn-forms]
  (loop [remaining defn-forms out []]
    (if (empty? remaining)
      out
      (let [form (first remaining)
            result (try
                     (binding [*target* :go]
                       (compile-form* form))
                     (catch e
                       (println (str "WARNING: lowering failed for "
                                     (pr-str (try (second form) (catch _ form)))
                                     ": " e))
                       nil))]
        (cond
          (nil? result)
          (recur (rest remaining) out)
          (= :lowered (:status result))
          (recur (rest remaining) (conj out result))
          (= :multi-fn-template (:kind result))
          ;; Flatten multi-arity templates into individual decls.
          (let [flat (reduce (fn [acc entry]
                               (if-let [d (:fn entry)]
                                 (conj acc {:status :lowered :decl d :imports []})
                                 acc))
                             []
                             (:fns result))]
            (recur (rest remaining) (into out flat)))
          :else
          (do
            ;; A non-:lowered single result (e.g. {:status :fallback :reason …})
            ;; carries no decl — warn rather than silently drop it, so a form
            ;; that failed to lower stays visible instead of vanishing from the
            ;; generated package with no trace.
            (println (str "WARNING: not lowered ("
                          (pr-str (or (:status result) (:kind result)))
                          ") for "
                          (pr-str (try (second form) (catch _ form)))
                          (if (:reason result) (str ": " (:reason result)) "")))
            (recur (rest remaining) out)))))))

(defn lower-ns-to-go [pkg-name ns-name forms]
  "Process a namespace's forms through the Go-lowering pipeline and return
   rendered Go source for a package. pkg-name is the Go package name string,
   ns-name is the namespace symbol (for *ns* binding), and forms is a vector of
   raw top-level forms: (defn ...) plus optional (defprotocol ...) / (deftype
   ...) declaration forms. Declaration forms are emitted as a native Go
   interface / struct+constructor / receiver methods, and the deftype
   constructor + protocol-method registries are bound so the namespace's own
   functions devirtualize constructor calls and protocol dispatch."
  ;; Determinism: the Go-lowering path encodes inferred types into the
  ;; rendered source, so typeinfer MUST run to fixpoint here — a wall-clock
  ;; budget would yield a partial, time-dependent result (non-deterministic
  ;; tree, and :bottom-heavy partials that drop forms → undefined: builds).
  ;; The monotone lattice has finite height, so unbounded execution always
  ;; terminates; it's just slower than the interactive/bytecode default.
  (let [decl-form?  (fn [form]
                      (and (seq? form)
                           (contains? #{'defprotocol 'deftype} (first form))))
        decl-forms  (filterv decl-form? forms)
        defn-forms0 (filterv (fn [form] (not (decl-form? form))) forms)
        ;; Capture each declaration form ({:decl-kind … :name … …}).
        captures    (mapv (fn [form] (binding [*target* :go] (compile-form* form))) decl-forms)
        protocols   (filterv (fn [c] (= :defprotocol (:decl-kind c))) captures)
        deftypes    (filterv (fn [c] (= :deftype (:decl-kind c))) captures)
        ;; Registries built from THIS namespace's captures, bound below so the
        ;; namespace's own defns type ctor results as [:dtype T] (typeinfer),
        ;; lower (->T …) to the native _T(…) constructor, and devirtualize
        ;; protocol-method calls on a known-concrete receiver to recv.M().
        protocol-method-set (into #{} (mapcat (fn [p] (map (fn [m] (str (first m))) (:methods p))) protocols))
        ctor-types  (into {} (map (fn [dt] [(str "->" (:name dt)) (:name dt)]) deftypes))
        ctors       (into {} (map (fn [dt] [(str "->" (:name dt)) (lower-go/go-export-name (:name dt))]) deftypes))
        vm-import   {:path "github.com/nooga/let-go/pkg/vm" :alias "vm"}
        rt-import   {:path "github.com/nooga/let-go/pkg/rt" :alias "rt"}
        _cache-rst  (reset! *deftype-method-ir-cache* {})]
    (binding [*ns* (the-ns ns-name)
              ir.passes.typeinfer/*typeinfer-budget-ms* nil
              ir.passes.typeinfer/*deftype-ctor-types* (when (seq ctor-types) ctor-types)
              lower-go/*deftype-ctors* (when (seq ctors) ctors)
              lower-go/*protocol-methods* (when (seq protocol-method-set) protocol-method-set)
              lower-go/*protocol-method-sigs* (let [s (protocol-method-sigs deftypes)]
                                                (when (seq s) s))]
      (let [;; Native decls for captured protocols (interface) and deftypes
            ;; (struct + constructor + receiver methods). The interface/struct
            ;; reference vm.* (vm import); receiver method bodies also call rt.*
            ;; arithmetic/dispatch helpers (rt import).
            protocol-decls (mapv (fn [p]
                                   {:decl (:decl (lower-go/lower-defprotocol p))
                                    :imports [vm-import]})
                                 protocols)
            deftype-decls  (vec (mapcat
                                  (fn [dt]
                                    (let [s (lower-go/lower-deftype-struct dt)
                                          m (lower-deftype-methods dt)]
                                      (into (mapv (fn [d] {:decl d :imports [vm-import]}) (:decls s))
                                            (mapv (fn [d] {:decl d :imports [vm-import rt-import]}) (:decls m)))))
                                  deftypes))
            type-decls (into protocol-decls deftype-decls)
            defn-forms (order-defn-forms defn-forms0)
            ;; Pass 1 discovers lowered single-arity vm.Value-uniform siblings
            ;; (:override-eligible?) — the intra-ns calls slice 1 can lift.
            pass1 (lower-defn-forms defn-forms)
            sibling-registry (reduce (fn [m r]
                                       (merge m (lower-go/registry-entry-from-result r ns-name pkg-name)))
                                     {} pass1)
            ;; Native modules (e.g. clojure.core/seq -> corefns.Seq) registered
            ;; via (rt/native-modules) seed the registry too, so cross-ns calls
            ;; into native Go fns lower to direct pkg.Fn(...) calls instead of
            ;; rt.CachedVarFn trampolines. Native entries are STABLE across the
            ;; pass-2 fixpoint (they name external Go fns that always exist), so
            ;; they are merged in fresh each iteration rather than subjected to
            ;; the sibling-shrinking select-keys below — which would otherwise
            ;; strip them (a native never emits a local :decl) and silently
            ;; revert native calls to trampolines in the converged result. A
            ;; lowered sibling that redefines a core fn shadows the native.
            native-reg (lower-go/native-registry (rt/native-modules))
            ;; Accumulates the Go import paths of native modules actually
            ;; direct-called in this ns (filled by lookup-direct-callable), so
            ;; the emitted file imports e.g. corefns for `corefns.Seq(...)`.
            native-imports (atom #{})
            ;; Pass 2 re-lowers with the registry visible so intra-ns and
            ;; cross-ns native calls lower to direct Go calls. The cross-ns atom
            ;; records trampoline-reaching load-var callees for memoized
            ;; cached-*vm.Var resolution.
            ;;
            ;; Dangling-call hazard: a fn registered from pass 1 can take a
            ;; different (registry-visible) path in pass 2 and BAIL (no :decl),
            ;; yet its callers still emit a *direct* Go call to it — a reference
            ;; to an undefined function. Whether this happens is nondeterministic
            ;; (depends on per-pass typeinfer/gensym state), which is why a fresh
            ;; `make check-generated` intermittently fails to compile the lowered
            ;; tree. Fix: iterate to a fixpoint where the registry holds ONLY fns
            ;; that actually emit a decl in that pass. reg' = reg ∩ emitted ⊆ reg,
            ;; so the registry is monotonically shrinking and this terminates;
            ;; worst case it empties and every intra-ns call falls back to the
            ;; always-compilable trampoline. A fresh cross-ns atom is used per
            ;; pass; the converged pass's atom is the one we keep.
            emitted-registry (fn [res]
                               (reduce (fn [m r]
                                         (if (some? (:decl r))
                                           (merge m (lower-go/registry-entry-from-result r ns-name pkg-name))
                                           m))
                                       {} res))
            pass2 (let [cap (+ 2 (count sibling-registry))]
                    ;; sib-reg shrinks to a fixpoint (dangling-call hazard);
                    ;; native-reg is always merged on top and never shrinks.
                    (loop [sib-reg sibling-registry guard 0]
                      (let [cross (atom {})
                            reg (merge native-reg sib-reg)
                            res (binding [lower-go/*lowered-registry* reg
                                          lower-go/*native-imports-used* native-imports
                                          lower-go/*cross-ns-vars-used* cross]
                                  (lower-defn-forms defn-forms))
                            sib-reg' (select-keys sib-reg (keys (emitted-registry res)))]
                        (if (or (= sib-reg' sib-reg) (>= guard cap))
                          {:results res :cross cross}
                          (recur sib-reg' (inc guard))))))
            cross-ns-vars (:cross pass2)
            results (:results pass2)
            ;; Filter out results with nil decls (failures that slipped through).
            valid-results (filterv (fn [r] (some? (:decl r))) results)
            ;; gogen_ir: append a __gogen_wrap helper + init() that
            ;; registers Go-native overrides for the eligible lowered fns.
            reg-entries (override-entries valid-results)
            extra-decls (if (seq reg-entries)
                          [{:decl (override-helper-decl)
                            :imports override-decl-imports}
                           {:decl (override-init-decl (str ns-name) reg-entries)
                            :imports override-decl-imports}]
                          [])
            ;; Package-level cached *vm.Var decls + lazy accessors for the
            ;; recorded cross-ns callees (deterministic, sorted by base name).
            cached-var-decls (lower-go/cross-ns-var-decls @cross-ns-vars)
            ;; Native type/struct/method decls lead the file; Go resolves
            ;; package-scope references regardless of declaration order.
            all-results (into (into (into type-decls valid-results) extra-decls) cached-var-decls)
            ;; Carry the accumulated native-module imports (corefns, …) into the
            ;; file's import block via a decl-less import-only result.
            native-import-results (if (seq @native-imports)
                                    [{:decl nil
                                      :imports (mapv (fn [p] {:path p}) (sort @native-imports))}]
                                    [])
            all-results (into all-results native-import-results)
            file-ast (lower-go/file pkg-name all-results)]
        (gogen/render file-ast)))))
