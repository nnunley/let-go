;; The Lisp optimization-pass pipeline driver.
;;
;; `(optimize-fn f)` runs the enabled Lisp passes in a sensible order:
;;   1. constfold   — fold Const arithmetic, identities, canonicalize
;;   2. cse         — same-block common-subexpression elimination
;;   3. constfold   — again; CSE may expose new fold opportunities
;;   4. licm        — hoist loop-invariant Insts to pre-headers
;;   5. constfold   — again; LICM may rearrange uses such that more
;;                    folds become possible
;;   6. dce         — drop pure Insts with zero uses (cleanup)
;;
;; Build (Phase 3) now emits BlockArg params proactively for all cross-block
;; captures, eliminating the need for post-pass threading.
;;
;; CSE remains intentionally narrow: same-block pure ops plus stable
;; LoadVar values only. Dominance/GVN-style cross-block CSE is deferred.
;;
;; Returns f (same object — passes mutate in place).

(ns ir.passes.pipeline
  (:require
   [graph :as g]
   [ir.build]
   [ir.lattice :as lat]
   [ir.lower :as lower]
   [ir.lower-go :as lower-go]
   [ir.passes.constfold :refer [constfold]]
   [ir.passes.cse :refer [cse]]
   [ir.passes.dce :refer [dce]]
   [ir.passes.infer-arg-types :refer [infer-arg-types]]
   [ir.passes.licm :refer [licm]]
   [ir.passes.typeinfer :refer [typeinfer]]
   [ir.validate :refer [validate-fn!]]))

(defn- run-typeinfra-epoch [f]
  (let [state0 (lat/seed-state-from-inst-types! (lat/new-typeinfra-state f) f)
        state1 (infer-arg-types f state0)
        state2 (typeinfer f state1)]
    (lat/flush-state-types! state2 f)
    f))

(defn optimize-fn [f]
  (validate-fn! f "build")
  (run-typeinfra-epoch f) (validate-fn! f "infer-arg-types")
  (constfold f)        (validate-fn! f "constfold-1")
  (cse f)              (validate-fn! f "cse")
  (constfold f)        (validate-fn! f "constfold-2")
  (licm f)             (validate-fn! f "licm")
  (constfold f)        (validate-fn! f "constfold-3")
  (dce f)              (validate-fn! f "dce")
  (run-typeinfra-epoch f)
  f)

(declare expand-all)

(declare dt-rewrite-field dt-rewrite-let dt-rewrite-fn)

;; Binding forms with a clean `[target init ...]` vector (no for/doseq-style
;; :let/:when modifiers). Their inits are rewritten in the outer scope; their
;; targets shadow field names inside the body. Mirrors core.lg's -dt-let-like.
;; NB: a *quoted* set literal '#{..} reads as a (hash-set ..) form in let-go,
;; so build the set explicitly with (set '(...)).
(def -dt-field-let-like
  (set '(let let* loop loop* when-let when-let* if-let if-let*
          when-some if-some binding with-open with-local-vars dotimes)))

;; Symbols a binding target introduces (conservative over destructuring: every
;; symbol in the pattern except &).
(defn- dt-collect-syms [form]
  (cond
    (and (symbol? form) (not= form '&)) (list form)
    (vector? form) (apply concat (map dt-collect-syms form))
    (map? form) (apply concat (map (fn [e] (dt-collect-syms (vec e))) (seq form)))
    :else nil))

(defn- dt-rewrite-field
  "Rewrite bare field symbols in a deftype method body into (. this field)
   member-access forms (lowered natively by build-dot/:dot), honoring lexical
   shadowing: a field symbol rebound by the method params or an inner let/loop/
   fn binding is left untouched. `bound` is the set of locally-bound symbols in
   scope. Mirrors core.lg's -dt-rewrite (the bytecode path), minus mutable-field
   / set! handling — the native deftype path is immutable. Known limitation
   (shared with core.lg): for/doseq/letfn are not treated as binding forms."
  [fieldset this-sym bound form]
  (cond
    (symbol? form)
    (if (and (contains? fieldset form) (not (contains? bound form)))
      (list '. this-sym form)
      form)
    (vector? form)
    (vec (map (fn [x] (dt-rewrite-field fieldset this-sym bound x)) form))
    (not (seq? form)) form
    (empty? form) form
    :else
    (let [h (first form)]
      (cond
        (= h 'quote) form
        (and (contains? -dt-field-let-like h) (vector? (second form)))
        (dt-rewrite-let fieldset this-sym bound form)
        (or (= h 'fn) (= h 'fn*))
        (dt-rewrite-fn fieldset this-sym bound form)
        :else
        (apply list (map (fn [x] (dt-rewrite-field fieldset this-sym bound x)) form))))))

(defn- dt-rewrite-let [fieldset this-sym bound form]
  (let [h    (first form)
        bvec (second form)
        body (next (next form))]
    (loop [v (seq bvec) b bound out []]
      (if (or (nil? v) (nil? (next v)))
        (apply list h (vec out)
               (map (fn [x] (dt-rewrite-field fieldset this-sym b x)) body))
        (let [target   (first v)
              init     (second v)
              new-init (dt-rewrite-field fieldset this-sym b init)
              b2       (reduce conj b (dt-collect-syms target))]
          (recur (next (next v)) b2 (conj (conj out target) new-init)))))))

(defn- dt-rewrite-fn [fieldset this-sym bound form]
  (let [h     (first form)
        tail  (next form)
        named (if (and tail (symbol? (first tail))) (first tail) nil)
        rest1 (if named (next tail) tail)
        b1    (if named (conj bound named) bound)
        rw    (fn [params body]
                (let [b2 (reduce conj b1 (dt-collect-syms params))]
                  (apply list params
                         (map (fn [x] (dt-rewrite-field fieldset this-sym b2 x)) body))))]
    (if (and rest1 (vector? (first rest1)))
      (apply list h (concat (if named (list named) (list)) (rw (first rest1) (next rest1))))
      (apply list h (concat (if named (list named) (list))
                            (map (fn [c] (rw (first c) (next c))) rest1))))))

(def ^:private *deftype-method-ir-cache*
  ;; Per-compile cache [tname mname arity] -> built+optimized IR fn, so a deftype
  ;; method isn't run through the full optimize-fn pipeline twice (once for
  ;; protocol-method-sigs/:needs-error?, once for lowering). Reset at the start of
  ;; the orchestration let below.
  (atom {}))

(defn- build-method-ir-fn
  "Build + optimize the IR fn for one deftype protocol-method impl form
   (mname [this & args] body...): bare field refs become (. this field), the body
   is built+optimized, and the receiver arg is seeded as [:dtype tname]. Cached
   per compile so :needs-error? analysis and lowering share a single build."
  [tname fieldset mform]
  (let [ckey [tname (first mform) (count (second mform))]]
    (or (get @*deftype-method-ir-cache* ckey)
        (let [params    (second mform)
              this-sym  (first params)
              body      (drop 2 mform)
              ;; Method params (receiver + args) shadow field names: seed the
              ;; bound set with all of them so a param like `side` on a type with
              ;; a `side` field stays the param, not (. this side).
              bound0    (set (dt-collect-syms params))
              rewritten (map (fn [b] (dt-rewrite-field fieldset this-sym bound0 b)) body)
              defn-form (apply list 'defn (first mform) params (map expand-all rewritten))
              ir-fn     (-> defn-form ir.build/build-fn optimize-fn)]
          (swap! ir-fn assoc :arg-types [[:dtype tname]])
          (swap! *deftype-method-ir-cache* assoc ckey ir-fn)
          ir-fn))))

(defn- protocol-method-sigs
  "Join across all impls of every protocol method to a unified signature map
   keyed by exported Go method name: {go-name {:needs-error? bool}}.
   MVP: only :needs-error? is joined (OR). An impl is total when its built IR fn
   needs no error (no try / only error-free calls), evaluated with
   *force-needs-error* unbound so the body's real shape shows through."
  [deftypes]
  (reduce
    (fn [acc dt]
      (let [tname    (:name dt)
            fieldset (set (:fields dt))]
        (reduce
          (fn [m mform]
            (let [ir-fn (build-method-ir-fn tname fieldset mform)
                  ne?   (binding [lower-go/*force-needs-error* nil]
                          (lower-go/function-needs-error? ir-fn))
                  gname (lower-go/go-export-name (first mform))
                  prev  (get m gname)]
              (assoc m gname {:needs-error? (or (:needs-error? prev) ne?)})))
          acc
          (filter (fn [x] (and (seq? x) (symbol? (first x)) (vector? (second x))))
                  (:impls dt)))))
    {}
    deftypes))

(defn lower-deftype-methods
  "Lower the protocol-method impls of a :deftype capture to native Go receiver
   methods. For each (mname [this & args] body...): bare field refs become
   (. this field), the body is built+optimized as an IR fn whose receiver arg
   is seeded as [:dtype T], then lowered (ir.lower-go/lower-method) to a method
   on *T. Returns {:status :lowered :decls [<method-decl> ...]}."
  [decl]
  (let [tname       (:name decl)
        struct-name (lower-go/go-export-name tname)
        recv-type   (str "*" struct-name)
        fieldset    (set (:fields decl))
        methods     (filter (fn [x] (and (seq? x) (symbol? (first x)) (vector? (second x))))
                            (:impls decl))
        decls       (mapv
                      (fn [m]
                        (let [ir-fn  (build-method-ir-fn tname fieldset m)
                              result (lower-go/lower-method ir-fn recv-type
                                       (lower-go/go-export-name (first m)))]
                          (:decl result)))
                      methods)]
    {:status :lowered :decls decls}))

;; --- end-to-end: form → IR → optimized IR → bytecode -----------------

;; Heads build.lg dispatches on natively. expand-all leaves these alone
;; so user-level macros (cond, when, and, or, ->) get expanded while
;; build-known shapes reach build-form as the special forms they are.
(def ^:private build-known-heads
  #{'let* 'if 'do 'quote 'loop* 'recur
    '+ '- '* '< '<= '> '>= '=})

(defn- expand-fully
  "Macroexpand to fixed point — let-go's `macroexpand` is one-level
   (Clojure's `macroexpand-1`); loop until the head stops changing."
  [form]
  (loop [f form]
    (let [e (macroexpand f)]
      (if (= e f) e (recur e)))))

;; Public: structurize_test.lg (and any out-of-ns IR driver) needs to expand
;; forms exactly as the pipeline does before build. Privacy was unenforced via
;; the bundle but rejected under the source-bootstrap loader, so this must be
;; `defn`, not `defn-`.
(defn expand-all [form]
  ;; seq? not list? — macros frequently return Cons cells (from `cons`)
  ;; which aren't list? but ARE seq?. Build-form will likewise need to
  ;; accept seq? not list? if we want to feed it Cons-shaped output.
  (cond
    ;; The empty list () is a self-evaluating literal, NOT a call. Without this
    ;; guard the (seq? form) branch reconstructs it as (apply list (expand-all
    ;; (first ())) (map expand-all (rest ()))) = (apply list nil) = (nil) — a
    ;; one-element (nil) list the IR builder then lowers as a call to a nil head
    ;; (rt.InvokeValueEC(ec, vm.NIL, …)). Surfaced once clojure.core was
    ;; Go-lowered: (defn reverse [coll] (reduce conj () coll)).
    (and (seq? form) (empty? form))
    form

    (seq? form)
    (let [head (first form)]
      (if (contains? build-known-heads head)
        (apply list head (doall (map expand-all (rest form))))
        (let [expanded (expand-fully form)]
          (if (seq? expanded)
            (if (= 'quote (first expanded))
              expanded
              ;; Expand the head too: in an immediately-invoked fn expression
              ;; ((fn [x] ...) args), the head is itself a form that must be
              ;; expanded (fn -> fn*). Leaving it raw makes the IR builder
              ;; misread the IIFE as a call and fail to resolve the inner
              ;; fn's body symbols. For a symbol head, expand-all is identity.
              (apply list (expand-all (first expanded))
                     (doall (map expand-all (rest expanded)))))
            (expand-all expanded)))))
    (vector? form)
    (vec (doall (map expand-all form)))
    (map? form)
    (into {} (doall (map (fn [[k v]] [(expand-all k) (expand-all v)]) form)))
    :else form))

;; --- canonical enumeration of a namespace's lowerable fn-units -------------
;; A `defn` is itself a macro: it expands to `(def NAME (fn ...))`. So the set
;; of functions a namespace contributes to lowering is NOT "the literal `defn`
;; forms" — it is every `(def NAME (fn ...))` that macroexpansion reveals,
;; including macro-generated ones (e.g. `deftest` -> `(do (def t (fn [] ...))
;; (register-test! ...))`). This is the single source of truth for "what
;; lowering operates on", shared by the stress harness today and (eventually)
;; production form-selection — so coverage measurement never drifts from what
;; the pipeline actually lowers. Requires the file's macros to be loaded first.

(defn- unwrap-name [raw-name]
  "Strip (with-meta sym {...}) wrapper from ^:private etc. metadata annotations.
   Returns the bare symbol (or raw-name unchanged)."
  (if (and (seq? raw-name) (= 'with-meta (first raw-name)))
    (second raw-name)
    raw-name))

(defn- private-name?
  "True when a defn NAME position carries `^:private` — i.e. it reads as the
   literal form `(with-meta sym {:private true …})`. (`defn-` is detected
   separately via the form head, since it doesn't wrap the name.) Used to carry
   :private? onto the ir-fn so emission picks an unexported go-name."
  [raw-name]
  (and (seq? raw-name) (= 'with-meta (first raw-name))
       (>= (count raw-name) 3)
       (let [m (nth raw-name 2)]
         (boolean (and (map? m) (get m :private))))))

(defn- try-expand-all
  "expand-all, but returns nil instead of throwing — a form that won't expand
   simply contributes no units."
  [form]
  (try (expand-all form) (catch e nil)))

(defn- def-target-name
  "Name a `(def NAME ...)` form defines (NAME possibly meta-wrapped), else nil."
  [form]
  (when (and (seq? form) (= (first form) 'def) (>= (count form) 2))
    (unwrap-name (nth form 1))))

(defn def-fn-form->defn
  "If form is `(def NAME (fn ...))` / `(def NAME (fn* ...))`, return the
   equivalent `(defn NAME <fn-tail>)`; else nil. `expand-all` rewrites `fn` ->
   `fn*`, so both heads must match. The fn-tail is a single `[args] body...` or
   multi-arity `([args] ...)` lists — both valid defn shapes (compile-form
   re-expands them on the way to build)."
  [form]
  (when (and (seq? form) (= (first form) 'def) (>= (count form) 3))
    (let [nm  (def-target-name form)
          val (nth form 2)]
      (when (and (symbol? nm) (seq? val)
                 (or (= (first val) 'fn) (= (first val) 'fn*)))
        (let [tail (rest val)
              ;; drop an optional self-name symbol after `fn`/`fn*`
              tail (if (symbol? (first tail)) (rest tail) tail)]
          (apply list 'defn nm tail))))))

(defn- set-macro-target
  "If form is `(set-macro! (var NAME))`, return NAME; else nil. Used to exclude
   `defmacro`s — a `defmacro` expands to `(do (defn name ...) (set-macro! (var
   name)))`, and macros are compile-time only (mirrors lgbgen's isDefnOnly
   excluding `defmacro`). Form-level detection is required: expansion happens
   before var resolution, so the runtime macro flag isn't available here."
  [form]
  (when (and (seq? form) (= (first form) 'set-macro!) (>= (count form) 2)
             (seq? (nth form 1)) (= (first (nth form 1)) 'var))
    (second (nth form 1))))

(defn collect-lowerable-fns
  "Walk a (macroexpanded) form, descending `do` wrappers, collecting every
   `(def NAME (fn ...))` as a normalized defn form, appended to acc. Names that
   a `(set-macro! (var NAME))` sibling marks as macros are excluded."
  [form acc]
  (cond
    (nil? form) acc
    (and (seq? form) (= (first form) 'do))
    (let [macros (set (keep set-macro-target (rest form)))]
      (reduce (fn [a g]
                (if (and (seq? g) (= (first g) 'do))
                  (collect-lowerable-fns g a)
                  (let [d (def-fn-form->defn g)]
                    (if (and d (not (contains? macros (nth d 1))))
                      (conj a d)
                      a))))
              acc (rest form)))
    :else
    (let [d (def-fn-form->defn form)]
      (if d (conj acc d) acc))))

(defn- walk-marked-names
  "Collect every name marked by a `(HEAD ...)` form ANYWHERE in form, via
   `extract`. Recurses into matched forms too — a `def` is namespace-level even
   when nested (e.g. `(def v 0)` inside a test-fn body still interns `v`).
   Quoted forms are data, not code, and are skipped."
  [head extract form acc]
  (cond
    (and (seq? form) (= (first form) 'quote)) acc
    (and (seq? form) (= (first form) head))
    (let [n   (extract form)
          acc (if n (conj acc n) acc)]
      (reduce (fn [a g] (walk-marked-names head extract g a)) acc (rest form)))
    (seq? form)    (reduce (fn [a g] (walk-marked-names head extract g a)) acc form)
    (vector? form) (reduce (fn [a g] (walk-marked-names head extract g a)) acc form)
    :else acc))

(defn analyze-ns-forms
  "Expand each top-level form ONCE and return
   `{:fixtures <lowerable defn-forms> :defined-names <symbols>}` — the single
   source of truth for what lowering operates on, shared by the stress harness
   today and (eventually) production form-selection so coverage never drifts
   from what the pipeline actually lowers. :fixtures are the harvested
   `(def NAME (fn ...))` units (incl. macro-generated like `deftest` bodies,
   excl. `defmacro`); :defined-names is every def'd name anywhere (excl. macros),
   for faithful sibling/forward pre-declaration. File macros MUST be loaded first
   so expansion resolves them; a form that won't expand contributes nothing."
  [forms]
  (reduce
    (fn [acc f]
      (let [ex (try-expand-all f)]
        (if (nil? ex)
          acc
          (let [macros (set (walk-marked-names 'set-macro! set-macro-target ex []))]
            {:fixtures (into (:fixtures acc) (collect-lowerable-fns ex []))
             :defined-names (into (:defined-names acc)
                                  (remove (fn [n] (contains? macros n))
                                          (walk-marked-names 'def def-target-name ex [])))}))))
    {:fixtures [] :defined-names []}
    forms))

(defn lowerable-fn-forms
  "Lowerable fn-units of a namespace's forms (see analyze-ns-forms). Convenience
   accessor — prefer analyze-ns-forms when you also need :defined-names, to avoid
   re-expanding the forms."
  [forms]
  (:fixtures (analyze-ns-forms forms)))

(defn defined-names
  "Every name a namespace's forms define, excluding macros (see analyze-ns-forms).
   Convenience accessor — prefer analyze-ns-forms when you also need :fixtures."
  [forms]
  (:defined-names (analyze-ns-forms forms)))

(def ^:dynamic *target* :bytecode)
;; When set to :go, compile-form* routes through ir.lower-go instead of ir.lower.
;; Set this before calling compile-form to generate Go-lowered output.

(defn- compile-form* [form]
  "Drives (defn NAME [args] body...) through expand → build → optimize → lower.
   Body forms are macroexpanded; defn and the args vector are passed through
   intact so build-fn's structural reader still works.
   When *target* is :bytecode: returns a lowered chunk for single-arity, or the
   raw *MultiArityFn value for multi-arity.
   When *target* is :go: returns a lowered result map {:status :lowered :decl ...}
   for single-arity, or a :multi-fn-template map for multi-arity."
  (cond
    ;; Capture defprotocol as a declaration form
    (= 'defprotocol (first form))
    {:decl-kind :defprotocol :name (nth form 1) :methods (vec (drop 2 form))}

    ;; Capture deftype as a declaration form
    (= 'deftype (first form))
    {:decl-kind :deftype :name (nth form 1) :fields (nth form 2) :impls (vec (drop 3 form))}

    ;; Capture defmulti as a declaration form. Mirror the defmulti macro's
    ;; argument parse (name docstring? attr-map? dispatch-fn & options) so the
    ;; dispatcher registry can later recognise a type-dispatch fn and the
    ;; default method's dispatch value.
    (= 'defmulti (first form))
    (let [margs       (drop 2 form)
          margs       (if (string? (first margs)) (next margs) margs)
          margs       (if (map? (first margs)) (next margs) margs)
          dispatch-fn (first margs)
          opts        (apply hash-map (or (next margs) '()))]
      {:decl-kind   :defmulti
       :name        (unwrap-name (nth form 1))
       :dispatch-fn dispatch-fn
       :default-val (get opts :default :default)})

    ;; Capture defmethod as a declaration form. The dispatch value selects the
    ;; switch arm; the fn-tail ([args] body...) is the method body lowered into
    ;; that arm.
    (= 'defmethod (first form))
    {:decl-kind    :defmethod
     :name         (unwrap-name (nth form 1))
     :dispatch-val (nth form 2)
     :fn-tail      (vec (drop 3 form))}

    ;; Otherwise, fall through to the existing defn logic
    :else
    (let [name-sym    (unwrap-name (nth form 1))
          ;; Public/private drives the emitted Go name (public → exported
          ;; PascalCase, private → unexported lowercase). Carried ON THE FORM
          ;; (:private?), like :multi-arity?, so the native self-hosted lowering
          ;; path needs no dynamic var. Private = `defn-` head OR `^:private` on
          ;; the name (raw forms reach here un-normalized, so both survive).
          private?    (or (= (first form) 'defn-)
                          (private-name? (nth form 1)))
          maybe-doc   (nth form 2)
          has-doc?    (string? maybe-doc)
          first-form  (if has-doc? (nth form 3) maybe-doc)
          go-target?  (= *target* :go)]
      (if (vector? first-form)
        ;; Single arity
        (let [args-vec   first-form
              body-forms (map expand-all (drop (if has-doc? 4 3) form))
              expanded   (apply list 'defn name-sym args-vec body-forms)
              ir-fn      (-> expanded ir.build/build-fn optimize-fn)
              _          (swap! ir-fn assoc :private? private?)]
          (if go-target?
            (lower-go/lower ir-fn :bridge)
            (lower/lower ir-fn)))
        ;; Multi-arity: build each arity separately, combine
        (let [arities   (drop (if has-doc? 3 2) form)]
          (if go-target?
            (let [fn-templates (mapv (fn [arity-form]
                                       (let [args-vec   (first arity-form)
                                             body-forms (map expand-all (rest arity-form))
                                             expanded   (apply list 'defn name-sym args-vec body-forms)
                                             ir-fn      (-> expanded ir.build/build-fn optimize-fn)
                                             ;; Mark the form as a multi-arity member (arity is
                                             ;; already carried on the form as :arity). Lowering
                                             ;; suffixes its Go name `<name>_<arity>` so the arities
                                             ;; don't redeclare `func <name>` and each is
                                             ;; independently direct-callable. Carried ON THE FORM
                                             ;; (not a dynamic var) so it survives native lowering.
                                             _          (swap! ir-fn assoc :multi-arity? true
                                                          :private? private?)
                                             result     (lower-go/lower ir-fn :bridge)]
                                         (if (= :lowered (:status result))
                                           ;; Keep :fn (the decl) for existing consumers
                                           ;; (lower-defn-forms flatten, lower-template-closure-expr)
                                           ;; AND carry the FULL per-arity result — its typed
                                           ;; :param-specs/:result-spec/:needs-error?, :arity,
                                           ;; :direct-callable? and :override-eligible?. Brick 4
                                           ;; (open the multi-arity gate) needs these to emit
                                           ;; per-arity fixed helpers + per-arity direct-callable
                                           ;; registry entries + the MakeNativeMultiArity dynamic
                                           ;; dispatcher. Additive: today's readers still use :fn.
                                           {:fn (:decl result) :result result}
                                           result)))
                                     arities)]
              {:kind :multi-fn-template :fns fn-templates})
            (let [fn-vals   (mapv (fn [arity-form]
                                    (let [args-vec   (first arity-form)
                                          body-forms (map expand-all (rest arity-form))
                                          expanded   (apply list 'defn name-sym args-vec body-forms)
                                          chunk      (-> expanded
                                                         ir.build/build-fn
                                                         optimize-fn
                                                         lower/lower)]
                                      (chunk->fn (count args-vec) false chunk)))
                                  arities)]
              (make-multi-arity (apply list fn-vals)))))))))

(defn compile-form [form & caller-ns]
  (if (seq caller-ns)
    (binding [*ns* (first caller-ns)]
      (compile-form* form))
    (compile-form* form)))

  ;; --- Go bootstrap generation -------------------------------------------

(defn- go-name-for [name-sym]
  "Convert a Lisp fn name to a valid Go identifier.
   Hyphens become underscores, other special chars are replaced."
  (let [s (str name-sym)]
    ;; Replace hyphens with underscores
    (apply str (map (fn [c] (if (= c \-) \_ c)) s))))

(defn- defn-key
  "Returns [name-string arity-or-:multi] for a (defn ...) form. Used to
   dedupe consecutive same-name same-arity defns (Lisp's last-write-wins
   for var bindings; Go has no overloading, so emitting both would
   produce a function-redeclaration error). Returns nil if the form
   shape isn't recognised — those are left alone."
  [form]
  (when (and (seq? form) (>= (count form) 3))
    (let [raw-name (nth form 1)
          name-sym (unwrap-name raw-name)
          name-str (str name-sym)
          maybe-doc (nth form 2)
          has-doc?  (string? maybe-doc)
          args-or-arity (if has-doc?
                          (if (>= (count form) 4) (nth form 3) nil)
                          maybe-doc)]
      (cond
        (vector? args-or-arity) [name-str (count args-or-arity)]
        (list? args-or-arity)   [name-str :multi]
        :else                   nil))))

(defn- collect-call-targets
  "Walk form, return a set of symbol-name strings used in
   call-head position. A symbol in head position of a list-form is
   treated as a call target. We over-approximate: this includes locals,
   special forms, macros — toposort-by only uses these to find graph
   edges between known defn names, so spurious entries are harmless."
  [form]
  (let [acc (atom #{})]
    (letfn [(visit [x]
              (cond
                (seq? x)
                (let [head (first x)]
                  (when (symbol? head)
                    (swap! acc conj (str head)))
                  (doseq [el (rest x)] (visit el)))
                (vector? x)
                (doseq [el x] (visit el))
                (map? x)
                (doseq [entry x]
                  (visit (key entry))
                  (visit (val entry)))
                :else nil))]
      (visit form))
    @acc))

(defn- forms-by-arity
  "Group same-name forms by their [name arity] key, keeping only the
   LAST occurrence per key (Lisp redefinition semantics). Returns a
   map {[name arity] -> form}."
  [forms]
  (loop [remaining forms acc {}]
    (if (empty? remaining)
      acc
      (let [form (first remaining)
            k    (defn-key form)]
        (recur (rest remaining)
               (if k (assoc acc k form) acc))))))

(defn- order-defn-forms
  "Dedupe same-(name,arity) forms (last wins) and arrange in
   dependencies-first topological order using graph/toposort-by.
   Tiebreak among independently-ready nodes by lexical name asc, then
   arity asc — so same-name arities cluster together and the overall
   output is deterministic across runs. Returns a vector of forms.

   Non-defn forms (anything `defn-key` doesn't recognise) and forms
   that participate in a dependency cycle fall through to the end in
   source order."
  [forms]
  (let [keyed     (forms-by-arity forms)
        own-names (set (map first (keys keyed)))
        ;; Sort keys deterministically: lex name asc, then arity asc
        ;; (multi-arity placeholder :multi sorts after numbers).
        cmp       (fn [[na aa] [nb ab]]
                    (let [c (compare na nb)]
                      (if (zero? c)
                        (compare (str aa) (str ab))
                        c)))
        sorted-ks (vec (sort cmp (keys keyed)))
        sorted-forms (mapv keyed sorted-ks)
        deps-fn   (fn [form]
                    (let [self-name (first (defn-key form))]
                      ;; SORT the deps: collect-call-targets returns a hash-SET,
                      ;; so filtering it yields hash-ordered (run-varying) deps.
                      ;; toposort appends deps in iteration order (post-order),
                      ;; so unsorted deps flip the emitted function order across
                      ;; processes on acyclic namespaces. A stable dep order pairs
                      ;; with graph/toposort's sorted DFS roots for full determinism.
                      (vec (sort (filter (fn [n] (and (not= n self-name)
                                                      (own-names n)))
                                         (collect-call-targets form))))))
        topo (g/toposort-by (fn [form] (first (defn-key form)))
                            sorted-forms
                            deps-fn)
        ;; If the call graph has a cycle (mutual recursion), toposort
        ;; returns nil — Go is fine with mutual recursion within a
        ;; package, so fall back to the lex-sorted order.
        ordered (or topo sorted-forms)
        non-defn (vec (remove (fn [f] (some? (defn-key f))) forms))]
    (into ordered non-defn)))

  ;; --- gogen_ir override-registration emission (Part 1) ----------------
  ;; Each lowered package emits a package-local `__gogen_wrap` helper plus
  ;; an init() that calls rt.RegisterGoOverrides, clobbering the bytecode-
  ;; produced Vars with NativeFn adapters that call the lowered Go fns. The
  ;; resolver/eval drains these after each namespace loads. Untagged builds
  ;; never import these packages, so none of this runs.
  ;;
  ;; All AST is built with gogen primitives (not string concat) so
  ;; gogen/render owns formatting. Only single-arity, non-variadic lowered
  ;; fns are registered — the strict fixed-arity wrapper can't represent an
  ;; &-rest tail.

(defn- override-wrapper-fn-lit [entry]
  "Build the per-defn `func(args []vm.Value) (vm.Value, error)` adapter:
   arity-check, then call the generated typed fn, supplying `, nil` when
   the typed fn doesn't itself return an error."
  (let [arity        (:arity entry)
        go-name      (:go-name entry)
        fn-name      (:fn-name entry)
        needs-error? (:needs-error? entry)
        args-id      (gogen/ident "args")
        len-call     (gogen/call (gogen/ident "len") [args-id])
        msg          (str fn-name ": wrong number of arguments %d (expected " arity ")")
        arity-mismatch
        (gogen/return-stmt
          [(gogen/ident "nil")
           (gogen/call
             (gogen/field-sel (gogen/ident "fmt") "Errorf")
             [(gogen/string-lit msg) len-call])])
        len-check    (gogen/if-stmt
                       nil
                       (gogen/binary "!=" len-call (gogen/int-lit arity))
                       [arity-mismatch]
                       nil)
        arg-exprs    (mapv (fn [i] (gogen/index args-id (gogen/int-lit i)))
                           (range arity))
        ;; Pass the wrapper's ExecContext as the lowered fn's first arg, so
        ;; dynamic-var resolution inside the lowered body runs against the
        ;; caller's context (matching the bytecode path) rather than the root.
        inner-call   (gogen/call (gogen/ident go-name)
                                 (into [(gogen/ident "ec")] arg-exprs))
        ret-stmt     (if needs-error?
                       (gogen/return-stmt [inner-call])
                       (gogen/return-stmt [inner-call (gogen/ident "nil")]))]
    (gogen/func-lit
      [(gogen/param "ec" (gogen/type "*vm.ExecContext"))
       (gogen/param "args" (gogen/type "[]vm.Value"))]
      [(gogen/result (gogen/type "vm.Value"))
       (gogen/result (gogen/type "error"))]
      [len-check ret-stmt])))

(defn- multi-arity-override-wrapper-fn-lit [arities]
  "Combined `func(ec, args []vm.Value) (vm.Value, error)` adapter for a
   multi-arity fn: `switch len(args)` routes each arity to its per-arity helper
   `<name>_<arity>(ec, args[0], …)`. Registered under the bare :fn-name (via
   __gogen_wrap/NewCtxNativeFn) so the dynamic var path stays multi-arity AND is
   context-aware — the caller's ec is threaded into each helper (a
   MakeNativeMultiArity value can't, being built at package load with no ec).
   Only used when every arity is override-eligible (uniform vm.Value)."
  (let [fn-name  (:fn-name (first arities))
        args-id  (gogen/ident "args")
        len-call (gogen/call (gogen/ident "len") [args-id])
        arm->case
        (fn [r]
          (let [arity        (:arity r)
                go-name      (:go-name r)
                needs-error? (:needs-error? r)
                arg-exprs    (mapv (fn [i] (gogen/index args-id (gogen/int-lit i)))
                                   (range arity))
                inner-call   (gogen/call (gogen/ident go-name)
                                         (into [(gogen/ident "ec")] arg-exprs))
                ret-stmt     (if needs-error?
                               (gogen/return-stmt [inner-call])
                               (gogen/return-stmt [inner-call (gogen/ident "nil")]))]
            (gogen/case-clause [(gogen/int-lit arity)] [ret-stmt])))
        cases    (mapv arm->case arities)
        msg      (str fn-name ": wrong number of arguments %d")
        default  (gogen/case-clause nil
                   [(gogen/return-stmt
                      [(gogen/ident "nil")
                       (gogen/call (gogen/field-sel (gogen/ident "fmt") "Errorf")
                                   [(gogen/string-lit msg) len-call])])])
        sw       (gogen/switch-stmt nil len-call (conj cases default))]
    (gogen/func-lit
      [(gogen/param "ec" (gogen/type "*vm.ExecContext"))
       (gogen/param "args" (gogen/type "[]vm.Value"))]
      [(gogen/result (gogen/type "vm.Value"))
       (gogen/result (gogen/type "error"))]
      [sw])))

(defn- override-helper-decl []
  "Build the package-local `__gogen_wrap` helper:
     func __gogen_wrap(fn func(ec *vm.ExecContext, args []vm.Value) (vm.Value, error)) vm.Value {
       return vm.NewCtxNativeFn(\"\", fn)
     }
   The override is a context-aware native: ec.Invoke hands it the caller's
   ExecContext, which the wrapper forwards into the lowered fn."
  (let [wrap-call (gogen/call
                    (gogen/field-sel (gogen/ident "vm") "NewCtxNativeFn")
                    [(gogen/string-lit "") (gogen/ident "fn")])
        ret       (gogen/return-stmt [wrap-call])]
    (gogen/func-decl
      "__gogen_wrap"
      [(gogen/param "fn" (gogen/type "func(ec *vm.ExecContext, args []vm.Value) (vm.Value, error)"))]
      [(gogen/result (gogen/type "vm.Value"))]
      [ret])))

(defn- override-init-decl [ns-name entries multi-groups]
  "Build the package's init() that calls rt.RegisterGoOverrides with a
   map[string]vm.Value literal of __gogen_wrap-wrapped adapters. `entries` are
   single-arity results (one fixed-arity wrapper each); `multi-groups` are
   [fn-name (sorted-by-arity results)] pairs (one len-switch adapter each)."
  (let [single-kvs (mapv (fn [e]
                           (gogen/kv-expr
                             (gogen/string-lit (:fn-name e))
                             (gogen/call (gogen/ident "__gogen_wrap")
                                         [(override-wrapper-fn-lit e)])))
                         entries)
        multi-kvs  (mapv (fn [[nm arities]]
                           (gogen/kv-expr
                             (gogen/string-lit nm)
                             (gogen/call (gogen/ident "__gogen_wrap")
                                         [(multi-arity-override-wrapper-fn-lit arities)])))
                         multi-groups)
        kv-pairs (into single-kvs multi-kvs)
        map-lit  (gogen/composite-lit-multi
                   (gogen/type "map[string]vm.Value")
                   kv-pairs)
        register-call (gogen/call
                        (gogen/field-sel (gogen/ident "rt") "RegisterGoOverrides")
                        [(gogen/string-lit ns-name) map-lit])]
    (gogen/func-decl
      "init" [] []
      [(gogen/expr-stmt register-call)])))

(defn- native-multifn-init-decl [ns-name names]
  "Build an init() that registers this ns's native-baked multimethods via
   rt.RegisterNativeMultiFns(\"ns\", []string{...}). The runtime freezes them
   as the native dispatch baseline once the ns finishes loading, so the
   generated type-switch guard (rt.MultiFnNativeFrozen) can detect a later
   defmethod and fall back to runtime dispatch."
  (let [slice-lit (gogen/composite-lit
                    (gogen/type "[]string")
                    (mapv gogen/string-lit names))
        register  (gogen/call
                    (gogen/field-sel (gogen/ident "rt") "RegisterNativeMultiFns")
                    [(gogen/string-lit ns-name) slice-lit])]
    (gogen/func-decl
      "init" [] []
      [(gogen/expr-stmt register)])))

(defn- override-entries [valid-results]
  "Lowered results eligible for SINGLE-arity override registration: single-arity
   fns (carry :fn-name) whose Go signature is uniformly vm.Value, so the
   fixed-arity wrapper adapts them without boxing/unboxing. Typed and
   variadic fns are flagged :override-eligible? false and stay on bytecode.
   Multi-arity arities (:multi-arity?) are EXCLUDED here — they'd each register a
   colliding single-arity wrapper under the same bare :fn-name; the whole fn gets
   one multi-arity override adapter instead (multi-arity-override-groups)."
  (filterv (fn [r] (and (:fn-name r) (:override-eligible? r) (not (:multi-arity? r))))
           valid-results))

(defn- multi-arity-override-groups [valid-results]
  "Group the multi-arity per-arity results by bare :fn-name for ONE combined
   override adapter each. Only emit the override when EVERY arity is
   :override-eligible? (uniform vm.Value) — a typed arity can't be called with
   boxed args[i] from the dynamic dispatch adapter. When any arity is typed the
   whole fn's dynamic (var) path stays on bytecode; the per-arity STATIC direct
   calls still go native (registry-entry-from-result gates on the broader
   :direct-callable?, coercing typed args at the call site). Returns a sorted vec
   of [fn-name (sorted-by-arity results)] pairs for deterministic emission."
  (let [by-name (reduce (fn [m r]
                          (if (:multi-arity? r)
                            (update m (:fn-name r) (fnil conj []) r)
                            m))
                        {} valid-results)]
    (vec
      (keep (fn [nm]
              (let [arities (sort-by :arity (get by-name nm))]
                (when (every? :override-eligible? arities)
                  [nm arities])))
            (sort (keys by-name))))))

  ;; Extra decls reference rt + vm + fmt; attach the imports explicitly so a
  ;; package whose lowered fns happen to need none still compiles.
(def ^:private override-decl-imports
  [{:path "github.com/nooga/let-go/pkg/rt" :alias "rt"}
   {:path "github.com/nooga/let-go/pkg/vm" :alias "vm"}
   {:path "fmt" :alias nil}])

;; EPIC-012 / ITER-0025 (cross-package direct calls). When true, lower-ns-to-go
;; emits an exported thin wrapper `func LG_<go>(ec, …) <ret> { return <go>(ec, …) }`
;; for each direct-callable lowered fn, so it is reachable from another Go
;; package. DEFAULT false: the committed lowered tree stays byte-identical until
;; the whole-program collector (registering cross-package entries that actually
;; emit `core.LG_<go>(…)` calls) is wired — keeping the bootstrap codegen green
;; at every step. Flipped on by the collector (and by the T3 unit test).
(def ^:dynamic *emit-exported-wrappers* false)

;; The whole-program cross-package registry, bound by lower-all-ns-to-go: a flat
;; {[internal-ns name arity] -> {:go-pkg <import-path> :go-name "LG_<go>" …}} of
;; every OTHER lowered package's direct-callable exports. Merged into the per-ns
;; `reg` like native-reg (stable, never shrunk by the per-ns fixpoint) so a call
;; into another lowered package resolves to `pkg.LG_<go>(ec, …)`. Default {} ⇒
;; lower-ns-to-go behaves exactly as before (no cross-package entries).
(def ^:dynamic *cross-pkg-registry* {})

;; Set of [defining-ns-internal-sym fn-name-str] that ARE referenced
;; cross-package (from the collector's union of @*cross-ns-vars-used*).
;; lower-ns-to-go emits an exported wrapper ONLY for a fn in this set — so we
;; export exactly the fns some other package calls, never dead wrappers.
;;   :all (default) ⇒ emit a wrapper for EVERY direct-callable fn (the manual /
;;     single-ns convenience: `(binding [*emit-exported-wrappers* true] …)` with
;;     no collected target set).
;;   a concrete set ⇒ emit wrappers for exactly its members; an EMPTY set ⇒ none.
;; lower-all-ns-to-go always binds the concrete `targets` set, so a whole-program
;; build with no cross-package references emits no wrappers (no dead exported API)
;; rather than exporting everything.
(def ^:dynamic *wrapper-target-names* :all)

(defn- exported-wrapper-decl [result]
  "Exported thin forwarding wrapper for a direct-callable lowered fn, so it is
   callable from another Go package without renaming the unexported fn (which
   would perturb byte-stable intra-package call sites). Name is `LG_<go-name>`:
   the munged go-name is already a valid+unique Go identifier, and the `LG_`
   prefix makes it exported (capital L) and valid even for go-names starting
   with `_` (e.g. `_dt_collect_syms` -> `LG__dt_collect_syms`). Signature mirrors
   the lowered fn exactly (param-specs/result-spec/needs-error?), forwarding ec +
   args positionally — so emit-typed-direct-call's `pkg.LG_<go>(ec, coerced…)`
   typechecks identically to a same-package direct call."
  (let [go-name      (:go-name result)
        exp-name     (str "LG_" go-name)
        arity        (:arity result)
        param-specs  (vec (:param-specs result))
        result-spec  (:result-spec result)
        needs-error? (:needs-error? result)
        params  (into [(gogen/param "ec" (gogen/type "*vm.ExecContext"))]
                      (mapv (fn [i] (gogen/param (str "arg" i)
                                      (gogen/type (nth param-specs i "vm.Value"))))
                            (range arity)))
        results (if needs-error?
                  [(gogen/result (gogen/type result-spec)) (gogen/result (gogen/type "error"))]
                  [(gogen/result (gogen/type result-spec))])
        arg-ids (mapv (fn [i] (gogen/ident (str "arg" i))) (range arity))
        call    (gogen/call (gogen/ident go-name) (into [(gogen/ident "ec")] arg-ids))]
    (gogen/func-decl exp-name params results [(gogen/return-stmt [call])])))

(defn- lower-defn-forms
  "Lower each defn form via the Go pipeline; return the vector of result maps.
   Independent of *lowered-registry* — the caller binds it for pass 2."
  [defn-forms]
  (loop [remaining defn-forms out []]
    (if (empty? remaining)
      out
      (let [form (first remaining)
            result (try
                     (binding [*target* :go]
                       (compile-form* form))
                     (catch e
                       (println (str "WARNING: lowering failed for "
                                     (pr-str (try (second form) (catch _ form)))
                                     ": " e))
                       nil))]
        (cond
          (nil? result)
          (recur (rest remaining) out)
          (= :lowered (:status result))
          (recur (rest remaining) (conj out result))
          (= :multi-fn-template (:kind result))
          ;; Flatten multi-arity templates into individual per-arity results.
          ;; Carry each arity's FULL result (compile-form* stashed it under
          ;; :result) so it registers as a per-arity direct-callable
          ;; [ns name arity] -> name_arity entry exactly like a single-arity fn
          ;; (registry-entry-from-result keys on the bare :fn-name + :arity and
          ;; calls the suffixed :go-name). Tag :multi-arity? so the SINGLE-arity
          ;; override path skips it — the whole fn instead gets ONE multi-arity
          ;; override adapter (see override-init-decl), avoiding N colliding
          ;; bare-name override map entries. Older templates without :result
          ;; (defensive) fall back to the decl-only shape.
          (let [flat (reduce (fn [acc entry]
                               (cond
                                 (:result entry)
                                 (conj acc (assoc (:result entry) :multi-arity? true))
                                 (:fn entry)
                                 (conj acc {:status :lowered :decl (:fn entry) :imports []})
                                 :else acc))
                             []
                             (:fns result))]
            (recur (rest remaining) (into out flat)))
          :else
          (do
            ;; A non-:lowered single result (e.g. {:status :fallback :reason …})
            ;; carries no decl — warn rather than silently drop it, so a form
            ;; that failed to lower stays visible instead of vanishing from the
            ;; generated package with no trace.
            (println (str "WARNING: not lowered ("
                          (pr-str (or (:status result) (:kind result)))
                          ") for "
                          (pr-str (try (second form) (catch _ form)))
                          (if (:reason result) (str ": " (:reason result)) "")))
            (recur (rest remaining) out)))))))

(defn lower-ns-to-go [pkg-name ns-name forms]
  "Process a namespace's forms through the Go-lowering pipeline and return
   rendered Go source for a package. pkg-name is the Go package name string,
   ns-name is the namespace symbol (for *ns* binding), and forms is a vector of
   raw top-level forms: (defn ...) plus optional (defprotocol ...) / (deftype
   ...) declaration forms. Declaration forms are emitted as a native Go
   interface / struct+constructor / receiver methods, and the deftype
   constructor + protocol-method registries are bound so the namespace's own
   functions devirtualize constructor calls and protocol dispatch."
  ;; Determinism: the Go-lowering path encodes inferred types into the
  ;; rendered source, so typeinfer MUST run to fixpoint here — a wall-clock
  ;; budget would yield a partial, time-dependent result (non-deterministic
  ;; tree, and :bottom-heavy partials that drop forms → undefined: builds).
  ;; The monotone lattice has finite height, so unbounded execution always
  ;; terminates; it's just slower than the interactive/bytecode default.
  (let [decl-form?  (fn [form]
                      (and (seq? form)
                           (contains? #{'defprotocol 'deftype 'defmulti 'defmethod} (first form))))
        decl-forms  (filterv decl-form? forms)
        defn-forms0 (filterv (fn [form] (not (decl-form? form))) forms)
        ;; Capture each declaration form ({:decl-kind … :name … …}).
        captures    (mapv (fn [form] (binding [*target* :go] (compile-form* form))) decl-forms)
        protocols   (filterv (fn [c] (= :defprotocol (:decl-kind c))) captures)
        deftypes    (filterv (fn [c] (= :deftype (:decl-kind c))) captures)
        ;; Multimethod captures. Methods are grouped by multifn name preserving
        ;; SOURCE ORDER (the switch arms are emitted in this order → deterministic).
        defmulti-caps  (filterv (fn [c] (= :defmulti (:decl-kind c))) captures)
        defmethod-caps (filterv (fn [c] (= :defmethod (:decl-kind c))) captures)
        methods-by-mm  (reduce (fn [m c]
                                 (update m (str (:name c)) (fnil conj []) c))
                               {} defmethod-caps)
        ;; Registries built from THIS namespace's captures, bound below so the
        ;; namespace's own defns type ctor results as [:dtype T] (typeinfer),
        ;; lower (->T …) to the native _T(…) constructor, and devirtualize
        ;; protocol-method calls on a known-concrete receiver to recv.M().
        protocol-method-set (into #{} (mapcat (fn [p] (map (fn [m] (str (first m))) (:methods p))) protocols))
        ctor-types  (into {} (map (fn [dt] [(str "->" (:name dt)) (:name dt)]) deftypes))
        ctors       (into {} (map (fn [dt] [(str "->" (:name dt)) (lower-go/go-export-name (:name dt))]) deftypes))
        vm-import   {:path "github.com/nooga/let-go/pkg/vm" :alias "vm"}
        rt-import   {:path "github.com/nooga/let-go/pkg/rt" :alias "rt"}
        _cache-rst  (reset! *deftype-method-ir-cache* {})]
    (binding [*ns* (the-ns ns-name)
              ir.passes.typeinfer/*typeinfer-budget-ms* nil
              ir.passes.typeinfer/*deftype-ctor-types* (when (seq ctor-types) ctor-types)
              lower-go/*deftype-ctors* (when (seq ctors) ctors)
              lower-go/*protocol-methods* (when (seq protocol-method-set) protocol-method-set)
              lower-go/*protocol-method-sigs* (let [s (protocol-method-sigs deftypes)]
                                                (when (seq s) s))]
      (let [;; Native decls for captured protocols (interface) and deftypes
            ;; (struct + constructor + receiver methods). The interface/struct
            ;; reference vm.* (vm import); receiver method bodies also call rt.*
            ;; arithmetic/dispatch helpers (rt import).
            protocol-decls (mapv (fn [p]
                                   {:decl (:decl (lower-go/lower-defprotocol p))
                                    :imports [vm-import]})
                                 protocols)
            deftype-decls  (vec (mapcat
                                  (fn [dt]
                                    (let [s (lower-go/lower-deftype-struct dt)
                                          m (lower-deftype-methods dt)]
                                      (into (mapv (fn [d] {:decl d :imports [vm-import]}) (:decls s))
                                            (mapv (fn [d] {:decl d :imports [vm-import rt-import]}) (:decls m)))))
                                  deftypes))
            ;; Native multimethod lowering. For each defmulti whose dispatch fn is
            ;; a recognized (fn [x] (type x)) shape, try to map each method's
            ;; dispatch-val to a Go type AND lower its body to a package-level Go
            ;; fn (_mm_*). A method counts as a native arm only if BOTH succeed;
            ;; a multifn with >=1 native arm becomes a :type dispatcher (the rest
            ;; — and all other Go representations — route through the runtime
            ;; vm.MultiFn default arm). Method bodies are lowered HERE, with
            ;; *defmulti-dispatchers* still unbound, so a body that recursively
            ;; calls the multifn uses the trampoline (no dangling self-reference
            ;; before the decls exist). Source order is preserved → deterministic.
            defmulti-lowered
            (mapv
              (fn [dm]
                (let [mm-name (str (:name dm))
                      di      (lower-go/recognize-type-dispatch-fn (:dispatch-fn dm))
                      methods (get methods-by-mm mm-name [])]
                  (if (nil? di)
                    ;; Not the (type x) shape → value/unknown dispatch. Register a
                    ;; MINIMAL entry (just :dispatch-type) so the multifn is VISIBLE
                    ;; to the coverage tooling (ITER-0012) and trampolines BY TAG
                    ;; rather than by omission. No :home-ns/:dispatch-arg-index/:arms:
                    ;; defmulti-call-stmts' (= :type …) guard rejects it before any of
                    ;; those are read, so emission is byte-identical AND we avoid the
                    ;; (resolve …) call here (keeps the registry deterministic).
                    {:name  mm-name
                     :entry {:dispatch-type (lower-go/classify-dispatch (:dispatch-fn dm))}
                     :decls []}
                    (let [arm+decl
                          (vec (keep-indexed
                                 (fn [i meth]
                                   (let [gt (lower-go/dispatch-val-to-go-type (:dispatch-val meth))]
                                     (when gt
                                       (let [go-name (lower-go/defmulti-method-go-name mm-name i)
                                             fn-form (apply list 'defn (symbol go-name) (:fn-tail meth))
                                             result  (try (binding [*target* :go] (compile-form* fn-form))
                                                          (catch _e nil))]
                                         ;; Native arm only if the method lowered to the UNIFORM
                                         ;; vm.Value ABI (all params + result vm.Value) — then the
                                         ;; call site passes boxed args + reads a vm.Value result
                                         ;; with no coercion. Typed-specialized methods (int/bool/…)
                                         ;; drop their arm and route through the runtime default.
                                         (when (and result
                                                    (= :lowered (:status result))
                                                    (= "vm.Value" (:result-spec result))
                                                    (every? (fn [s] (= "vm.Value" s)) (:param-specs result)))
                                           {:arm  {:go-case-type gt
                                                   :go-fn-name   (:go-name result)
                                                   :param-count  (count (first (:fn-tail meth)))
                                                   :needs-error? (:needs-error? result)}
                                            :decl {:decl (:decl result)
                                                   :imports (or (:imports result) [vm-import rt-import])}})))))
                                 methods))
                          ;; Runtime multimethod semantics are last-write-wins
                          ;; by dispatch value: a later (defmethod mm dv …)
                          ;; replaces the earlier method in the MultiFn map. For
                          ;; the native :type switch each :go-case-type IS that
                          ;; dispatch value's Go representation, so two
                          ;; (defmethod mm (type []) …) would otherwise emit
                          ;; duplicate `case vm.ArrayVector:` clauses — invalid
                          ;; Go, and semantically wrong (an older arm could win,
                          ;; or a stale-arity arm survive the call-site
                          ;; :param-count filter while the runtime would use the
                          ;; latest method). Collapse to the LAST arm+decl per
                          ;; :go-case-type, kept at its last source position so
                          ;; native dispatch matches runtime last-wins. No
                          ;; duplicates → identical to source order, no churn.
                          collapsed (let [last-ix (reduce (fn [m [i x]]
                                                            (assoc m (:go-case-type (:arm x)) i))
                                                          {} (map-indexed vector arm+decl))]
                                      (mapv second
                                            (filterv (fn [[i x]]
                                                       (= i (get last-ix (:go-case-type (:arm x)))))
                                                     (map-indexed vector arm+decl))))
                          arms  (mapv :arm collapsed)
                          decls (mapv :decl collapsed)]
                      (if (seq arms)
                        {:name  mm-name
                         ;; :home-ns is the multifn var's namespace, resolved the
                         ;; SAME way a call site resolves it (both go through the
                         ;; var → identical ns string), so defmulti-call-stmts can
                         ;; match same-ns calls robustly regardless of the
                         ;; ns-name/canonical-name duality (e.g. core vs the
                         ;; lookup symbol passed to lower-ns-to-go).
                         :entry {:dispatch-type :type
                                 :dispatch-arg-index di
                                 :home-ns (let [v (try (resolve (symbol mm-name)) (catch _e nil))]
                                            (when v (namespace (symbol v))))
                                 :arms arms}
                         :decls decls}
                        ;; Type-dispatch SHAPE but no method mapped to a Go type →
                        ;; no native arms. Still register it (tag :type, no :arms) so
                        ;; it is visible to coverage tooling; the empty :arms means
                        ;; defmulti-call-stmts trampolines (byte-identical to the
                        ;; prior omission).
                        {:name  mm-name
                         :entry {:dispatch-type :type}
                         :decls []})))))
              defmulti-caps)
            defmulti-registry (into {} (keep (fn [x] (when (:entry x) [(:name x) (:entry x)]))
                                             defmulti-lowered))
            defmulti-decls    (vec (mapcat :decls defmulti-lowered))
            type-decls (into (into protocol-decls deftype-decls) defmulti-decls)
            defn-forms (order-defn-forms defn-forms0)
            ;; Pass 1 discovers lowered single-arity vm.Value-uniform siblings
            ;; (:override-eligible?) — the intra-ns calls slice 1 can lift.
            pass1 (lower-defn-forms defn-forms)
            sibling-registry (reduce (fn [m r]
                                       (merge m (lower-go/registry-entry-from-result r ns-name pkg-name)))
                                     {} pass1)
            ;; Native modules (e.g. clojure.core/seq -> corefns.Seq) registered
            ;; via (rt/native-modules) seed the registry too, so cross-ns calls
            ;; into native Go fns lower to direct pkg.Fn(...) calls instead of
            ;; rt.CachedVarFn trampolines. Native entries are STABLE across the
            ;; pass-2 fixpoint (they name external Go fns that always exist), so
            ;; they are merged in fresh each iteration rather than subjected to
            ;; the sibling-shrinking select-keys below — which would otherwise
            ;; strip them (a native never emits a local :decl) and silently
            ;; revert native calls to trampolines in the converged result. A
            ;; lowered sibling that redefines a core fn shadows the native.
            native-reg (lower-go/native-registry (rt/native-modules))
            ;; Accumulates the Go import paths of native modules actually
            ;; direct-called in this ns (filled by lookup-direct-callable), so
            ;; the emitted file imports e.g. corefns for `corefns.Seq(...)`.
            native-imports (atom #{})
            ;; Pass 2 re-lowers with the registry visible so intra-ns and
            ;; cross-ns native calls lower to direct Go calls. The cross-ns atom
            ;; records trampoline-reaching load-var callees for memoized
            ;; cached-*vm.Var resolution.
            ;;
            ;; Dangling-call hazard: a fn registered from pass 1 can take a
            ;; different (registry-visible) path in pass 2 and BAIL (no :decl),
            ;; yet its callers still emit a *direct* Go call to it — a reference
            ;; to an undefined function. Whether this happens is nondeterministic
            ;; (depends on per-pass typeinfer/gensym state), which is why a fresh
            ;; `make check-generated` intermittently fails to compile the lowered
            ;; tree. Fix: iterate to a fixpoint where the registry holds ONLY fns
            ;; that actually emit a decl in that pass. reg' = reg ∩ emitted ⊆ reg,
            ;; so the registry is monotonically shrinking and this terminates;
            ;; worst case it empties and every intra-ns call falls back to the
            ;; always-compilable trampoline. A fresh cross-ns atom is used per
            ;; pass; the converged pass's atom is the one we keep.
            emitted-registry (fn [res]
                               (reduce (fn [m r]
                                         (if (some? (:decl r))
                                           (merge m (lower-go/registry-entry-from-result r ns-name pkg-name))
                                           m))
                                       {} res))
            pass2 (let [cap (+ 2 (count sibling-registry))]
                    ;; sib-reg shrinks to a fixpoint (dangling-call hazard);
                    ;; native-reg is always merged on top and never shrinks.
                    (loop [sib-reg sibling-registry guard 0]
                      (let [cross (atom {})
                            ;; *cross-pkg-registry* (other lowered packages'
                            ;; exports) is merged like native-reg — stable, never
                            ;; shrunk — BELOW sib-reg so this ns's own siblings
                            ;; (bare intra-pkg calls) shadow their cross-pkg form.
                            reg (merge native-reg *cross-pkg-registry* sib-reg)
                            res (binding [lower-go/*lowered-registry* reg
                                          lower-go/*native-imports-used* native-imports
                                          lower-go/*cross-ns-vars-used* cross
                                          lower-go/*defmulti-dispatchers* (when (seq defmulti-registry)
                                                                            defmulti-registry)]
                                  (lower-defn-forms defn-forms))
                            sib-reg' (select-keys sib-reg (keys (emitted-registry res)))]
                        (if (or (= sib-reg' sib-reg) (>= guard cap))
                          {:results res :cross cross}
                          (recur sib-reg' (inc guard))))))
            cross-ns-vars (:cross pass2)
            results (:results pass2)
            ;; Filter out results with nil decls (failures that slipped through).
            valid-results (filterv (fn [r] (some? (:decl r))) results)
            ;; gogen_ir: append a __gogen_wrap helper + init() that
            ;; registers Go-native overrides for the eligible lowered fns.
            reg-entries (override-entries valid-results)
            multi-groups (multi-arity-override-groups valid-results)
            extra-decls (if (or (seq reg-entries) (seq multi-groups))
                          [{:decl (override-helper-decl)
                            :imports override-decl-imports}
                           {:decl (override-init-decl (str ns-name) reg-entries multi-groups)
                            :imports override-decl-imports}]
                          [])
            ;; Native-baked multimethods (a :type dispatcher with >=1 arm) must
            ;; be frozen at ns-load so the generated MultiFnNativeFrozen guard
            ;; can detect later defmethods. Register them via their own init().
            native-mm-names (sort (keep (fn [[nm entry]]
                                          (when (and (= :type (:dispatch-type entry))
                                                     (seq (:arms entry)))
                                            nm))
                                        defmulti-registry))
            extra-decls (if (seq native-mm-names)
                          (conj extra-decls
                                {:decl (native-multifn-init-decl (str ns-name) native-mm-names)
                                 :imports override-decl-imports})
                          extra-decls)
            ;; Package-level cached *vm.Var decls + lazy accessors for the
            ;; recorded cross-ns callees (deterministic, sorted by base name).
            cached-var-decls (lower-go/cross-ns-var-decls @cross-ns-vars)
            ;; EPIC-012/ITER-0025 → ITER-0037: cross-package calls now resolve to
            ;; a public fn's OWN exported PascalCase name (emit-go-name), so the
            ;; `LG_<go>` forwarding-wrapper indirection is gone — no wrapper decls
            ;; are emitted. (*emit-exported-wrappers*/*wrapper-target-names* and
            ;; exported-wrapper-decl are retained only as the legacy manual
            ;; single-ns path; the whole-program collector no longer needs them.)
            wrapper-results []
            ;; Native type/struct/method decls lead the file; Go resolves
            ;; package-scope references regardless of declaration order.
            all-results (into (into (into (into type-decls valid-results) extra-decls) cached-var-decls) wrapper-results)
            ;; Carry the accumulated native-module imports (corefns, …) into the
            ;; file's import block via a decl-less import-only result.
            native-import-results (if (seq @native-imports)
                                    [{:decl nil
                                      :imports (mapv (fn [p] {:path p}) (sort @native-imports))}]
                                    [])
            all-results (into all-results native-import-results)
            file-ast (lower-go/file pkg-name all-results)]
        (gogen/render file-ast)))))

;; --- EPIC-012 / ITER-0025: whole-program cross-package direct-call collector ---

(defn- collect-ns-exports [pkg-name ns-sym forms import-path]
  "Phase-0 discovery for one namespace: run pass-1 lowering (no cross-pkg
   registry) and return {:exports {<key> <cross-pkg-entry>} :refs #{[ns name]}}.
   :exports are this ns's direct-callable fns re-keyed for cross-package dispatch
   via the canonical registry-entry-from-result, then stamped with :go-pkg =
   import-path. The :go-name is the fn's OWN exported PascalCase name (public fns
   are their own callable name — no `LG_` forwarding wrapper), so a cross-package
   call resolves to `pkg.Conj(ec,…)`. :refs are the cross-ns callees it references
   (same-ns calls filtered — those resolve intra-package with no import)."
  (binding [*ns* (the-ns ns-sym)
            ir.passes.typeinfer/*typeinfer-budget-ms* nil]
    (let [cross   (atom {})
          results (binding [lower-go/*cross-ns-vars-used* cross]
                    (lower-defn-forms (order-defn-forms forms)))
          exports (reduce
                    (fn [m r]
                      (let [base (when (:decl r)
                                   (lower-go/registry-entry-from-result r ns-sym pkg-name))]
                        (if base
                          (into m (map (fn [kv]
                                         [(key kv) (assoc (val kv)
                                                          :go-pkg  import-path)])
                                       base))
                          m)))
                    {} results)
          ns-str  (str ns-sym)
          refs    (reduce (fn [s kv]
                            (let [k (key kv)]      ; k = [ns-str name-str]
                              (if (= (first k) ns-str) s (conj s k))))
                          #{} @cross)]
      {:exports exports :refs refs})))

(defn- cross-pkg-owners [global-reg]
  "Internal-ns symbols that OWN at least one cross-package export — i.e. the
   packages a direct call would `import`."
  (reduce (fn [s k] (conj s (first k))) #{} (keys global-reg)))

(defn- cross-pkg-dep-graph [specs collected owners]
  "Candidate cross-package call graph: caller-internal-ns -> #{callee-internal-ns},
   over refs whose callee package actually owns a registry export (those are the
   edges that would become Go imports). Self-edges dropped. A cycle here is a Go
   import cycle, so these edges are what must be kept acyclic."
  (reduce
    (fn [m i]
      (let [caller  (lower-go/internal-ns-sym (str (nth (nth specs i) 1)))
            callees (reduce (fn [s ref]
                              (let [q (lower-go/internal-ns-sym (first ref))]
                                (if (or (= q caller) (not (contains? owners q)))
                                  s
                                  (conj s q))))
                            #{} (:refs (nth collected i)))]
        (assoc m caller (into (get m caller #{}) callees))))
    {} (range (count specs))))

(defn- transitive-reach [graph]
  "graph: node -> #{direct successors}. Returns node -> #{all nodes reachable via
   one or more edges}. Fixpoint over the finite node set."
  (let [nodes (keys graph)]
    (loop [reach (reduce (fn [m n] (assoc m n (get graph n #{}))) {} nodes)]
      (let [nxt (reduce
                  (fn [m n]
                    (assoc m n
                           (reduce (fn [acc s] (into acc (get reach s #{})))
                                   (get reach n #{})
                                   (get reach n #{}))))
                  {} nodes)]
        (if (= nxt reach) reach (recur nxt))))))

(defn- acyclic-registry-for [global-reg reach caller]
  "global-reg minus entries whose owner package can transitively reach `caller`:
   keeping such a `caller -> owner` edge would close an import cycle, so that call
   stays on the cached-var trampoline until cycle support exists. DAG edges
   (including an acyclic external caller into a cyclic component) are preserved."
  (reduce (fn [m kv]
            (let [q (first (key kv))]
              (if (or (= q caller) (not (contains? (get reach q #{}) caller)))
                (assoc m (key kv) (val kv))
                m)))
          {} global-reg))

(defn lower-all-ns-to-go [specs]
  "Whole-program Go lowering with cross-package direct calls (EPIC-012/ITER-0025).
   specs: vector of positional [pkg-name ns-sym forms import-path]. Phase 0 collects the
   global cross-package registry + the set of fns referenced cross-package; phase
   1 lowers every namespace with that registry visible (a call into another
   lowered package emits `pkg.LG_<go>(ec, …)`) and emits an exported wrapper for
   each cross-referenced fn. Two SEPARATED phases (collect-all then emit-all), so
   emission order is irrelevant: the global registry is complete before any
   package is emitted. Soundness: registry visibility only turns trampolines into
   direct calls (or the same trampoline on coercion failure) — it never causes a
   fn that emitted in phase 0 to bail in phase 1 — so every confirmed export's
   wrapper is emitted; `make check-generated`'s compile step is the hard backstop
   against any residual dangling reference. Returns a vector of Go source strings
   in spec order; a namespace that fails to lower yields nil at its slot (the Go
   driver treats nil as a per-ns failure, preserving per-namespace resilience)."
  (let [collected  (mapv (fn [s]
                           (try
                             (collect-ns-exports (nth s 0) (nth s 1) (nth s 2) (nth s 3))
                             (catch e
                               (println (str "WARNING: cross-pkg collect failed for "
                                             (nth s 1) ": " e))
                               {:exports {} :refs #{}})))
                         specs)
        global-reg (reduce (fn [m c] (merge m (:exports c))) {} collected)
        ;; Normalize each ref's ns through internal-ns-sym so the wrapper-target
        ;; match agrees with the registry key space (a ref to clojure.core/nil?
        ;; and the lowered ns `core` both reduce to 'core) — otherwise the
        ;; alias-remapped namespaces emit no wrappers and their callers dangle.
        targets    (reduce (fn [s c]
                             (into s (map (fn [k] [(lower-go/internal-ns-sym (first k)) (second k)])
                                          (:refs c))))
                           #{} collected)
        ;; Cross-package edges must stay acyclic or the emitted Go has an import
        ;; cycle. Build the candidate call graph, take its transitive closure,
        ;; and give each package a registry view that excludes any callee able to
        ;; reach back to it (those calls keep trampolining). Cycle-free programs
        ;; are unaffected — every callee passes the reach test.
        owners     (cross-pkg-owners global-reg)
        dep-graph  (cross-pkg-dep-graph specs collected owners)
        reach      (transitive-reach dep-graph)]
    (binding [*wrapper-target-names*   targets
              *emit-exported-wrappers* true]
      (mapv (fn [s]
              (let [caller (lower-go/internal-ns-sym (str (nth s 1)))]
                (binding [*cross-pkg-registry* (acyclic-registry-for global-reg reach caller)]
                  (try
                    (lower-ns-to-go (nth s 0) (nth s 1) (nth s 2))
                    (catch e
                      (println (str "WARNING: Go lowering failed for " (nth s 1) ": " e))
                      nil)))))
            specs))))
