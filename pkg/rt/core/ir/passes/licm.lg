;; Loop-Invariant Code Motion — Lisp port.
;;
;; LICM identifies natural loops (via dominance + back-edges) and
;; hoists loop-invariant pure Insts to a pre-header that runs once
;; before the loop body.
;;
;; Algorithm:
;;   1. Compute dominators (Lisp-side via ir.dominance/dominates?).
;;   2. Find back-edges: pred → header pairs where header dominates pred.
;;   3. For each back-edge:
;;      a. Compute the loop's block set (all blocks that can reach pred
;;         without exiting via header).
;;      b. Identify the pre-header: a non-loop pred of header. We
;;         assume there is exactly one such pred (the typical Phase 1
;;         output shape). If zero or multiple, skip this loop.
;;      c. Walk Insts in loop blocks; for each pure Inst whose ALL
;;         operands are defined OUTSIDE the loop set, hoist it to the
;;         pre-header by moving the Inst's Block to pre-header and
;;         appending it to pre-header.Insts (just before pre-header's
;;         terminator).
;;   4. After hoisting, cross-block direct refs from hoisted defs to
;;      in-loop uses will fire Lower's guardrail — thread-block-args
;;      cleans those up.
;;
;; MVP limitations:
;;   - One pre-header pred only (skip multi-pre-header cases)
;;   - No cascading hoist (a hoisted Inst whose operands are also
;;     loop-invariant doesn't trigger re-evaluation of the rest of
;;     the loop body — caller can re-run LICM to fixed point)
;;   - Doesn't detect/handle side-effect-free OpCall (only the pure
;;     ops in pure-ops set)

(ns ir.passes.licm
  (:require [ir.passes :refer []]
            [ir.dominance :as dom]))

(def pure-ops
  "Ops safe to hoist — same as DCE's pure set."
  #{:const :load-arg :load-closed :block-arg
    :add :sub :mul :lt :lte :gt :gte :eq :inc :dec})

(defn pure-op? [op] (contains? pure-ops op))

;; --- back-edge + loop-block detection ---------------------------------

(defn back-edges [f]
  "Return a vector of [pred-block header-block] pairs where
   header-block dominates pred-block (the back-edge invariant)."
  (vec
    (for [header (ir/blocks f)
          pred   (ir/block-preds header f)
          :when  (dom/dominates? f header pred)]
      [pred header])))

(defn reachable-without [f start avoid]
  "Set of blocks reachable from `start` by walking PREDECESSORS,
   excluding `avoid`. Used to compute the loop body: from the back-edge
   tail, walk back through preds; the loop is everything you reach
   before hitting the header (which we 'avoid' so we don't escape
   upward past the loop)."
  (loop [visited  #{start}
         frontier [start]]
    (if (empty? frontier)
      visited
      (let [b         (peek frontier)
            rest-wl   (pop frontier)
            new-preds (->> (ir/block-preds b f)
                           (remove #(or (= % avoid) (visited %)))
                           vec)]
        (recur (into visited new-preds)
               (into rest-wl new-preds))))))

(defn loop-blocks [f [pred header]]
  "Compute the set of blocks comprising the natural loop for back-edge
   [pred header]: {header} ∪ {blocks reachable from pred without going
   through header}."
  (conj (reachable-without f pred header) header))

(defn unique-pre-header [f header loop-set]
  "Return the unique non-loop predecessor of `header`, or nil if
   there isn't exactly one. That pred is our pre-header."
  (let [outs (remove loop-set (ir/block-preds header f))]
    (when (= 1 (count outs))
      (first outs))))

;; --- loop-invariance analysis + hoisting ----------------------------

(defn operand-defined-outside? [f inst loop-set]
  "True iff every Refs entry of `inst` is defined in a block NOT in
   `loop-set`. Constants count as outside-defined (their block is
   typically the entry but we don't special-case)."
  (let [refs (ir/refs inst f)]
    (every? (fn [r] (not (contains? loop-set (ir/block-of r f)))) refs)))

(defn collect-hoistable [f loop-set]
  "Fixed-point invariance marking. Returns set of InstIds in loop-set
   whose op is pure-op AND all refs are loop-invariant. An Inst's refs
   are loop-invariant if every ref is either outside loop-set OR was
   marked in a previous iteration. Iterates to fixed point because
   marking one Inst can satisfy another's refs."
  (loop [invariant #{}]
    (let [new-invariant
          (->> (range (count (:insts @f)))
               (filter (fn [nid]
                         (and (not (invariant nid))
                              (not= :invalid (ir/op nid f))
                              (loop-set (ir/block-of nid f))
                              (pure-op? (ir/op nid f))
                              (not= :block-arg (ir/op nid f))
                              (every? (fn [r]
                                        (or (invariant r)
                                            (not (loop-set (ir/block-of r f)))))
                                      (ir/refs nid f)))))
               (into invariant))]
      (if (= invariant new-invariant)
        invariant
        (recur new-invariant)))))

(defn hoist-one! [f nid pre-header]
  "Clone Inst nid into pre-header, redirect all uses to the clone,
   remove the original from its block. Returns the new InstId (the clone
   in the pre-header).

   After this, nid is marked :invalid and all uses flow through the clone.
   The clone is positioned in the pre-header."
  (let [op        (ir/op nid f)
        refs      (ir/refs nid f)
        aux       (ir/aux nid f)
        clone     (ir/add-inst f pre-header op refs aux)
        from-block (ir/block-of nid f)]
    (ir/replace-all-uses! f nid clone)
    (ir/remove-inst! f from-block nid)
    clone))

;; --- threading hoisted values through the loop header ----------------

(defn- find-in-loop-users [f clone loop-set]
  "Find all Insts in loop-set that reference clone."
  (->> (range (count (:insts @f)))
       (filter (fn [nid]
                 (and (not= :invalid (ir/op nid f))
                      (loop-set (ir/block-of nid f))
                      (some #(= % clone) (ir/refs nid f)))))
       vec))

(defn thread-hoisted-through-header! [f loop-info hoisted-pairs]
  "For each hoisted value used inside the loop body, add a header
   BlockArg, rewire in-loop uses to the new param, update each header
   pred's branch-target args appropriately.

   loop-info = {:header BLK :body SET :preheader BLK}
   hoisted-pairs = vector of [original-id clone-id] from hoisting

   Per pred of header:
     - if pred IS in loop body (back-edge) → pass new-param-id
     - else (forward edge) → pass clone-id (defined in pre-header)

   Algorithm matches OLD pkg/ir/passes/licm.go threadHoistedThroughHeader."
  (let [{:keys [header body preheader]} loop-info
        ;; Per hoisted-pair, find body-Insts that consume the clone.
        ;; clone-id is what got installed in the pre-header; its uses
        ;; are now all the uses inherited from the original.
        threads
        (->> hoisted-pairs
             (keep (fn [[_orig clone]]
                     (let [users-in-loop (find-in-loop-users f clone body)]
                       (when (seq users-in-loop)
                         {:clone clone :users users-in-loop}))))
             vec)]
    (when (seq threads)
      ;; Allocate one new header BlockArg per hoisted value that's
      ;; consumed inside the loop. Store the mapping from clone → param.
      (let [threads-with-params
            (mapv (fn [t]
                    (let [pos (count (ir/block-params header f))
                          pid (ir/add-inst f header :block-arg [] pos)]
                      (ir/add-block-param! f header pid)
                      (assoc t :param pid)))
                  threads)]

        ;; Step 1: Rewire in-loop user refs from clone → param.
        ;; If user is in the header block, refs rewrite directly to param.
        ;; If user is in a non-header loop block, we must thread the value
        ;; from header to user-block by adding a chain of block-params and
        ;; extending each intermediate predecessor's branch-target args.
        (doseq [{:keys [clone param users]} threads-with-params
                user users]
          (let [user-blk (ir/block-of user f)]
            (if (= user-blk header)
              (let [new-refs (mapv (fn [r] (if (= r clone) param r))
                                   (ir/refs user f))]
                (ir/set-refs! f user new-refs))
              ;; Non-header user: walk from user-blk back to header via
              ;; body predecessors, collect the path, then thread forward.
              (let [path (loop [cur user-blk acc []]
                           (if (= cur header)
                             acc
                             (let [body-preds (filter body (ir/block-preds cur f))]
                               (if (empty? body-preds)
                                 ;; Shouldn't happen in well-formed loop: every
                                 ;; non-header body block has a body-predecessor.
                                 acc
                                 (recur (first body-preds) (cons cur acc))))))
                    ;; Forward-thread: for each block on path, add a block-arg
                    ;; param and extend the predecessor's branch-target args.
                    final-param
                    (reduce (fn [prev-param dst-blk]
                              (let [pos        (count (ir/block-params dst-blk f))
                                    new-pid    (ir/add-inst f dst-blk :block-arg [] pos)
                                    _          (ir/add-block-param! f dst-blk new-pid)
                                    ;; Find the unique body-pred → dst-blk edge.
                                    src-blk    (first (filter body (ir/block-preds dst-blk f)))
                                    src-term   (ir/block-term src-blk f)
                                    src-op     (ir/op src-term f)
                                    src-aux    (ir/aux src-term f)]
                                (case src-op
                                  :branch
                                    (let [new-args (conj (vec (ir/branch-target-args src-aux))
                                                         prev-param)
                                          target   (ir/branch-target-target src-aux)
                                          new-bt   (ir/new-branch-target target new-args)]
                                      (ir/set-aux! f src-term new-bt)
                                      ;; If target (e.g. an inner loop header) has other
                                      ;; preds in the loop body, they must also pass the
                                      ;; new param so arg/parity stays balanced.
                                      (doseq [other-pred (ir/block-preds target f)
                                              :when (and (body other-pred)
                                                         (not= other-pred src-blk))]
                                        (let [term (ir/block-term other-pred f)
                                              aux  (ir/aux term f)]
                                          (when (= :branch (ir/op term f))
                                            (ir/set-aux! f term
                                              (ir/new-branch-target target
                                                (conj (vec (ir/branch-target-args aux)) new-pid)))))))
                                  :branch-if
                                    ;; Symmetric invariant (validate.lg's
                                    ;; check-branch-if-symmetric-args!): both
                                    ;; targets' args vectors must be identical.
                                    ;; Append prev-param to BOTH true and false
                                    ;; args; if the sibling target isn't the
                                    ;; thread destination, add a block-param to
                                    ;; that block too so its params count matches.
                                    (let [tt (ir/cond-target-true src-aux)
                                          ft (ir/cond-target-false src-aux)
                                          tt-blk (ir/branch-target-target tt)
                                          ft-blk (ir/branch-target-target ft)
                                          ;; If sibling-blk isn't dst-blk, give it a
                                          ;; new block-arg to keep param counts
                                          ;; balanced. (For dst-blk we already added
                                          ;; new-pid above.)
                                          _ (when (not= tt-blk dst-blk)
                                              (let [pos2 (count (ir/block-params tt-blk f))
                                                    pid2 (ir/add-inst f tt-blk :block-arg [] pos2)]
                                                (ir/add-block-param! f tt-blk pid2)))
                                          _ (when (not= ft-blk dst-blk)
                                              (let [pos2 (count (ir/block-params ft-blk f))
                                                    pid2 (ir/add-inst f ft-blk :block-arg [] pos2)]
                                                (ir/add-block-param! f ft-blk pid2)))
                                          new-tt (ir/new-branch-target tt-blk
                                                   (conj (vec (ir/branch-target-args tt))
                                                         prev-param))
                                          new-ft (ir/new-branch-target ft-blk
                                                   (conj (vec (ir/branch-target-args ft))
                                                         prev-param))
                                          new-aux (-> src-aux
                                                      (ir/cond-target-set-true! new-tt)
                                                      (ir/cond-target-set-false! new-ft))]
                                      (ir/set-aux! f src-term new-aux)))
                                new-pid))
                            param
                            path)
                    new-refs (mapv (fn [r] (if (= r clone) final-param r))
                                   (ir/refs user f))]
                (ir/set-refs! f user new-refs)))))

        ;; Step 2: Update each header pred's branch-target args.
        ;; For each thread, append the right value based on whether pred
        ;; is in the loop body.
        ;;   - Back-edge (from loop): pass the param (loop-carried)
        ;;   - Forward edge (from pre-header): pass the clone (from pre-header)
        (doseq [pred (ir/block-preds header f)
                :let [term      (ir/block-term pred f)
                      op        (ir/op term f)
                      aux       (ir/aux term f)
                      from-loop? (body pred)
                      extras    (mapv (fn [{:keys [clone param]}]
                                        (if from-loop? param clone))
                                      threads-with-params)]]
          (case op
            :branch
              (let [new-args (into (vec (ir/branch-target-args aux)) extras)
                    new-bt   (ir/new-branch-target
                              (ir/branch-target-target aux) new-args)]
                (ir/set-aux! f term new-bt))
            :branch-if
              ;; Update whichever side(s) target the header.
              (let [tt       (ir/cond-target-true aux)
                    ft       (ir/cond-target-false aux)
                    new-aux  (cond-> aux
                               (= header (ir/branch-target-target tt))
                                 (ir/cond-target-set-true!
                                   (ir/new-branch-target header
                                     (into (vec (ir/branch-target-args tt)) extras)))
                               (= header (ir/branch-target-target ft))
                                 (ir/cond-target-set-false!
                                   (ir/new-branch-target header
                                     (into (vec (ir/branch-target-args ft)) extras))))]
                (ir/set-aux! f term new-aux))))))))

;; --- driver ---------------------------------------------------------

(defn licm-one-loop [f back-edge]
  "Run LICM on a single loop identified by back-edge."
  (let [header     (nth back-edge 1)
        loop-set   (loop-blocks f back-edge)
        pre-header (unique-pre-header f header loop-set)]
    (when pre-header
      (let [hoistable      (collect-hoistable f loop-set)
            ;; Hoist each in deterministic order, collecting [orig → clone] pairs.
            hoisted-pairs  (mapv (fn [orig]
                                   [orig (hoist-one! f orig pre-header)])
                                 (sort hoistable))]
        (when (seq hoisted-pairs)
          (thread-hoisted-through-header!
            f
            {:header header :body loop-set :preheader pre-header}
            hoisted-pairs))))))

(defn licm [f]
  "Run LICM on every natural loop in f."
  (doseq [be (back-edges f)]
    (licm-one-loop f be))
  f)
