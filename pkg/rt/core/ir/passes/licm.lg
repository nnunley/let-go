;; Loop-Invariant Code Motion — Lisp port.
;;
;; LICM identifies natural loops (via dominance + back-edges) and
;; hoists loop-invariant pure Insts to a pre-header that runs once
;; before the loop body.
;;
;; Algorithm:
;;   1. Compute dominators (Lisp-side via ir.dominance/dominates?).
;;   2. Find back-edges: pred → header pairs where header dominates pred.
;;   3. For each back-edge:
;;      a. Compute the loop's block set (all blocks that can reach pred
;;         without exiting via header).
;;      b. Identify the pre-header: a non-loop pred of header. We
;;         assume there is exactly one such pred (the typical Phase 1
;;         output shape). If zero or multiple, skip this loop.
;;      c. Walk Insts in loop blocks; for each pure Inst whose ALL
;;         operands are defined OUTSIDE the loop set, hoist it to the
;;         pre-header by moving the Inst's Block to pre-header and
;;         appending it to pre-header.Insts (just before pre-header's
;;         terminator).
;;   4. After hoisting, cross-block direct refs from hoisted defs to
;;      in-loop uses will fire Lower's guardrail — thread-block-args
;;      cleans those up.
;;
;; MVP limitations:
;;   - One pre-header pred only (skip multi-pre-header cases)
;;   - No cascading hoist (a hoisted Inst whose operands are also
;;     loop-invariant doesn't trigger re-evaluation of the rest of
;;     the loop body — caller can re-run LICM to fixed point)
;;   - Doesn't detect/handle side-effect-free OpCall (only the pure
;;     ops in pure-ops set)

(ns ir.passes.licm
  (:require [ir.passes :refer []]
            [ir.dominance :as dom]))

(def pure-ops
  "Ops safe to hoist — same as DCE's pure set."
  #{:const :load-arg :load-closed :block-arg
    :add :sub :mul :lt :lte :gt :gte :eq :inc :dec})

(defn pure-op? [op] (contains? pure-ops op))

;; --- back-edge + loop-block detection ---------------------------------

(defn back-edges [f]
  "Return a vector of [pred-block header-block] pairs where
   header-block dominates pred-block (the back-edge invariant)."
  (vec
    (for [header (ir/blocks f)
          pred   (ir/block-preds header f)
          :when  (dom/dominates? f header pred)]
      [pred header])))

(defn reachable-without [f start avoid]
  "Set of blocks reachable from `start` by walking PREDECESSORS,
   excluding `avoid`. Used to compute the loop body: from the back-edge
   tail, walk back through preds; the loop is everything you reach
   before hitting the header (which we 'avoid' so we don't escape
   upward past the loop)."
  (loop [visited  #{start}
         frontier [start]]
    (if (empty? frontier)
      visited
      (let [b         (peek frontier)
            rest-wl   (pop frontier)
            new-preds (->> (ir/block-preds b f)
                           (remove #(or (= % avoid) (visited %)))
                           vec)]
        (recur (into visited new-preds)
               (into rest-wl new-preds))))))

(defn loop-blocks [f [pred header]]
  "Compute the set of blocks comprising the natural loop for back-edge
   [pred header]: {header} ∪ {blocks reachable from pred without going
   through header}."
  (conj (reachable-without f pred header) header))

(defn unique-pre-header [f header loop-set]
  "Return the unique non-loop predecessor of `header`, or nil if
   there isn't exactly one. That pred is our pre-header."
  (let [outs (remove loop-set (ir/block-preds header f))]
    (when (= 1 (count outs))
      (first outs))))

;; --- loop-invariance analysis + hoisting ----------------------------

(defn operand-defined-outside? [f inst loop-set]
  "True iff every Refs entry of `inst` is defined in a block NOT in
   `loop-set`. Constants count as outside-defined (their block is
   typically the entry but we don't special-case)."
  (let [refs (ir/refs inst f)]
    (every? (fn [r] (not (contains? loop-set (ir/block-of r f)))) refs)))

(defn collect-hoistable [f loop-set]
  "Fixed-point invariance marking. Returns set of InstIds in loop-set
   whose op is pure-op AND all refs are loop-invariant. An Inst's refs
   are loop-invariant if every ref is either outside loop-set OR was
   marked in a previous iteration. Iterates to fixed point because
   marking one Inst can satisfy another's refs."
  (loop [invariant #{}]
    (let [new-invariant
          (->> (range (count (:insts @f)))
               (filter (fn [nid]
                         (and (not (invariant nid))
                              (not= :invalid (ir/op nid f))
                              (loop-set (ir/block-of nid f))
                              (pure-op? (ir/op nid f))
                              (not= :block-arg (ir/op nid f))
                              (every? (fn [r]
                                        (or (invariant r)
                                            (not (loop-set (ir/block-of r f)))))
                                      (ir/refs nid f)))))
               (into invariant))]
      (if (= invariant new-invariant)
        invariant
        (recur new-invariant)))))

(defn hoist-one! [f nid pre-header]
  "Clone Inst nid into pre-header, redirect all uses to the clone,
   remove the original from its block. Returns the new InstId (the clone
   in the pre-header).

   After this, nid is marked :invalid and all uses flow through the clone.
   The clone is positioned in the pre-header."
  (let [op        (ir/op nid f)
        refs      (ir/refs nid f)
        aux       (ir/aux nid f)
        clone     (ir/add-inst f pre-header op refs aux)
        from-block (ir/block-of nid f)]
    (ir/replace-all-uses! f nid clone)
    (ir/remove-inst! f from-block nid)
    clone))

;; --- threading hoisted values through the loop header ----------------

(defn- find-in-loop-users [f clone loop-set]
  "Find all Insts in loop-set that reference clone."
  (->> (range (count (:insts @f)))
       (filter (fn [nid]
                 (and (not= :invalid (ir/op nid f))
                      (loop-set (ir/block-of nid f))
                      (some #(= % clone) (ir/refs nid f)))))
       vec))

(defn thread-hoisted-through-header! [f loop-info hoisted-pairs]
  "For each hoisted value used inside the loop body, add a block-arg parameter
   to EVERY block in the loop body. Map each block to its new parameter ID.
   Update the branch targets of all predecessors of loop blocks to pass the
   hoisted value. Rewire all in-loop uses to the corresponding block's parameter.

   loop-info = {:header BLK :body SET :preheader BLK}
   hoisted-pairs = vector of [original-id clone-id] from hoisting"
  (let [{:keys [header body preheader]} loop-info
        ;; Per hoisted-pair, find body-Insts that consume the clone.
        ;; clone-id is what got installed in the pre-header; its uses
        ;; are now all the uses inherited from the original.
        threads
        (->> hoisted-pairs
             (keep (fn [[_orig clone]]
                     (let [users-in-loop (find-in-loop-users f clone body)]
                       (when (seq users-in-loop)
                         {:clone clone :users users-in-loop}))))
             vec)]
    (when (seq threads)
      (doseq [{:keys [clone users]} threads]
        ;; 1. Allocate a block-arg parameter in EVERY block of the loop body.
        ;; Create a map of block-id -> param-id.
        (let [block-params-map
              (reduce (fn [m blk]
                        (let [pos (count (ir/block-params blk f))
                              pid (ir/add-inst f blk :block-arg [] pos)]
                          (ir/add-block-param! f blk pid)
                          (assoc m blk pid)))
                      {}
                      body)]

          ;; 2. Update in-loop users. Each user in block `b` should reference block-params-map[b].
          (doseq [user users]
            (let [user-blk (ir/block-of user f)
                  param    (block-params-map user-blk)
                  new-refs (mapv (fn [r] (if (= r clone) param r))
                                 (ir/refs user f))]
              (ir/set-refs! f user new-refs)))

          ;; 3. Update all branches targeting any block in the loop body.
          ;; The source of the edge can be `preheader` or any block in the loop body.
          (doseq [src (conj (vec body) preheader)
                  :let [term (ir/block-term src f)]
                  :when (and term (> term 0))
                  :let [op      (ir/op term f)
                        aux     (ir/aux term f)
                        ;; Determine the value being carried from `src`.
                        ;; If `src` is `preheader`, the value is `clone`.
                        ;; If `src` is in the loop body, the value is `block-params-map[src]`.
                        val-to-pass (if (= src preheader)
                                      clone
                                      (block-params-map src))]]
            (case op
              :branch
                (let [tgt (ir/branch-target-target aux)]
                  (when (body tgt)
                    ;; Target is in the loop, append val-to-pass to args
                    (let [new-args (conj (vec (ir/branch-target-args aux)) val-to-pass)
                          new-bt   (ir/new-branch-target tgt new-args)]
                      (ir/set-aux! f term new-bt))))
              :branch-if
                (let [tt (ir/cond-target-true aux)
                      ft (ir/cond-target-false aux)
                      tt-tgt (ir/branch-target-target tt)
                      ft-tgt (ir/branch-target-target ft)
                      tt-in-loop? (body tt-tgt)
                      ft-in-loop? (body ft-tgt)]
                  (when (or tt-in-loop? ft-in-loop?)
                    ;; Symmetric invariant: both targets' args vectors must be identical!
                    ;; So if either target is in the loop, we must append val-to-pass to both.
                    ;; If one of the targets is outside the loop, it must be balanced with a new block parameter.
                    (when (not tt-in-loop?)
                      (let [pos (count (ir/block-params tt-tgt f))
                            pid (ir/add-inst f tt-tgt :block-arg [] pos)]
                        (ir/add-block-param! f tt-tgt pid)))
                    (when (not ft-in-loop?)
                      (let [pos (count (ir/block-params ft-tgt f))
                            pid (ir/add-inst f ft-tgt :block-arg [] pos)]
                        (ir/add-block-param! f ft-tgt pid)))
                    (let [new-tt (ir/new-branch-target tt-tgt (conj (vec (ir/branch-target-args tt)) val-to-pass))
                          new-ft (ir/new-branch-target ft-tgt (conj (vec (ir/branch-target-args ft)) val-to-pass))
                          new-aux (-> aux
                                      (ir/cond-target-set-true! new-tt)
                                      (ir/cond-target-set-false! new-ft))]
                      (ir/set-aux! f term new-aux))))
              nil)))))))

;; --- driver ---------------------------------------------------------

(defn licm-one-loop [f back-edge]
  "Run LICM on a single loop identified by back-edge."
  (let [header     (nth back-edge 1)
        loop-set   (loop-blocks f back-edge)
        pre-header (unique-pre-header f header loop-set)]
    (when pre-header
      (let [hoistable      (collect-hoistable f loop-set)
            ;; Hoist each in deterministic order, collecting [orig → clone] pairs.
            hoisted-pairs  (mapv (fn [orig]
                                   [orig (hoist-one! f orig pre-header)])
                                 (sort hoistable))]
        (when (seq hoisted-pairs)
          (thread-hoisted-through-header!
            f
            {:header header :body loop-set :preheader pre-header}
            hoisted-pairs))))))

(defn licm [f]
  "Run LICM on every natural loop in f."
  (doseq [be (back-edges f)]
    (licm-one-loop f be))
  f)
